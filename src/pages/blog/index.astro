---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogSkeleton from '../../components/BlogSkeleton.astro';
import { getAllBlogPosts, getBlogCategories } from '../../lib/blog';

// Get initial posts and categories
const initialPosts = await getAllBlogPosts();
const categories = ["Semua", ...await getBlogCategories()];

// Initial batch size
const INITIAL_BATCH_SIZE = 9;
const initialBatch = initialPosts.slice(0, INITIAL_BATCH_SIZE);
const totalPosts = initialPosts.length;
const hasMoreInitial = totalPosts > INITIAL_BATCH_SIZE;
---

<Layout title="Blog - Digital360" description="Temukan insight terbaru tentang teknologi dan transformasi digital dari tim Digital360" lang="id">
  <Header />

  <!-- Language Banner -->
  <section class="bg-blue-50 border-b border-blue-200 py-3">
    <div class="container mx-auto px-4">
      <div class="flex items-center justify-center text-sm text-blue-800">
        <svg class="w-4 h-4 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span class="text-center">
          Blog articles are available in <strong>Bahasa Indonesia</strong> only.
          <a href="/" class="underline font-semibold hover:text-blue-900 mx-1">Return to homepage</a>
          for bilingual content.
        </span>
      </div>
    </div>
  </section>

  <main class="pt-20">
    <!-- Hero Section -->
    <section class="bg-gradient-to-r from-primary-800 to-primary-900 text-white py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl">
          <h1 class="text-4xl md:text-5xl font-bold mb-4">Digital360 Blog</h1>
          <p class="text-xl text-primary-100">
            Temukan insight terbaru tentang teknologi, transformasi digital, dan inovasi bisnis
          </p>
        </div>
      </div>
    </section>

    <!-- Blog Content -->
    <section class="py-16">
      <div class="container mx-auto px-4">
        <!-- Search Bar -->
        <div class="mb-8 max-w-2xl mx-auto">
          <div class="relative">
            <input
              type="text"
              id="searchInput"
              placeholder="Cari artikel..."
              class="w-full px-6 py-4 pr-12 rounded-full border-2 border-gray-200 focus:border-primary-800 focus:outline-none text-lg"
            />
            <svg class="w-6 h-6 absolute right-6 top-1/2 -translate-y-1/2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </div>
        </div>

        <!-- Category Filter -->
        <div class="mb-12">
          <div class="flex flex-wrap gap-2 justify-center" id="categoryFilters">
            {categories.map((category) => (
              <button
                data-category={category}
                class={`category-filter px-4 py-2 rounded-full font-medium transition-colors cursor-pointer inline-block ${
                  category === 'Semua'
                    ? "bg-primary-800 text-white"
                    : "bg-gray-200 text-gray-700 hover:bg-gray-300"
                }`}
              >
                {category}
              </button>
            ))}
          </div>
        </div>

        <!-- Blog Grid -->
        <div id="blogGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-8">
          <!-- Initial Posts (Server-side rendered) -->
          {initialBatch.map((post) => (
            <article
              data-category={post.category}
              data-slug={post.slug}
              class="blog-card bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300"
            >
              <div class="relative blog-card-image overflow-hidden aspect-video">
                <img
                  src={post.image}
                  alt={post.title}
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              </div>

              <div class="p-6">
                <!-- Category Badge & Tags -->
                <div class="mb-3 flex flex-wrap items-center gap-2">
                  <span class="inline-block bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-semibold">
                    {post.category}
                  </span>
                  {post.tags && post.tags.length > 0 ? (
                    post.tags.slice(0, 3).map((tag) => (
                      <span class="inline-block bg-gray-100 text-gray-600 px-2 py-1 rounded-full text-xs font-medium">
                        #{tag}
                      </span>
                    ))
                  ) : null}
                  {post.tags && post.tags.length > 3 ? (
                    <span class="inline-block bg-gray-100 text-gray-600 px-2 py-1 rounded-full text-xs font-medium">
                      +{post.tags.length - 3}
                    </span>
                  ) : null}
                </div>

                <h3 class="text-xl font-bold mb-3 line-clamp-2 hover:text-primary-800 transition-colors">
                  <a href={`/blog/${post.slug}`} class="hover:text-primary-800 transition-colors">
                    {post.title}
                  </a>
                </h3>

                <p class="text-gray-600 mb-4 line-clamp-3">
                  {post.excerpt}
                </p>

                <div class="flex items-center justify-between text-sm text-gray-500 mb-4">
                  <div class="flex items-center space-x-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                    <span>{post.date}</span>
                  </div>
                  <div class="flex items-center space-x-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <span>{post.readTime}</span>
                  </div>
                </div>

                <a
                  href={`/blog/${post.slug}`}
                  class="inline-flex items-center text-primary-800 font-semibold hover:text-primary-900 transition-colors"
                >
                  Baca Selengkapnya
                  <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>

        <!-- Skeleton Loader (hidden by default) -->
        <div id="blogSkeleton" class="hidden">
          <BlogSkeleton count={9} />
        </div>

        <!-- Load More Indicator -->
        <div id="loadMoreIndicator" class={`text-center py-8 ${hasMoreInitial ? '' : 'hidden'}`}>
          <div class="inline-flex items-center text-gray-500">
            <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-gray-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <span>Memuat lebih banyak artikel...</span>
          </div>
        </div>

        <!-- End of Posts Message -->
        <div id="endMessage" class={`text-center py-8 hidden`}>
          <p class="text-gray-500 text-lg">Semua artikel telah ditampilkan</p>
        </div>

        <!-- Filter Info -->
        <div class="text-center text-gray-600 mt-8">
          <p id="filterInfo">Menampilkan <span id="displayedCount">{initialBatch.length}</span> dari <span id="totalCount">{totalPosts}</span> artikel</p>
        </div>
      </div>
    </section>

    <!-- Sentinel element for infinite scroll -->
    <div id="sentinel" class={`h-20 ${hasMoreInitial ? '' : 'hidden'}`}></div>
  </main>
  <Footer />
</Layout>

<script define:vars={{ INITIAL_BATCH_SIZE, totalPosts }}>
  // Configuration
  const API_BASE = '/api/blog';
  const SCROLL_DELAY = 500;

  // State
  let currentOffset = INITIAL_BATCH_SIZE;
  let isLoading = false;
  let hasMoreItems = totalPosts > INITIAL_BATCH_SIZE;
  let currentCategory = 'Semua';
  let currentSearch = '';
  let searchTimeout = null;
  let loadTimeout = null;
  let totalPostsCount = totalPosts;

  // DOM elements
  const blogGrid = document.getElementById('blogGrid');
  const blogSkeleton = document.getElementById('blogSkeleton');
  const loadMoreIndicator = document.getElementById('loadMoreIndicator');
  const endMessage = document.getElementById('endMessage');
  const filterInfo = document.getElementById('filterInfo');
  const displayedCount = document.getElementById('displayedCount');
  const totalCount = document.getElementById('totalCount');
  const filterButtons = document.querySelectorAll('.category-filter');
  const searchInput = document.getElementById('searchInput');
  const sentinel = document.getElementById('sentinel');

  // Show skeleton loader
  function showSkeleton() {
    if (blogSkeleton) {
      blogSkeleton.classList.remove('hidden');
    }
    loadMoreIndicator?.classList.add('hidden');
  }

  // Hide skeleton loader
  function hideSkeleton() {
    if (blogSkeleton) {
      blogSkeleton.classList.add('hidden');
    }
  }

  // Update filter info
  function updateFilterInfo(displayed, total) {
    if (displayedCount) displayedCount.textContent = displayed.toString();
    if (totalCount) totalCount.textContent = total.toString();
  }

  // Show load more indicator
  function showLoadMoreIndicator() {
    loadMoreIndicator?.classList.remove('hidden');
  }

  // Hide load more indicator
  function hideLoadMoreIndicator() {
    loadMoreIndicator?.classList.add('hidden');
  }

  // Show end message
  function showEndMessage() {
    endMessage?.classList.remove('hidden');
    sentinel?.classList.add('hidden');
  }

  // Hide end message
  function hideEndMessage() {
    endMessage?.classList.add('hidden');
  }

  // Create blog card HTML
  function createBlogCard(post) {
    const article = document.createElement('article');
    article.className = 'blog-card bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300';
    article.setAttribute('data-category', post.category);
    article.setAttribute('data-slug', post.slug);

    // Create tags HTML
    let tagsHtml = '';
    if (post.tags && post.tags.length > 0) {
      const displayTags = post.tags.slice(0, 3);
      tagsHtml = displayTags.map(tag => `
        <span class="inline-block bg-gray-100 text-gray-600 px-2 py-1 rounded-full text-xs font-medium">
          #${tag}
        </span>
      `).join('');

      if (post.tags.length > 3) {
        tagsHtml += `
          <span class="inline-block bg-gray-100 text-gray-600 px-2 py-1 rounded-full text-xs font-medium">
            +${post.tags.length - 3}
          </span>
        `;
      }
    }

    article.innerHTML = `
      <div class="relative blog-card-image overflow-hidden aspect-video">
        <img
          src="${post.image}"
          alt="${post.title}"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
          loading="lazy"
        />
      </div>

      <div class="p-6">
        <!-- Category Badge & Tags -->
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <span class="inline-block bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-semibold">
            ${post.category}
          </span>
          ${tagsHtml}
        </div>

        <h3 class="text-xl font-bold mb-3 line-clamp-2 hover:text-primary-800 transition-colors">
          <a href="/blog/${post.slug}" class="hover:text-primary-800 transition-colors">
            ${post.title}
          </a>
        </h3>

        <p class="text-gray-600 mb-4 line-clamp-3">
          ${post.excerpt}
        </p>

        <div class="flex items-center justify-between text-sm text-gray-500 mb-4">
          <div class="flex items-center space-x-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <span>${post.date}</span>
          </div>
          <div class="flex items-center space-x-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>${post.readTime}</span>
          </div>
        </div>

        <a
          href="/blog/${post.slug}"
          class="inline-flex items-center text-primary-800 font-semibold hover:text-primary-900 transition-colors"
        >
          Baca Selengkapnya
          <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    `;

    // Add fade-in animation
    article.style.opacity = '0';
    article.style.transform = 'translateY(20px)';
    article.style.transition = 'opacity 0.5s ease, transform 0.5s ease';

    return article;
  }

  // Fetch posts from API
  async function fetchPosts(offset, search = '', category = 'all') {
    const params = new URLSearchParams({
      offset: offset.toString(),
      limit: INITIAL_BATCH_SIZE.toString()
    });

    if (category && category !== 'Semua' && category !== 'all') {
      params.append('category', category);
    }

    if (search) {
      params.append('search', search);
    }

    const response = await fetch(`${API_BASE}?${params}`);
    if (!response.ok) {
      throw new Error('Failed to fetch posts');
    }

    return response.json();
  }

  // Load more items
  async function loadMoreItems() {
    if (isLoading || !hasMoreItems) return;

    isLoading = true;
    showLoadMoreIndicator();

    try {
      const data = await fetchPosts(currentOffset, currentSearch, currentCategory);

      hideLoadMoreIndicator();

      if (data.posts && data.posts.length > 0) {
        data.posts.forEach((post, index) => {
          const postCard = createBlogCard(post);
          blogGrid.appendChild(postCard);

          // Trigger animation with staggered delay
          setTimeout(() => {
            postCard.style.opacity = '1';
            postCard.style.transform = 'translateY(0)';
          }, index * 100);
        });

        currentOffset += data.posts.length;
        hasMoreItems = data.hasMore;
        totalPostsCount = data.total;

        updateFilterInfo(currentOffset, totalPostsCount);

        if (!hasMoreItems) {
          showEndMessage();
        } else {
          sentinel?.classList.remove('hidden');
        }
      } else {
        hasMoreItems = false;
        showEndMessage();
      }
    } catch (error) {
      console.error('Error loading more posts:', error);
      hideLoadMoreIndicator();
    } finally {
      isLoading = false;
    }
  }

  // Reset and load (for search/filter)
  async function resetAndLoad() {
    // Clear existing posts
    const existingCards = blogGrid.querySelectorAll('.blog-card');
    existingCards.forEach(card => card.remove());

    // Reset state
    currentOffset = 0;
    hideEndMessage();
    showSkeleton();

    try {
      const data = await fetchPosts(0, currentSearch, currentCategory);

      hideSkeleton();

      if (data.posts && data.posts.length > 0) {
        data.posts.forEach((post, index) => {
          const postCard = createBlogCard(post);
          blogGrid.appendChild(postCard);

          // Trigger animation with staggered delay
          setTimeout(() => {
            postCard.style.opacity = '1';
            postCard.style.transform = 'translateY(0)';
          }, index * 100);
        });

        currentOffset = data.posts.length;
        hasMoreItems = data.hasMore;
        totalPostsCount = data.total;

        updateFilterInfo(currentOffset, totalPostsCount);

        if (!hasMoreItems) {
          showEndMessage();
        } else {
          sentinel?.classList.remove('hidden');
        }
      } else {
        hasMoreItems = false;
        showEndMessage();
        updateFilterInfo(0, 0);
      }
    } catch (error) {
      console.error('Error loading posts:', error);
      hideSkeleton();
    }
  }

  // Handle search input
  function handleSearch(value) {
    currentSearch = value;

    // Clear existing timeout
    if (searchTimeout) {
      clearTimeout(searchTimeout);
    }

    // Debounce search
    searchTimeout = setTimeout(() => {
      resetAndLoad();
    }, 500);
  }

  // Setup Intersection Observer for infinite scroll
  function setupIntersectionObserver() {
    const observerOptions = {
      root: null,
      rootMargin: '200px',
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !isLoading && hasMoreItems) {
          // Clear any existing load timeout
          if (loadTimeout) {
            clearTimeout(loadTimeout);
          }

          // Set new timeout for debounced loading
          loadTimeout = setTimeout(() => {
            loadMoreItems();
          }, SCROLL_DELAY);
        }
      });
    }, observerOptions);

    if (sentinel) {
      observer.observe(sentinel);
    }

    return observer;
  }

  // Update category button states
  function updateCategoryButtons(activeCategory) {
    filterButtons.forEach(button => {
      const buttonCategory = button.getAttribute('data-category');
      if (buttonCategory === activeCategory) {
        button.classList.remove('bg-gray-200', 'text-gray-700', 'hover:bg-gray-300');
        button.classList.add('bg-primary-800', 'text-white');
      } else {
        button.classList.remove('bg-primary-800', 'text-white');
        button.classList.add('bg-gray-200', 'text-gray-700', 'hover:bg-gray-300');
      }
    });
  }

  // Initialize event listeners
  document.addEventListener('DOMContentLoaded', () => {
    // Category filter buttons
    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const category = button.getAttribute('data-category');
        currentCategory = category;
        currentSearch = ''; // Reset search when category changes
        if (searchInput) searchInput.value = '';
        updateCategoryButtons(category);
        resetAndLoad();
      });
    });

    // Search input
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        handleSearch(e.target.value);
      });
    }

    // Setup infinite scroll
    setupIntersectionObserver();
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Aspect ratio for images */
  .aspect-video {
    aspect-ratio: 16 / 9;
  }
</style>
