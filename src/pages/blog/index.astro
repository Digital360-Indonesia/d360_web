---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getAllBlogPosts, getBlogCategories } from '../../lib/blog';

// Get ALL blog posts (not just initial batch)
const allPosts = await getAllBlogPosts();
const categories = ["Semua", ...await getBlogCategories()];

// Initial display
const INITIAL_BATCH_SIZE = 9;
const initialBatch = allPosts.slice(0, INITIAL_BATCH_SIZE);
const totalPosts = allPosts.length;
---

<Layout title="Blog - Digital360" description="Temukan insight terbaru tentang teknologi dan transformasi digital dari tim Digital360" lang="id">
  <Header />

  <!-- Language Banner -->
  <section class="bg-blue-50 border-b border-blue-200 py-3">
    <div class="container mx-auto px-4">
      <div class="flex items-center justify-center text-sm text-blue-800">
        <svg class="w-4 h-4 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span class="text-center">
          Blog articles are available in <strong>Bahasa Indonesia</strong> only.
          <a href="/" class="underline font-semibold hover:text-blue-900 mx-1">Return to homepage</a>
          for bilingual content.
        </span>
      </div>
    </div>
  </section>

  <main class="pt-20">
    <!-- Hero Section -->
    <section class="bg-gradient-to-r from-primary-800 to-primary-900 text-white py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl">
          <h1 class="text-4xl md:text-5xl font-bold mb-4">Digital360 Blog</h1>
          <p class="text-xl text-primary-100">
            Temukan insight terbaru tentang teknologi, transformasi digital, dan inovasi bisnis
          </p>
        </div>
      </div>
    </section>

    <!-- Blog Content -->
    <section class="py-16">
      <div class="container mx-auto px-4">
        <!-- Search Bar -->
        <div class="mb-8 max-w-2xl mx-auto">
          <div class="relative">
            <input
              type="text"
              id="searchInput"
              placeholder="Cari artikel..."
              class="w-full px-6 py-4 pr-12 rounded-full border-2 border-gray-200 focus:border-primary-800 focus:outline-none text-lg"
            />
            <svg class="w-6 h-6 absolute right-6 top-1/2 -translate-y-1/2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </div>
        </div>

        <!-- Category Filter -->
        <div class="mb-12">
          <div class="flex flex-wrap gap-2 justify-center" id="categoryFilters">
            {categories.map((category) => (
              <button
                data-category={category}
                class={`category-filter px-4 py-2 rounded-full font-medium transition-colors cursor-pointer inline-block ${
                  category === 'Semua'
                    ? "bg-primary-800 text-white"
                    : "bg-gray-200 text-gray-700 hover:bg-gray-300"
                }`}
              >
                {category}
              </button>
            ))}
          </div>
        </div>

        <!-- Results Info -->
        <div class="mb-6 text-center text-gray-600">
          <span id="displayedCount">{initialBatch.length}</span> dari <span id="totalCount">{totalPosts}</span> artikel
        </div>

        <!-- Blog Grid -->
        <div id="blogGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-8">
          <!-- Initial Posts (Server-side rendered) -->
          {initialBatch.map((post) => (
            <article
              data-category={post.category}
              data-slug={post.slug}
              class="blog-card bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300"
            >
              <div class="relative blog-card-image overflow-hidden aspect-video">
                <img
                  src={post.image}
                  alt={post.title}
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              </div>

              <div class="p-6">
                <!-- Category Badge & Tags -->
                <div class="mb-3 flex flex-wrap items-center gap-2">
                  <span class="inline-block bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-semibold">
                    {post.category}
                  </span>
                  {post.tags && post.tags.slice(0, 3).map((tag) => (
                    <span class="inline-block bg-gray-100 text-gray-600 px-2 py-1 rounded-full text-xs font-medium">
                      #{tag}
                    </span>
                  ))}
                </div>

                <h3 class="text-xl font-bold mb-3 line-clamp-2 hover:text-primary-800 transition-colors">
                  <a href={`/blog/${post.slug}`} class="hover:text-primary-800 transition-colors">
                    {post.title}
                  </a>
                </h3>

                <p class="text-gray-600 mb-4 line-clamp-3">
                  {post.excerpt}
                </p>

                <div class="flex items-center justify-between text-sm text-gray-500 mb-4">
                  <div class="flex items-center space-x-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                    <span>{post.date}</span>
                  </div>
                  <div class="flex items-center space-x-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <span>{post.readTime}</span>
                  </div>
                </div>

                <a
                  href={`/blog/${post.slug}`}
                  class="inline-flex items-center text-primary-800 font-semibold hover:text-primary-900 transition-colors"
                >
                  Baca Selengkapnya
                  <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>

        <!-- Load More Button -->
        <div class="text-center mb-8">
          <button
            id="loadMoreBtn"
            class="px-8 py-3 bg-primary-800 text-white font-semibold rounded-full hover:bg-primary-900 transition-colors duration-200"
          >
            Load More Articles
          </button>
        </div>

        <!-- End Message -->
        <div id="endMessage" class="hidden text-center text-gray-500 py-8">
          <p class="text-lg">Tidak ada lagi artikel untuk ditampilkan</p>
        </div>

        <!-- No Results Message -->
        <div id="noResults" class="hidden text-center py-16">
          <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <h3 class="text-xl font-semibold text-gray-600 mb-2">Tidak ada artikel ditemukan</h3>
          <p class="text-gray-500">Coba kata kunci atau kategori lain</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script define:vars={{ allPosts }}>
  // Embed all blog data directly
  window.ALL_BLOG_POSTS = allPosts;
</script>

<script src="https://cdn.jsdelivr.net/npm/fuse.js@7.0.0/dist/fuse.min.js"></script>

<script>
  // Get blog data from window
  const allPosts = window.ALL_BLOG_POSTS;

  const INITIAL_BATCH_SIZE = 9;
  const BATCH_INCREMENT = 9;

  let displayedPosts = [...allPosts.slice(0, INITIAL_BATCH_SIZE)];
  let currentIndex = INITIAL_BATCH_SIZE;
  let currentCategory = 'Semua';
  let fuse = null;

  // Initialize Fuse.js
  function initFuse() {
    const options = {
      keys: [
        { name: 'title', weight: 0.4 },
        { name: 'excerpt', weight: 0.3 },
        { name: 'tags', weight: 0.2 },
        { name: 'category', weight: 0.1 }
      ],
      threshold: 0.3,
      includeScore: true
    };
    fuse = new Fuse(allPosts, options);
  }

  // Filter by category
  function filterByCategory(posts, category) {
    if (category === 'Semua') return posts;
    return posts.filter(post => post.category === category);
  }

  // Search function
  function searchPosts(query) {
    if (!query.trim()) {
      return allPosts;
    }
    const results = fuse.search(query);
    return results.map(result => result.item);
  }

  // Get filtered and searched posts
  function getProcessedPosts() {
    const searchQuery = document.getElementById('searchInput').value;
    let posts = searchPosts(searchQuery);
    posts = filterByCategory(posts, currentCategory);
    return posts;
  }

  // Render blog cards
  function renderBlogCards(posts, append = false) {
    const blogGrid = document.getElementById('blogGrid');
    const noResults = document.getElementById('noResults');
    const endMessage = document.getElementById('endMessage');
    const loadMoreBtn = document.getElementById('loadMoreBtn');

    if (!append) {
      blogGrid.innerHTML = '';
    }

    if (posts.length === 0) {
      noResults?.classList.remove('hidden');
      loadMoreBtn?.classList.add('hidden');
      endMessage?.classList.add('hidden');
      return;
    }

    noResults?.classList.add('hidden');

    posts.forEach(post => {
      const article = document.createElement('article');
      article.className = 'blog-card bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300';
      article.setAttribute('data-category', post.category);
      article.setAttribute('data-slug', post.slug);

      const tagsHtml = post.tags && post.tags.slice(0, 3).map(tag =>
        `<span class="inline-block bg-gray-100 text-gray-600 px-2 py-1 rounded-full text-xs font-medium">#${tag}</span>`
      ).join('');

      article.innerHTML = `
        <div class="relative blog-card-image overflow-hidden aspect-video">
          <img
            src="${post.image}"
            alt="${post.title}"
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
            loading="lazy"
          />
        </div>

        <div class="p-6">
          <div class="mb-3 flex flex-wrap items-center gap-2">
            <span class="inline-block bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-semibold">
              ${post.category}
            </span>
            ${tagsHtml}
          </div>

          <h3 class="text-xl font-bold mb-3 line-clamp-2 hover:text-primary-800 transition-colors">
            <a href="/blog/${post.slug}" class="hover:text-primary-800 transition-colors">
              ${post.title}
            </a>
          </h3>

          <p class="text-gray-600 mb-4 line-clamp-3">
            ${post.excerpt}
          </p>

          <div class="flex items-center justify-between text-sm text-gray-500 mb-4">
            <div class="flex items-center space-x-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              <span>${post.date}</span>
            </div>
            <div class="flex items-center space-x-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span>${post.readTime}</span>
            </div>
          </div>

          <a
            href="/blog/${post.slug}"
            class="inline-flex items-center text-primary-800 font-semibold hover:text-primary-900 transition-colors"
          >
            Baca Selengkapnya
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      `;

      // Add fade-in animation
      article.style.opacity = '0';
      article.style.transform = 'translateY(20px)';
      blogGrid.appendChild(article);

      requestAnimationFrame(() => {
        article.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
        article.style.opacity = '1';
        article.style.transform = 'translateY(0)';
      });
    });

    updateCounts();
    updateLoadMoreButton();
  }

  // Update counts
  function updateCounts() {
    const processedPosts = getProcessedPosts();
    const displayed = document.querySelectorAll('#blogGrid .blog-card').length;
    document.getElementById('displayedCount').textContent = displayed;
    document.getElementById('totalCount').textContent = processedPosts.length;
  }

  // Update load more button
  function updateLoadMoreButton() {
    const processedPosts = getProcessedPosts();
    const displayed = document.querySelectorAll('#blogGrid .blog-card').length;
    const loadMoreBtn = document.getElementById('loadMoreBtn');
    const endMessage = document.getElementById('endMessage');

    if (displayed >= processedPosts.length) {
      loadMoreBtn?.classList.add('hidden');
      if (processedPosts.length > 0) {
        endMessage?.classList.remove('hidden');
      }
    } else {
      loadMoreBtn?.classList.remove('hidden');
      endMessage?.classList.add('hidden');
    }
  }

  // Load more function
  function loadMore() {
    const processedPosts = getProcessedPosts();
    const displayed = document.querySelectorAll('#blogGrid .blog-card').length;
    const nextBatch = processedPosts.slice(displayed, displayed + BATCH_INCREMENT);

    if (nextBatch.length > 0) {
      renderBlogCards(nextBatch, true);
    }
  }

  // Reset and re-render
  function resetAndRender() {
    currentIndex = 0;
    const processedPosts = getProcessedPosts();
    const initialBatch = processedPosts.slice(0, INITIAL_BATCH_SIZE);
    renderBlogCards(initialBatch, false);
    currentIndex = INITIAL_BATCH_SIZE;
  }

  // Initialize
  document.addEventListener('DOMContentLoaded', () => {
    initFuse();

    // Category filter buttons
    document.querySelectorAll('.category-filter').forEach(button => {
      button.addEventListener('click', (e) => {
        currentCategory = e.target.dataset.category;

        // Update active state
        document.querySelectorAll('.category-filter').forEach(btn => {
          btn.classList.remove('bg-primary-800', 'text-white');
          btn.classList.add('bg-gray-200', 'text-gray-700');
        });
        e.target.classList.remove('bg-gray-200', 'text-gray-700');
        e.target.classList.add('bg-primary-800', 'text-white');

        resetAndRender();
      });
    });

    // Search input
    const searchInput = document.getElementById('searchInput');
    let searchTimeout;
    searchInput.addEventListener('input', (e) => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        resetAndRender();
      }, 300);
    });

    // Load more button
    document.getElementById('loadMoreBtn').addEventListener('click', loadMore);
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .aspect-video {
    aspect-ratio: 16 / 9;
  }
</style>
