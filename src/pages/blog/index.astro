---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogCard from '../../components/BlogCard.astro';
import BlogSkeleton from '../../components/BlogSkeleton.astro';
import { getCollection } from 'astro:content';

// Get all published blog posts sorted by date (no server-side filtering)
const allBlogPosts = await getCollection('blog', ({ data }) => {
  return data.published;
});

// Sort by date (newest first) and map to required format
const sortedBlogPosts = allBlogPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map((post) => ({
    title: post.data.title,
    excerpt: post.data.excerpt,
    category: post.data.category,
    date: new Date(post.data.date).toLocaleDateString('id-ID', {
      day: 'numeric',
      month: 'long',
      year: 'numeric'
    }),
    readTime: post.data.readTime,
    image: post.data.image || 'https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=1200&h=715&fit=crop',
    slug: post.slug,
    tags: post.data.tags || []
  }));

// Get unique categories for filter
const categories = ["Semua", ...Array.from(new Set(allBlogPosts.map(post => post.data.category)))];

// Get all posts for client-side filtering and pagination
const blogPosts = sortedBlogPosts;

// Pagination settings
const POSTS_PER_PAGE = 9;
const TOTAL_PAGES = Math.ceil(blogPosts.length / POSTS_PER_PAGE);
---

<Layout title="Blog - Digital360" description="Temukan insight terbaru tentang teknologi dan transformasi digital dari tim Digital360" lang="id">
  <Header />

  <!-- Language Banner -->
  <section class="bg-blue-50 border-b border-blue-200 py-3">
    <div class="container mx-auto px-4">
      <div class="flex items-center justify-center text-sm text-blue-800">
        <svg class="w-4 h-4 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span class="text-center">
          Blog articles are available in <strong>Bahasa Indonesia</strong> only.
          <a href="/" class="underline font-semibold hover:text-blue-900 mx-1">Return to homepage</a>
          for bilingual content.
        </span>
      </div>
    </div>
  </section>

  <main class="pt-20">
    <!-- Hero Section -->
    <section class="bg-gradient-to-r from-primary-800 to-primary-900 text-white py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl">
          <h1 class="text-4xl md:text-5xl font-bold mb-4">Digital360 Blog</h1>
          <p class="text-xl text-primary-100">
            Temukan insight terbaru tentang teknologi, transformasi digital, dan inovasi bisnis
          </p>
        </div>
      </div>
    </section>

  <!-- Blog Content -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <!-- Category Filter -->
      <div class="mb-12">
        <div class="flex flex-wrap gap-2 justify-center">
          {categories.map((category) => (
            <button
              data-category={category}
              class={`category-filter px-4 py-2 rounded-full font-medium transition-colors cursor-pointer inline-block ${
                category === 'Semua'
                  ? "bg-primary-800 text-white"
                  : "bg-gray-200 text-gray-700 hover:bg-gray-300"
              }`}
            >
              {category}
            </button>
          ))}
        </div>
      </div>

      <!-- Blog Grid -->
      <div id="blogGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-8">
        <!-- Skeleton Loader (initially hidden) -->
        <div id="blogSkeleton" class="hidden">
          <BlogSkeleton count={POSTS_PER_PAGE} />
        </div>

        <!-- Blog Posts -->
        {blogPosts.slice(0, POSTS_PER_PAGE).map((post) => (
          <BlogCard {...post} data-category={post.category} />
        ))}
      </div>

      <!-- Pagination -->
      <nav id="pagination" class="flex justify-center items-center gap-2 mb-8" aria-label="Pagination">
        <!-- Pagination will be generated by JavaScript -->
      </nav>

      <!-- Filter Info -->
      <div class="text-center text-gray-600">
        <p id="filterInfo">Menampilkan {Math.min(POSTS_PER_PAGE, blogPosts.length)} dari {blogPosts.length} artikel</p>
      </div>

      </div>
  </section>

    </main>
  <Footer />
</Layout>

<script define:vars={{ blogPosts, POSTS_PER_PAGE, TOTAL_PAGES }}>
  // Get all blog posts from server-side data
  let posts = Array.isArray(blogPosts) ? blogPosts : [];
  let currentPage = 1;
  let currentCategory = 'Semua';
  let filteredPosts = [...posts];

  // DOM elements
  const blogGrid = document.getElementById('blogGrid');
  const blogSkeleton = document.getElementById('blogSkeleton');
  const filterButtons = document.querySelectorAll('.category-filter');
  const filterInfo = document.getElementById('filterInfo');
  const paginationNav = document.getElementById('pagination');

  // Show skeleton loader
  function showSkeleton() {
    if (blogSkeleton) {
      blogSkeleton.classList.remove('hidden');
    }
    // Hide existing blog cards
    const existingCards = blogGrid.querySelectorAll('article[data-category]');
    existingCards.forEach(card => card.style.display = 'none');
  }

  // Hide skeleton loader
  function hideSkeleton() {
    if (blogSkeleton) {
      blogSkeleton.classList.add('hidden');
    }
    // Show existing blog cards
    const existingCards = blogGrid.querySelectorAll('article[data-category]');
    existingCards.forEach(card => card.style.display = '');
  }

  // Filter posts function
  function filterPosts(category) {
    showSkeleton();

    // Simulate loading delay for better UX
    setTimeout(() => {
      currentCategory = category;
      filteredPosts = category === 'Semua'
        ? [...posts]
        : posts.filter(post => post.category === category);

      currentPage = 1; // Reset to first page when filter changes
      renderPage(currentPage);
      updateFilterInfo();
      updatePagination();
      updateCategoryButtons(category);
      hideSkeleton();
    }, 300);
  }

  // Render posts for specific page
  function renderPage(page) {
    const startIndex = (page - 1) * POSTS_PER_PAGE;
    const endIndex = startIndex + POSTS_PER_PAGE;
    const postsToShow = filteredPosts.slice(startIndex, endIndex);

    // Clear current grid but keep skeleton
    const skeleton = blogGrid.querySelector('#blogSkeleton');
    blogGrid.innerHTML = '';
    if (skeleton) {
      blogGrid.appendChild(skeleton);
    }

    // Add posts for current page
    postsToShow.forEach(post => {
      const postCard = createBlogCard(post);
      blogGrid.appendChild(postCard);
    });

    // Scroll to top of grid
    blogGrid.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Update filter info text
  function updateFilterInfo() {
    const startIndex = (currentPage - 1) * POSTS_PER_PAGE + 1;
    const endIndex = Math.min(currentPage * POSTS_PER_PAGE, filteredPosts.length);
    const categoryText = currentCategory === 'Semua' ? '' : ` dalam kategori "${currentCategory}"`;
    filterInfo.textContent = `Menampilkan ${startIndex}-${endIndex} dari ${filteredPosts.length} artikel${categoryText}`;
  }

  // Update pagination controls
  function updatePagination() {
    const totalPages = Math.ceil(filteredPosts.length / POSTS_PER_PAGE);

    if (totalPages <= 1) {
      paginationNav.innerHTML = '';
      return;
    }

    let paginationHTML = '';

    // Previous button
    paginationHTML += `
      <button
        onclick="goToPage(${currentPage - 1})"
        class="pagination-btn px-4 py-2 rounded-lg font-medium transition-colors ${
          currentPage === 1
            ? 'bg-gray-100 text-gray-400 cursor-not-allowed'
            : 'bg-white text-gray-700 hover:bg-gray-100 border border-gray-300'
        }"
        ${currentPage === 1 ? 'disabled' : ''}
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>
    `;

    // Page numbers
    const maxVisiblePages = 5;
    let startPage = Math.max(1, currentPage - Math.floor(maxVisiblePages / 2));
    let endPage = Math.min(totalPages, startPage + maxVisiblePages - 1);

    if (endPage - startPage < maxVisiblePages - 1) {
      startPage = Math.max(1, endPage - maxVisiblePages + 1);
    }

    if (startPage > 1) {
      paginationHTML += `
        <button
          onclick="goToPage(1)"
          class="pagination-btn px-4 py-2 rounded-lg font-medium bg-white text-gray-700 hover:bg-gray-100 border border-gray-300"
        >
          1
        </button>
      `;

      if (startPage > 2) {
        paginationHTML += `<span class="px-2 text-gray-500">...</span>`;
      }
    }

    for (let i = startPage; i <= endPage; i++) {
      paginationHTML += `
        <button
          onclick="goToPage(${i})"
          class="pagination-btn px-4 py-2 rounded-lg font-medium transition-colors ${
            i === currentPage
              ? 'bg-primary-800 text-white'
              : 'bg-white text-gray-700 hover:bg-gray-100 border border-gray-300'
          }"
        >
          ${i}
        </button>
      `;
    }

    if (endPage < totalPages) {
      if (endPage < totalPages - 1) {
        paginationHTML += `<span class="px-2 text-gray-500">...</span>`;
      }

      paginationHTML += `
        <button
          onclick="goToPage(${totalPages})"
          class="pagination-btn px-4 py-2 rounded-lg font-medium bg-white text-gray-700 hover:bg-gray-100 border border-gray-300"
        >
          ${totalPages}
        </button>
      `;
    }

    // Next button
    paginationHTML += `
      <button
        onclick="goToPage(${currentPage + 1})"
        class="pagination-btn px-4 py-2 rounded-lg font-medium transition-colors ${
          currentPage === totalPages
            ? 'bg-gray-100 text-gray-400 cursor-not-allowed'
            : 'bg-white text-gray-700 hover:bg-gray-100 border border-gray-300'
        }"
        ${currentPage === totalPages ? 'disabled' : ''}
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </button>
    `;

    paginationNav.innerHTML = paginationHTML;
  }

  // Update category button states
  function updateCategoryButtons(activeCategory) {
    filterButtons.forEach(button => {
      const buttonCategory = button.getAttribute('data-category');
      if (buttonCategory === activeCategory) {
        button.classList.remove('bg-gray-200', 'text-gray-700', 'hover:bg-gray-300');
        button.classList.add('bg-primary-800', 'text-white');
      } else {
        button.classList.remove('bg-primary-800', 'text-white');
        button.classList.add('bg-gray-200', 'text-gray-700', 'hover:bg-gray-300');
      }
    });
  }

  // Go to specific page
  window.goToPage = function(page) {
    const totalPages = Math.ceil(filteredPosts.length / POSTS_PER_PAGE);
    if (page < 1 || page > totalPages) return;

    showSkeleton();

    // Simulate loading delay for better UX
    setTimeout(() => {
      currentPage = page;
      renderPage(currentPage);
      updateFilterInfo();
      updatePagination();
      hideSkeleton();

      // Scroll to top of blog grid
      document.getElementById('blogGrid').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 300);
  }

  // Create blog card HTML
  function createBlogCard(post) {
    const article = document.createElement('article');
    article.className = 'bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300';
    article.setAttribute('data-category', post.category);

    article.innerHTML = `
      <div class="relative blog-card-image overflow-hidden">
        <img
          src="${post.image}"
          alt="${post.title}"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
          loading="lazy"
        />
      </div>

      <div class="p-6">
        <!-- Category Badge & Tags -->
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <span class="inline-block bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-semibold">
            ${post.category}
          </span>
          ${post.tags && post.tags.length > 0 ? `
            ${post.tags.slice(0, 3).map(tag => `
              <span class="inline-block bg-gray-100 text-gray-600 px-2 py-1 rounded-full text-xs font-medium">
                #${tag}
              </span>
            `).join('')}
            ${post.tags.length > 3 ? `
              <span class="inline-block bg-gray-100 text-gray-600 px-2 py-1 rounded-full text-xs font-medium">
                +${post.tags.length - 3}
              </span>
            ` : ''}
          ` : ''}
        </div>

        <h3 class="text-xl font-bold mb-3 line-clamp-2 hover:text-primary-800 transition-colors">
          <a href="/blog/${post.slug}" class="hover:text-primary-800 transition-colors">
            ${post.title}
          </a>
        </h3>

        <p class="text-gray-600 mb-4 line-clamp-3">
          ${post.excerpt}
        </p>

        <div class="flex items-center justify-between text-sm text-gray-500 mb-4">
          <div class="flex items-center space-x-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <span>${post.date}</span>
          </div>
          <div class="flex items-center space-x-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>${post.readTime}</span>
          </div>
        </div>

        <a
          href="/blog/${post.slug}"
          class="inline-flex items-center text-primary-800 font-semibold hover:text-primary-900 transition-colors"
        >
          Baca Selengkapnya
          <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    `;

    return article;
  }

  // Add click event listeners to filter buttons
  filterButtons.forEach(button => {
    button.addEventListener('click', () => {
      const category = button.getAttribute('data-category');
      filterPosts(category);
    });
  });

  // Check URL parameters on page load
  function initFromURL() {
    const urlParams = new URLSearchParams(window.location.search);
    const categoryFromURL = urlParams.get('category');
    const pageFromURL = parseInt(urlParams.get('page'));

    if (categoryFromURL) {
      filterPosts(categoryFromURL);
    } else {
      // Default to showing all posts
      filterPosts('Semua');
    }

    if (pageFromURL && !isNaN(pageFromURL)) {
      const totalPages = Math.ceil(filteredPosts.length / POSTS_PER_PAGE);
      if (pageFromURL >= 1 && pageFromURL <= totalPages) {
        currentPage = pageFromURL;
        renderPage(currentPage);
        updateFilterInfo();
        updatePagination();
      }
    }
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', () => {
    initFromURL();
  });
</script>


<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .pagination-btn:disabled {
    pointer-events: none;
  }
</style>
