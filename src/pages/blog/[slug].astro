---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => {
    return data.published;
  });

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;

// Format date for display
const formattedDate = new Date(post.data.date).toLocaleDateString('id-ID', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});

// Format ISO date for meta tags
const isoDate = new Date(post.data.date).toISOString();

// Get related posts (same category, excluding current post)
const relatedPosts = await getCollection('blog', ({ data }) => {
  return data.published && data.category === post.data.category;
});

const filteredRelatedPosts = relatedPosts
  .filter(relatedPost => relatedPost.slug !== post.slug)
  .slice(0, 2);

// Get the Content component
const { Content } = await post.render();

// Blog-specific meta
const blogTitle = `${post.data.title} - Digital360 Blog`;
const blogDescription = post.data.excerpt;
const blogImage = post.data.image || 'https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=1200&h=630&fit=crop';
const blogUrl = `https://digital360.id/blog/${post.slug}`;
const blogAuthor = post.data.author || 'Digital360';

// Prepare tags for schema
const schemaTags = post.data.tags || [];
---

<Layout
  title={blogTitle}
  description={blogDescription}
  lang="id"
  ogImage={blogImage}
  ogType="article"
  articlePublishedTime={isoDate}
  articleAuthor={blogAuthor}
>
  <!-- JSON-LD Structured Data - Article -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.data.title,
    "description": post.data.excerpt,
    "image": blogImage,
    "datePublished": isoDate,
    "dateModified": isoDate,
    "author": {
      "@type": "Organization",
      "name": blogAuthor
    },
    "publisher": {
      "@type": "Organization",
      "name": "Digital360",
      "logo": {
        "@type": "ImageObject",
        "url": "https://digital360.id/assets/images/logo-digital360-ori.png"
      }
    },
    "inLanguage": "id-ID",
    "keywords": schemaTags.join(', ')
  })} />

  <Header />
  <main class="pt-20">
    <!-- Hero Section -->
    <section class="bg-gradient-to-r from-primary-800 to-primary-900 text-white py-20">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <span class="inline-block bg-primary-800 text-white px-3 py-1 rounded-full text-sm font-semibold mb-4">
            {post.data.category}
          </span>
          <h1 class="text-4xl md:text-5xl font-bold mb-6">{post.data.title}</h1>
          <div class="flex items-center justify-center text-primary-100 mb-6">
            <span>{post.data.author}</span>
            <span class="mx-3">•</span>
            <time>{formattedDate}</time>
            <span class="mx-3">•</span>
            <span>{post.data.readTime}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Image -->
    <section class="py-8">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="featured-image-container">
            <img
              src={post.data.image || 'https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=1200&h=715&fit=crop'}
              alt={post.data.title}
              class="featured-image rounded-lg shadow-lg"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Blog Content -->
    <article class="py-12">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="prose prose-lg max-w-none">
            <Content />
          </div>

          <!-- Article Meta -->
          <div class="mt-12 pt-8 border-t border-gray-200">
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mb-8">
                <span class="text-gray-600 font-semibold">Tags:</span>
                {post.data.tags.map((tag) => (
                  <span class="bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm">
                    {tag}
                  </span>
                ))}
              </div>
            )}

            <!-- Share Buttons -->
            <div class="mb-8">
              <h3 class="text-lg font-semibold mb-4">Bagikan Artikel:</h3>
              <div class="flex gap-4">
                <button class="bg-primary-800 text-white px-4 py-2 rounded-lg hover:bg-primary-900 transition-colors">
                  LinkedIn
                </button>
                <button class="bg-primary-600 text-white px-4 py-2 rounded-lg hover:bg-primary-700 transition-colors">
                  Twitter
                </button>
                <button class="bg-primary-800 text-white px-4 py-2 rounded-lg hover:bg-primary-900 transition-colors">
                  Facebook
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </article>

    <!-- Related Articles -->
    {filteredRelatedPosts.length > 0 && (
      <section class="py-16 bg-gray-50">
        <div class="container mx-auto px-4">
          <div class="max-w-4xl mx-auto">
            <h2 class="text-3xl font-bold text-center mb-12">Artikel Terkait</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              {filteredRelatedPosts.map((relatedPost) => (
                <div class="bg-white rounded-lg shadow-md overflow-hidden">
                  {relatedPost.data.image ? (
                    <img
                      src={relatedPost.data.image}
                      alt={relatedPost.data.title}
                      class="h-48 w-full object-cover"
                    />
                  ) : (
                    <div class="h-48 bg-gradient-to-r from-blue-500 to-purple-600"></div>
                  )}
                  <div class="p-6">
                    <span class="text-sm text-primary-800 font-semibold">{relatedPost.data.category}</span>
                    <h3 class="text-xl font-bold mt-2 mb-3">{relatedPost.data.title}</h3>
                    <p class="text-gray-600 mb-4">{relatedPost.data.excerpt}</p>
                    <a href={`/blog/${relatedPost.slug}`} class="text-primary-800 font-semibold hover:text-primary-900">
                      Baca Selengkapnya →
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

      </main>
  <Footer />
</Layout>

<style>
  /* Enhanced prose styles */
  :global(.prose) {
    @apply text-gray-700;
  }

  :global(.prose h1) {
    @apply text-3xl font-bold text-gray-900 mb-6 mt-8;
  }

  :global(.prose h2) {
    @apply text-2xl font-bold text-gray-900 mb-4 mt-8 pb-2 border-b border-gray-200;
  }

  :global(.prose h3) {
    @apply text-xl font-semibold text-gray-900 mb-3 mt-6;
  }

  :global(.prose p) {
    @apply mb-4 leading-relaxed text-gray-700;
  }

  :global(.prose ul) {
    @apply mb-4 list-disc pl-6 space-y-2;
  }

  :global(.prose ol) {
    @apply mb-4 list-decimal pl-6 space-y-2;
  }

  :global(.prose li) {
    @apply text-gray-700 leading-relaxed;
  }

  :global(.prose strong) {
    @apply font-semibold text-gray-900;
  }

  :global(.prose a) {
    @apply text-primary-600 hover:text-primary-800 underline transition-colors;
  }

  :global(.prose blockquote) {
    @apply border-l-4 border-primary-300 bg-primary-50 p-4 my-4 italic text-gray-700 rounded-r-lg;
  }

  :global(.prose code) {
    @apply bg-gray-100 text-primary-600 px-2 py-1 rounded text-sm font-mono;
  }

  :global(.prose pre) {
    @apply bg-gray-900 text-gray-100 p-4 rounded-lg overflow-x-auto my-4;
  }

  :global(.prose pre code) {
    @apply bg-transparent text-gray-100 p-0;
  }

  :global(.prose hr) {
    @apply border-gray-200 my-8;
  }

  :global(.prose img) {
    @apply rounded-lg shadow-md my-6 w-full max-w-none;
  }

  :global(.prose p img) {
    @apply rounded-lg shadow-md my-4 w-full max-w-none;
  }

  :global(.image-container) {
    @apply my-6;
  }

  :global(.image-container img) {
    @apply rounded-lg shadow-lg w-full max-w-none;
  }

  :global(.image-caption) {
    @apply text-center text-sm text-gray-600 italic mt-2;
  }

  .featured-image-container {
    @apply my-6 w-full;
    aspect-ratio: 1200 / 715;
  }

  .featured-image {
    @apply rounded-lg shadow-lg w-full h-full object-cover;
  }
</style>