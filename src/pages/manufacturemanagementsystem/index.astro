---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Manufacture360 - Complete Manufacturing Management System | Digital360"
  description="Streamline your manufacturing operations with Manufacture360 - comprehensive solution for production planning, inventory, quality control, and more."
  ogImage="https://digital360.id/assets/images/manufacture360-og.jpg"
>
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="hero-section">
      <div class="container">
        <div class="hero-content">
          <div class="hero-text">
            <img src="/assets/images/satu360manufacture-logo_wh.png" alt="Manufacture360" class="hero-logo" />
            <p class="hero-description" data-lang-en="All-in-one manufacturing management: production planning, inventory, quality control & tracking. More efficient, more productive." data-lang-id="Semua dalam satu sistem manajemen manufaktur: perencanaan produksi, inventory, quality control & tracking. Lebih efisien, lebih produktif.">All-in-one manufacturing management: production planning, inventory, quality control & tracking. More efficient, more productive.</p>
            <div class="hero-buttons">
              <a href="#demo" class="btn btn-primary" data-lang-en="Try Demo" data-lang-id="Coba Demo">Try Demo</a>
              <a href="https://wa.me/6285156858298?text=Hello%20Digital360,%20I%20want%20to%20schedule%20a%20consultation%20for%20Manufacture360" class="btn btn-secondary" target="_blank" rel="noopener" data-lang-en="Schedule Consultation" data-lang-id="Jadwalkan Konsultasi">Schedule Consultation</a>
            </div>
          </div>
          <div class="hero-image">
            <img src="/assets/images/business360-dashboard.png" alt="Manufacture360 Dashboard" />
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: Key Features -->
    <section class="features-section">
      <div class="container">
        <h2 class="section-title" data-lang-en="Why Choose Digital360 Manufacturing Management System?" data-lang-id="Mengapa Memilih Sistem Manajemen Manufaktur Digital360?">Why Choose Digital360 Manufacturing Management System?</h2>
        <div class="features-cards">
          <div class="feature-card">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 21V5a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v5m-4 0h4"></path>
              </svg>
            </div>
            <h3 data-lang-en="All-in-One Manufacturing Platform" data-lang-id="Platform Manufaktur Terintegrasi">All-in-One Manufacturing Platform</h3>
            <p data-lang-en="Replace multiple disconnected systems with one unified platform for your entire operation" data-lang-id="Ganti banyak sistem terpisah dengan satu platform terpadu untuk seluruh operasional Anda">Replace multiple disconnected systems with one unified platform for your entire operation</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 data-lang-en="Trusted by Industry Leaders" data-lang-id="Terpercaya oleh Pemimpin Industri">Trusted by Industry Leaders</h3>
            <p data-lang-en="Proven track record with hundreds of manufacturers across Indonesia achieving consistent results" data-lang-id="Terkerek baik dengan ratusan manufaktur di seluruh Indonesia yang mencapai hasil konsisten">Proven track record with hundreds of manufacturers across Indonesia achieving consistent results</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
              </svg>
            </div>
            <h3 data-lang-en="Scales as Your Business Grows" data-lang-id="Berkembang Bersama Bisnis Anda">Scales as Your Business Grows</h3>
            <p data-lang-en="Flexible system that adapts to your changing needs from startup to enterprise level" data-lang-id="Sistem fleksibel yang menyesuaikan dengan kebutuhan yang berubah dari startup hingga level enterprise">Flexible system that adapts to your changing needs from startup to enterprise level</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 data-lang-en="Dedicated Expert Support" data-lang-id="Support Expert Khusus">Dedicated Expert Support</h3>
            <p data-lang-en="Professional implementation team and ongoing support committed to your long-term success" data-lang-id="Tim implementasi profesional dan support berkelanjutan yang berkomitmen pada kesuksesan jangka panjang Anda">Professional implementation team and ongoing support committed to your long-term success</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
              </svg>
            </div>
            <h3 data-lang-en="Enterprise-Grade Security" data-lang-id="Keamanan Tingkat Enterprise">Enterprise-Grade Security</h3>
            <p data-lang-en="Your data is protected with bank-level encryption and strict access controls" data-lang-id="Data Anda dilindungi dengan enkripsi level bank dan kontrol akses yang ketat">Your data is protected with bank-level encryption and strict access controls</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <h3 data-lang-en="Customizable to Your Needs" data-lang-id"Dapat Disesuaikan dengan Kebutuhan Anda">Customizable to Your Needs</h3>
            <p data-lang-en="Tailored workflows and features that align with your unique manufacturing processes" data-lang-id="Workflow dan fitur yang disesuaikan dengan proses manufaktur unik Anda">Tailored workflows and features that align with your unique manufacturing processes</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 3: All Features (Carousel) -->
    <section class="all-features-section">
      <div class="container">
        <h2 class="section-title" data-lang-en="Complete Features for Your Business" data-lang-id="Fitur Lengkap untuk Bisnis Anda">Complete Features for Your Business</h2>
        <p class="section-description" data-lang-en="Everything you need to run your manufacturing business efficiently in one platform" data-lang-id="Semua yang Anda butuhkan untuk menjalankan bisnis manufaktur secara efisien dalam satu platform">Everything you need to run your manufacturing business efficiently in one platform</p>

        <div class="carousel-wrapper">
          <div class="carousel-track" id="carouselTrack">
            <div class="feature-slide">
              <img src="/assets/images/manufacturebsm-s3-1.png" alt="Manufacture ERP" class="slide-img" />
              <h3 data-lang-en="Manufacture ERP System" data-lang-id="Sistem ERP Manufaktur">Manufacture ERP System</h3>
              <p data-lang-en="Tailored ERP solution with centralized dashboard integrating production, inventory, sales, and finance in one platform" data-lang-id="Solusi ERP yang disesuaikan dengan dashboard terpusat mengintegrasikan produksi, inventory, sales, dan keuangan dalam satu platform">Tailored ERP solution with centralized dashboard integrating production, inventory, sales, and finance in one platform</p>
            </div>
            <div class="feature-slide">
              <img src="/assets/images/manufacturebsm-s3-2.png" alt="HR Management" class="slide-img" />
              <h3 data-lang-en="HR Management System" data-lang-id="Sistem Manajemen HR">HR Management System</h3>
              <p data-lang-en="Streamlined human resource operations from employee database, payroll management to daily attendance check-in and tracking" data-lang-id="Operasi HR yang efisien dari database karyawan, manajemen payroll hingga check-in dan tracking absensi harian">Streamlined human resource operations from employee database, payroll management to daily attendance check-in and tracking</p>
            </div>
            <div class="feature-slide">
              <img src="/assets/images/manufacturebsm-s3-3.png" alt="Production Tracking" class="slide-img" />
              <h3 data-lang-en="Production Workflow Tracking" data-lang-id="Tracking Workflow Produksi">Production Workflow Tracking</h3>
              <p data-lang-en="Real-time monitoring and reporting of entire production process from planning to completion with detailed analytics" data-lang-id="Monitoring dan reporting real-time seluruh proses produksi dari perencanaan hingga penyelesaian dengan analitik detail">Real-time monitoring and reporting of entire production process from planning to completion with detailed analytics</p>
            </div>
            <div class="feature-slide">
              <img src="/assets/images/manufacturebsm-s3-4.png" alt="Project Management" class="slide-img" />
              <h3 data-lang-en="Project Management" data-lang-id="Manajemen Proyek">Project Management</h3>
              <p data-lang-en="Comprehensive project tracking with team work schedules, task assignments, deadlines, and progress monitoring tools" data-lang-id="Tracking proyek komprehensif dengan jadwal kerja tim, penugasan tugas, deadline, dan tools monitoring progress">Comprehensive project tracking with team work schedules, task assignments, deadlines, and progress monitoring tools</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 4: CTA Banner -->
    <section class="cta-banner" id="demo">
      <div class="container">
        <div class="cta-content">
          <div class="cta-image">
            <img src="/assets/images/business360-dashboard.png" alt="Manufacture360 Platform" />
          </div>
          <div class="cta-text">
            <h2 data-lang-en="Ready to Transform Your Manufacturing?" data-lang-id="Siap untuk Mengubah Manufaktur Anda?">Ready to Transform Your Manufacturing?</h2>
            <p data-lang-en="Join hundreds of manufacturers already using Manufacture360 to streamline their operations and boost productivity." data-lang-id="Bergabunglah dengan ratusan manufaktur yang sudah menggunakan Manufacture360 untuk menyederhanakan operasional dan meningkatkan produktivitas.">Join hundreds of manufacturers already using Manufacture360 to streamline their operations and boost productivity.</p>
            <div class="cta-buttons">
              <a href="#demo" class="btn btn-primary" data-lang-en="Try Demo" data-lang-id="Coba Demo">Try Demo</a>
              <a href="https://wa.me/6285156858298?text=Hello%20Digital360,%20I%20want%20to%20schedule%20a%20consultation%20for%20Manufacture360" class="btn btn-secondary" target="_blank" rel="noopener" data-lang-en="Schedule Consultation" data-lang-id="Jadwalkan Konsultasi">Schedule Consultation</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  :root {
    --primary: #ffb703;
    --primary-dark: #e6a500;
    --primary-light: #ffcf57;
    --text-dark: #1e293b;
    --text-light: #64748b;
    --white: #ffffff;
    --bg-light: #f8fafc;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero Section */
  .hero-section {
    min-height: 100vh;
    background: linear-gradient(135deg, #ffb703 0%, #ff9500 100%);
    display: flex;
    align-items: center;
    padding: 2rem 0;
    position: relative;
    overflow: hidden;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 800px;
    height: 800px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    filter: blur(100px);
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-text {
    color: var(--white);
  }

  .hero-logo {
    width: 450px;
    height: auto;
    margin-bottom: 2rem;
  }

  .hero-description {
    font-size: 1.45rem;
    line-height: 1.7;
    opacity: 0.9;
    margin-bottom: 2.5rem;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-buttons .btn {
    padding: 0.75rem 1.5rem;
    font-size: 0.9rem;
  }

  .btn {
    display: inline-block;
    padding: 1rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    font-size: 1rem;
  }

  .btn-primary {
    background: var(--white);
    color: var(--primary);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .btn-secondary {
    background: transparent;
    color: var(--white);
    border: 2px solid var(--white);
  }

  .btn-secondary:hover {
    background: var(--white);
    color: var(--primary);
  }

  .hero-image img {
    width: 100%;
    height: auto;
    border-radius: 16px;
    transition: transform 0.3s ease;
  }

  .hero-image img:hover {
    animation: gentleShake 3s ease-in-out infinite;
  }

  @keyframes gentleShake {
    0%, 100% {
      transform: translateX(0);
    }
    25% {
      transform: translateX(-5px);
    }
    75% {
      transform: translateX(5px);
    }
  }

  /* Section 2: Features */
  .features-section {
    padding: 6rem 0;
    background: var(--bg-light);
  }

  .section-title {
    text-align: center;
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--text-dark);
    margin-bottom: 1rem;
  }

  .features-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .feature-card {
    background: var(--white);
    padding: 2.5rem;
    border-radius: 20px;
    text-align: center;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .feature-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(0, 127, 255, 0.15);
  }

  .feature-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 1.5rem;
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
  }

  .feature-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 1rem;
  }

  .feature-card p {
    color: var(--text-light);
    line-height: 1.6;
  }

  /* Section 3: Carousel */
  .all-features-section {
    padding: 6rem 0;
    background: var(--white);
  }

  .section-description {
    text-align: center;
    font-size: 1.25rem;
    color: var(--text-light);
    margin-top: 0.15rem;
    margin-bottom: 3rem;
  }

  .carousel-wrapper {
    overflow-x: auto;
    padding-bottom: 1rem;
  }

  .carousel-track {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-behavior: smooth;
    padding: 0.5rem;
  }

  .carousel-track::-webkit-scrollbar {
    height: 8px;
  }

  .carousel-track::-webkit-scrollbar-track {
    background: var(--bg-light);
    border-radius: 4px;
  }

  .carousel-track::-webkit-scrollbar-thumb {
    background: var(--primary);
    border-radius: 4px;
  }

  .carousel-track::-webkit-scrollbar-thumb:hover {
    background: var(--primary-dark);
  }

  .feature-slide {
    background: var(--bg-light);
    border-radius: 16px;
    padding: 1.5rem;
    text-align: center;
    transition: all 0.3s ease;
    flex-shrink: 0;
    width: 320px;
  }

  .feature-slide:hover {
    background: var(--white);
    box-shadow: 0 15px 40px rgba(0, 127, 255, 0.15);
  }

  .slide-img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 1rem;
  }

  .feature-slide h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 0.75rem;
  }

  .feature-slide p {
    color: var(--text-light);
    line-height: 1.5;
    font-size: 0.9rem;
  }

  /* Section 4: CTA Banner */
  .cta-banner {
    padding: 4rem 0;
    background: var(--bg-light);
  }

  .cta-content {
    background: linear-gradient(135deg, var(--primary) 0%, #ff9500 100%);
    border-radius: 30px;
    padding: 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .cta-image img {
    width: 100%;
    height: auto;
    border-radius: 16px;
  }

  .cta-text {
    color: var(--white);
  }

  .cta-text h2 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .cta-text p {
    font-size: 1.125rem;
    opacity: 0.9;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hero-content,
    .cta-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .hero-image,
    .cta-image {
      order: -1;
    }

    .features-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero-logo {
      width: 320px;
    }

    .section-title {
      font-size: 2rem;
    }

    .features-cards {
      grid-template-columns: 1fr;
    }

    .feature-slide {
      width: 280px;
    }

    .cta-content {
      padding: 2rem;
    }

    .cta-text h2 {
      font-size: 1.5rem;
    }
  }
</style>

<script>
  // Auto-scroll carousel with better reset logic
  let carouselState = {
    carousel: null,
    isScrolling: false,
    isPaused: false,
    scrollSpeed: 0.5,
    animationFrame: null
  };

  function autoScroll() {
    if (!carouselState.carousel || carouselState.isPaused || carouselState.isScrolling) {
      carouselState.animationFrame = requestAnimationFrame(autoScroll);
      return;
    }

    const carousel = carouselState.carousel;
    const maxScroll = carousel.scrollWidth - carousel.clientWidth;

    // Check if we're near the end
    if (carousel.scrollLeft >= maxScroll - 10) {
      // Near the end - smooth reset to start
      carouselState.isScrolling = true;

      carousel.scrollTo({
        left: 0,
        behavior: 'smooth'
      });

      // Wait for smooth scroll to complete
      setTimeout(() => {
        carouselState.isScrolling = false;
      }, 500); // Adjust based on scroll duration
    } else {
      // Continue scrolling
      carousel.scrollLeft += carouselState.scrollSpeed;
    }

    carouselState.animationFrame = requestAnimationFrame(autoScroll);
  }

  function startAutoScroll() {
    if (!carouselState.carousel) {
      carouselState.carousel = document.getElementById('carouselTrack');
    }
    carouselState.animationFrame = requestAnimationFrame(autoScroll);
  }

  function stopAutoScroll() {
    if (carouselState.animationFrame) {
      cancelAnimationFrame(carouselState.animationFrame);
      carouselState.animationFrame = null;
    }
  }

  // Initialize and start auto-scroll
  function initCarousel() {
    const carousel = document.getElementById('carouselTrack');
    if (carousel) {
      carouselState.carousel = carousel;
      startAutoScroll();

      // Pause on hover
      carousel.addEventListener('mouseenter', () => {
        carouselState.isPaused = true;
      });

      carousel.addEventListener('mouseleave', () => {
        carouselState.isPaused = false;
      });

      // Pause on user interaction (scroll)
      carousel.addEventListener('mousedown', () => {
        carouselState.isPaused = true;
      });

      carousel.addEventListener('mouseup', () => {
        carouselState.isPaused = false;
      });

      carousel.addEventListener('touchstart', () => {
        carouselState.isPaused = true;
      });

      carousel.addEventListener('touchend', () => {
        carouselState.isPaused = false;
      });
    }
  }

  // Start on DOM load
  initCarousel();

  // Re-initialize after view transition
  document.addEventListener('astro:after-swap', () => {
    stopAutoScroll();
    carouselState = {
      carousel: null,
      isScrolling: false,
      isPaused: false,
      scrollSpeed: 0.5,
      animationFrame: null
    };
    setTimeout(initCarousel, 100);
  });
</script>

<script>
  // Language switching functionality
  function setManufacture360Language(lang) {
    const langKey = lang === 'EN' ? 'en' : 'id';

    // Update all elements with data-lang attributes
    document.querySelectorAll('[data-lang-en]').forEach(element => {
      const translation = element.getAttribute(`data-lang-${langKey}`);
      if (translation) {
        element.textContent = translation;
      }
    });
  }

  // Listen for language change events from Header
  window.addEventListener('languageChanged', (event) => {
    setManufacture360Language(event.detail.language);
  });

  // Set initial language on page load
  document.addEventListener('DOMContentLoaded', () => {
    const savedLang = localStorage.getItem('language') || 'EN';
    setManufacture360Language(savedLang);
  });

  // Re-initialize after view transition
  document.addEventListener('astro:after-swap', () => {
    setTimeout(() => {
      const savedLang = localStorage.getItem('language') || 'EN';
      setManufacture360Language(savedLang);
    }, 50);
  });
</script>
