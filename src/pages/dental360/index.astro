---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Dental360 - Complete Dental Practice Management System | Digital360"
  description="Streamline your dental practice with Dental360 - comprehensive management solution for appointment scheduling, patient records, billing, and more."
  ogImage="https://digital360.id/assets/images/dental360-og.jpg"
>
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="hero-section">
      <div class="container">
        <div class="hero-content">
          <div class="hero-text">
            <img src="/assets/images/satu360dental-logo_wh.webp" alt="Dental360" class="hero-logo" />
            <p class="hero-description">All-in-one clinic management: bookings, records, inventory & billing. More efficient, more professional.</p>
            <div class="hero-buttons">
              <a href="#demo" class="btn btn-primary">Try Demo</a>
              <a href="https://wa.me/6285156858298?text=Hello%20Digital360,%20I%20want%20to%20schedule%20a%20consultation%20for%20Dental360" class="btn btn-secondary" target="_blank" rel="noopener">Schedule Consultation</a>
            </div>
          </div>
          <div class="hero-image">
            <img src="/assets/images/dental360-dashboard.webp" alt="Dental360 Dashboard" />
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: Key Features -->
    <section class="features-section">
      <div class="container">
        <h2 class="section-title">Why Choose Digital360 Dental Management System?</h2>
        <div class="features-cards">
          <div class="feature-card">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <h3>Reduce Admin Time by 40%</h3>
            <p>Automate appointment scheduling, patient records, and billing processes. Focus more on patient care while our system handles the rest.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
              </svg>
            </div>
            <h3>Decrease No-Shows by 60%</h3>
            <p>Automated SMS and email reminders ensure patients remember their appointments. Significantly reduce missed appointments and revenue loss.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="1" x2="12" y2="23"></line>
                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
              </svg>
            </div>
            <h3>Increase Revenue by 25%</h3>
            <p>Streamlined billing, automated invoicing, and integrated payment processing help you get paid faster and reduce outstanding balances.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 3: All Features (Carousel) -->
    <section class="all-features-section">
      <div class="container">
        <h2 class="section-title">Complete Features for Your Practice</h2>
        <p class="section-description">Everything you need to run your dental practice efficiently in one platform</p>

        <div class="carousel-wrapper">
          <div class="carousel-track" id="carouselTrack">
            <div class="feature-slide">
              <img src="/assets/images/dentalbsm-s3-1.webp" alt="Appointment Management" class="slide-img" />
              <h3>Appointment Management</h3>
              <p>Smart scheduling system with conflict detection, recurring appointments, and waitlist management</p>
            </div>
            <div class="feature-slide">
              <img src="/assets/images/dentalbsm-s3-2.webp" alt="Patient Database" class="slide-img" />
              <h3>Patient Database</h3>
              <p>Comprehensive patient profiles with medical history, treatments, and document attachments</p>
            </div>
            <div class="feature-slide">
              <img src="/assets/images/dentalbsm-s3-3.webp" alt="Patient Medical Records" class="slide-img" />
              <h3>Patient Medical Records</h3>
              <p>Complete documentation from anamnesis, complaints, diagnosis to odontogram visualization</p>
            </div>
            <div class="feature-slide">
              <img src="/assets/images/dentalbsm-s3-4.webp" alt="Dashboard" class="slide-img" />
              <h3>Dashboard</h3>
              <p>Centralized all-in-one quick access for complete practice overview</p>
            </div>
            <div class="feature-slide">
              <img src="/assets/images/dentalbsm-s3-5.webp" alt="Analytics Report" class="slide-img" />
              <h3>Analytics Report</h3>
              <p>Comprehensive reports on revenue, treatment, financial, and demographics for dental business</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 4: CTA Banner -->
    <section class="cta-banner" id="demo">
      <div class="container">
        <div class="cta-content">
          <div class="cta-image">
            <img src="/assets/images/dental360-dashboard.webp" alt="Dental360 Platform" />
          </div>
          <div class="cta-text">
            <h2>Ready to Transform Your Practice?</h2>
            <p>Join hundreds of dental practices already using Dental360 to streamline their operations and improve patient care.</p>
            <div class="cta-buttons">
              <a href="#demo" class="btn btn-primary">Try Demo</a>
              <a href="https://wa.me/6285156858298?text=Hello%20Digital360,%20I%20want%20to%20schedule%20a%20consultation%20for%20Dental360" class="btn btn-secondary" target="_blank" rel="noopener">Schedule Consultation</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  :root {
    --primary: #007FFF;
    --primary-dark: #0066CC;
    --primary-light: #4DA6FF;
    --text-dark: #1e293b;
    --text-light: #64748b;
    --white: #ffffff;
    --bg-light: #f8fafc;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero Section */
  .hero-section {
    min-height: 100vh;
    background: linear-gradient(135deg, #007FFF 0%, #00D4FF 100%);
    display: flex;
    align-items: center;
    padding: 2rem 0;
    position: relative;
    overflow: hidden;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 800px;
    height: 800px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    filter: blur(100px);
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-text {
    color: var(--white);
  }

  .hero-logo {
    width: 450px;
    height: auto;
    margin-bottom: 2rem;
  }

  .hero-description {
    font-size: 1.45rem;
    line-height: 1.7;
    opacity: 0.9;
    margin-bottom: 2.5rem;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-buttons .btn {
    padding: 0.75rem 1.5rem;
    font-size: 0.9rem;
  }

  .btn {
    display: inline-block;
    padding: 1rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    font-size: 1rem;
  }

  .btn-primary {
    background: var(--white);
    color: var(--primary);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .btn-secondary {
    background: transparent;
    color: var(--white);
    border: 2px solid var(--white);
  }

  .btn-secondary:hover {
    background: var(--white);
    color: var(--primary);
  }

  .hero-image img {
    width: 100%;
    height: auto;
    border-radius: 16px;
    transition: transform 0.3s ease;
  }

  .hero-image img:hover {
    animation: gentleShake 3s ease-in-out infinite;
  }

  @keyframes gentleShake {
    0%, 100% {
      transform: translateX(0);
    }
    25% {
      transform: translateX(-5px);
    }
    75% {
      transform: translateX(5px);
    }
  }

  /* Section 2: Features */
  .features-section {
    padding: 6rem 0;
    background: var(--bg-light);
  }

  .section-title {
    text-align: center;
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--text-dark);
    margin-bottom: 1rem;
  }

  .features-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .feature-card {
    background: var(--white);
    padding: 2.5rem;
    border-radius: 20px;
    text-align: center;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .feature-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(0, 127, 255, 0.15);
  }

  .feature-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 1.5rem;
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
  }

  .feature-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 1rem;
  }

  .feature-card p {
    color: var(--text-light);
    line-height: 1.6;
  }

  /* Section 3: Carousel */
  .all-features-section {
    padding: 6rem 0;
    background: var(--white);
  }

  .section-description {
    text-align: center;
    font-size: 1.25rem;
    color: var(--text-light);
    margin-top: 0.15rem;
    margin-bottom: 3rem;
  }

  .carousel-wrapper {
    overflow-x: auto;
    padding-bottom: 1rem;
  }

  .carousel-track {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-behavior: smooth;
    padding: 0.5rem;
  }

  .carousel-track::-webkit-scrollbar {
    height: 8px;
  }

  .carousel-track::-webkit-scrollbar-track {
    background: var(--bg-light);
    border-radius: 4px;
  }

  .carousel-track::-webkit-scrollbar-thumb {
    background: var(--primary);
    border-radius: 4px;
  }

  .carousel-track::-webkit-scrollbar-thumb:hover {
    background: var(--primary-dark);
  }

  .feature-slide {
    background: var(--bg-light);
    border-radius: 16px;
    padding: 1.5rem;
    text-align: center;
    transition: all 0.3s ease;
    flex-shrink: 0;
    width: 320px;
  }

  .feature-slide:hover {
    background: var(--white);
    box-shadow: 0 15px 40px rgba(0, 127, 255, 0.15);
  }

  .slide-img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 1rem;
  }

  .feature-slide h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 0.75rem;
  }

  .feature-slide p {
    color: var(--text-light);
    line-height: 1.5;
    font-size: 0.9rem;
  }

  /* Section 4: CTA Banner */
  .cta-banner {
    padding: 4rem 0;
    background: var(--bg-light);
  }

  .cta-content {
    background: linear-gradient(135deg, var(--primary) 0%, #00D4FF 100%);
    border-radius: 30px;
    padding: 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .cta-image img {
    width: 100%;
    height: auto;
    border-radius: 16px;
  }

  .cta-text {
    color: var(--white);
  }

  .cta-text h2 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .cta-text p {
    font-size: 1.125rem;
    opacity: 0.9;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hero-content,
    .cta-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .hero-image,
    .cta-image {
      order: -1;
    }

    .features-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero-logo {
      width: 320px;
    }

    .section-title {
      font-size: 2rem;
    }

    .features-cards {
      grid-template-columns: 1fr;
    }

    .feature-slide {
      width: 280px;
    }

    .cta-content {
      padding: 2rem;
    }

    .cta-text h2 {
      font-size: 1.5rem;
    }
  }
</style>

<script>
  // Auto-scroll carousel
  const carousel = document.getElementById('carouselTrack');
  let autoScrollInterval;
  let isPaused = false;

  function startAutoScroll() {
    autoScrollInterval = setInterval(() => {
      if (!isPaused && carousel) {
        carousel.scrollLeft += 1;
        // Reset to start when reaching the end
        if (carousel.scrollLeft >= carousel.scrollWidth - carousel.clientWidth) {
          carousel.scrollLeft = 0;
        }
      }
    }, 50); // Slow scroll speed
  }

  function stopAutoScroll() {
    clearInterval(autoScrollInterval);
  }

  // Start auto-scroll
  startAutoScroll();

  // Pause on hover
  carousel.addEventListener('mouseenter', () => {
    isPaused = true;
  });

  carousel.addEventListener('mouseleave', () => {
    isPaused = false;
  });

  // Pause on user interaction (scroll)
  carousel.addEventListener('mousedown', () => {
    isPaused = true;
  });

  carousel.addEventListener('mouseup', () => {
    isPaused = false;
  });

  carousel.addEventListener('touchstart', () => {
    isPaused = true;
  });

  carousel.addEventListener('touchend', () => {
    isPaused = false;
  });
</script>
