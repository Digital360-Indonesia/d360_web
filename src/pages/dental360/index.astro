---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Dental360 - Complete Dental Practice Management System | Digital360"
  description="Streamline your dental practice with Dental360 - comprehensive management solution for appointment scheduling, patient records, billing, and more."
  ogImage="https://digital360.id/assets/images/dental360-og.jpg"
>
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="hero-section">
      <div class="container">
        <div class="hero-content">
          <div class="hero-text">
            <img src="/assets/images/satu360dental-logo_wh.png" alt="Dental360" class="hero-logo" />
            <p class="hero-description" data-lang-en="All-in-one clinic management: bookings, records, inventory & billing. More efficient, more professional." data-lang-id="Semua dalam satu sistem manajemen klinik: booking, rekam medis, inventory & billing. Lebih efisien, lebih profesional.">All-in-one clinic management: bookings, records, inventory & billing. More efficient, more professional.</p>
            <div class="hero-buttons">
              <a href="#demo" class="btn btn-primary" data-lang-en="Try Demo" data-lang-id="Coba Demo">Try Demo</a>
              <a href="https://wa.me/6285156858298?text=Hello%20Digital360,%20I%20want%20to%20schedule%20a%20consultation%20for%20Dental360" class="btn btn-secondary" target="_blank" rel="noopener" data-lang-en="Schedule Consultation" data-lang-id="Jadwalkan Konsultasi">Schedule Consultation</a>
            </div>
          </div>
          <div class="hero-image">
            <img src="/assets/images/dental360-dashboard.png" alt="Dental360 Dashboard" />
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: Key Features -->
    <section class="features-section">
      <div class="container">
        <h2 class="section-title" data-lang-en="Why Choose Digital360 Dental Management System?" data-lang-id="Mengapa Memilih Sistem Manajemen Dental Digital360?">Why Choose Digital360 Dental Management System?</h2>
        <div class="features-cards">
          <div class="feature-card">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 21V5a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v5m-4 0h4"></path>
              </svg>
            </div>
            <h3 data-lang-en="All-in-One Solution" data-lang-id="Solusi Terintegrasi">All-in-One Solution</h3>
            <p data-lang-en="From appointment booking to billing - everything in one powerful platform" data-lang-id="Dari booking sampai billing - semua dalam satu platform yang powerful">From appointment booking to billing - everything in one powerful platform</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                <path d="M9 12l2 2 4-4"></path>
              </svg>
            </div>
            <h3 data-lang-en="Proven & Trusted" data-lang-id="Terbukti & Terpercaya">Proven & Trusted</h3>
            <p data-lang-en="Used by 50+ dental clinics across Indonesia with 99.9% satisfaction rate" data-lang-id="Digunakan oleh 50+ klinik gigi di seluruh Indonesia dengan tingkat kepuasan 99.9%">Used by 50+ dental clinics across Indonesia with 99.9% satisfaction rate</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 data-lang-en="Dedicated Support" data-lang-id="Support Khusus">Dedicated Support</h3>
            <p data-lang-en="24/7 expert support team ready to help you succeed" data-lang-id="Tim support expert 24/7 siap membantu Anda sukses">24/7 expert support team ready to help you succeed</p>
          </div>
        </div>
      </div>
    </section>
    <section class="all-features-section">
      <div class="container">
        <h2 class="section-title" data-lang-en="Complete Features for Your Practice" data-lang-id="Fitur Lengkap untuk Praktik Anda">Complete Features for Your Practice</h2>
        <p class="section-description" data-lang-en="Everything you need to run your dental practice efficiently in one platform" data-lang-id="Semua yang Anda butuhkan untuk menjalankan praktik dental secara efisien dalam satu platform">Everything you need to run your dental practice efficiently in one platform</p>

        <div class="carousel-wrapper">
          <div class="carousel-track" id="carouselTrack">
            <div class="feature-slide">
              <img src="/assets/images/dentalbsm-s3-1.png" alt="Appointment Management" class="slide-img" />
              <h3 data-lang-en="Appointment Management" data-lang-id="Manajemen Appointment">Appointment Management</h3>
              <p data-lang-en="Smart scheduling system with conflict detection, recurring appointments, and waitlist management" data-lang-id="Sistem penjadwalan cerdas dengan deteksi konflik, appointment berulang, dan manajemen waitlist">Smart scheduling system with conflict detection, recurring appointments, and waitlist management</p>
            </div>
            <div class="feature-slide">
              <img src="/assets/images/dentalbsm-s3-2.png" alt="Patient Database" class="slide-img" />
              <h3 data-lang-en="Patient Database" data-lang-id="Database Pasien">Patient Database</h3>
              <p data-lang-en="Comprehensive patient profiles with medical history, treatments, and document attachments" data-lang-id="Profil pasien lengkap dengan riwayat medis, perawatan, dan lampiran dokumen">Comprehensive patient profiles with medical history, treatments, and document attachments</p>
            </div>
            <div class="feature-slide">
              <img src="/assets/images/dentalbsm-s3-3.png" alt="Patient Medical Records" class="slide-img" />
              <h3 data-lang-en="Patient Medical Records" data-lang-id="Rekam Medis Pasien">Patient Medical Records</h3>
              <p data-lang-en="Complete documentation from anamnesis, complaints, diagnosis to odontogram visualization" data-lang-id="Dokumentasi lengkap dari anamnesis, keluhan, diagnosis hingga visualisasi odontogram">Complete documentation from anamnesis, complaints, diagnosis to odontogram visualization</p>
            </div>
            <div class="feature-slide">
              <img src="/assets/images/dentalbsm-s3-4.png" alt="Dashboard" class="slide-img" />
              <h3 data-lang-en="Dashboard" data-lang-id="Dasbor">Dashboard</h3>
              <p data-lang-en="Centralized all-in-one quick access for complete practice overview" data-lang-id="Akses terpusat all-in-one untuk overview praktik lengkap">Centralized all-in-one quick access for complete practice overview</p>
            </div>
            <div class="feature-slide">
              <img src="/assets/images/dentalbsm-s3-5.png" alt="Analytics Report" class="slide-img" />
              <h3 data-lang-en="Analytics Report" data-lang-id="Laporan Analitik">Analytics Report</h3>
              <p data-lang-en="Comprehensive reports on revenue, treatment, financial, and demographics for dental business" data-lang-id="Laporan komprehensif tentang pendapatan, perawatan, keuangan, dan demografi untuk bisnis dental">Comprehensive reports on revenue, treatment, financial, and demographics for dental business</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 4: CTA Banner -->
    <section class="cta-banner" id="demo">
      <div class="container">
        <div class="cta-content">
          <div class="cta-image">
            <img src="/assets/images/dental360-dashboard.png" alt="Dental360 Platform" />
          </div>
          <div class="cta-text">
            <h2 data-lang-en="Ready to Transform Your Practice?" data-lang-id="Siap untuk Mengubah Praktik Anda?">Ready to Transform Your Practice?</h2>
            <p data-lang-en="Join hundreds of dental practices already using Dental360 to streamline their operations and improve patient care." data-lang-id="Bergabunglah dengan ratusan praktik dental yang sudah menggunakan Dental360 untuk menyederhanakan operasional dan meningkatkan perawatan pasien.">Join hundreds of dental practices already using Dental360 to streamline their operations and improve patient care.</p>
            <div class="cta-buttons">
              <a href="#demo" class="btn btn-primary" data-lang-en="Try Demo" data-lang-id="Coba Demo">Try Demo</a>
              <a href="https://wa.me/6285156858298?text=Hello%20Digital360,%20I%20want%20to%20schedule%20a%20consultation%20for%20Dental360" class="btn btn-secondary" target="_blank" rel="noopener" data-lang-en="Schedule Consultation" data-lang-id="Jadwalkan Konsultasi">Schedule Consultation</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  :root {
    --primary: #007FFF;
    --primary-dark: #0066CC;
    --primary-light: #4DA6FF;
    --text-dark: #1e293b;
    --text-light: #64748b;
    --white: #ffffff;
    --bg-light: #f8fafc;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero Section */
  .hero-section {
    min-height: 100vh;
    background: linear-gradient(135deg, #007FFF 0%, #00D4FF 100%);
    display: flex;
    align-items: center;
    padding: 2rem 0;
    position: relative;
    overflow: hidden;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 800px;
    height: 800px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    filter: blur(100px);
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-text {
    color: var(--white);
  }

  .hero-logo {
    width: 450px;
    height: auto;
    margin-bottom: 2rem;
  }

  .hero-description {
    font-size: 1.45rem;
    line-height: 1.7;
    opacity: 0.9;
    margin-bottom: 2.5rem;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-buttons .btn {
    padding: 0.75rem 1.5rem;
    font-size: 0.9rem;
  }

  .btn {
    display: inline-block;
    padding: 1rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    font-size: 1rem;
  }

  .btn-primary {
    background: var(--white);
    color: var(--primary);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .btn-secondary {
    background: transparent;
    color: var(--white);
    border: 2px solid var(--white);
  }

  .btn-secondary:hover {
    background: var(--white);
    color: var(--primary);
  }

  .hero-image img {
    width: 100%;
    height: auto;
    border-radius: 16px;
    transition: transform 0.3s ease;
  }

  .hero-image img:hover {
    animation: gentleShake 3s ease-in-out infinite;
  }

  @keyframes gentleShake {
    0%, 100% {
      transform: translateX(0);
    }
    25% {
      transform: translateX(-5px);
    }
    75% {
      transform: translateX(5px);
    }
  }

  /* Section 2: Features */
  .features-section {
    padding: 6rem 0;
    background: var(--bg-light);
  }

  .section-title {
    text-align: center;
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--text-dark);
    margin-bottom: 1rem;
  }

  .features-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .feature-card {
    background: var(--white);
    padding: 2.5rem;
    border-radius: 20px;
    text-align: center;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .feature-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(0, 127, 255, 0.15);
  }

  .feature-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 1.5rem;
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
  }

  .feature-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 1rem;
  }

  .feature-card p {
    color: var(--text-light);
    line-height: 1.6;
  }

  /* Section 3: Carousel */
  .all-features-section {
    padding: 6rem 0;
    background: var(--white);
  }

  .section-description {
    text-align: center;
    font-size: 1.25rem;
    color: var(--text-light);
    margin-top: 0.15rem;
    margin-bottom: 3rem;
  }

  .carousel-wrapper {
    overflow-x: auto;
    padding-bottom: 1rem;
  }

  .carousel-track {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-behavior: smooth;
    padding: 0.5rem;
  }

  .carousel-track::-webkit-scrollbar {
    height: 8px;
  }

  .carousel-track::-webkit-scrollbar-track {
    background: var(--bg-light);
    border-radius: 4px;
  }

  .carousel-track::-webkit-scrollbar-thumb {
    background: var(--primary);
    border-radius: 4px;
  }

  .carousel-track::-webkit-scrollbar-thumb:hover {
    background: var(--primary-dark);
  }

  .feature-slide {
    background: var(--bg-light);
    border-radius: 16px;
    padding: 1.5rem;
    text-align: center;
    transition: all 0.3s ease;
    flex-shrink: 0;
    width: 320px;
  }

  .feature-slide:hover {
    background: var(--white);
    box-shadow: 0 15px 40px rgba(0, 127, 255, 0.15);
  }

  .slide-img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 1rem;
  }

  .feature-slide h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 0.75rem;
  }

  .feature-slide p {
    color: var(--text-light);
    line-height: 1.5;
    font-size: 0.9rem;
  }

  /* Section 4: CTA Banner */
  .cta-banner {
    padding: 4rem 0;
    background: var(--bg-light);
  }

  .cta-content {
    background: linear-gradient(135deg, var(--primary) 0%, #00D4FF 100%);
    border-radius: 30px;
    padding: 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .cta-image img {
    width: 100%;
    height: auto;
    border-radius: 16px;
  }

  .cta-text {
    color: var(--white);
  }

  .cta-text h2 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .cta-text p {
    font-size: 1.125rem;
    opacity: 0.9;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hero-content,
    .cta-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .hero-image,
    .cta-image {
      order: -1;
    }

    .features-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero-logo {
      width: 320px;
    }

    .section-title {
      font-size: 2rem;
    }

    .features-cards {
      grid-template-columns: 1fr;
    }

    .feature-slide {
      width: 280px;
    }

    .cta-content {
      padding: 2rem;
    }

    .cta-text h2 {
      font-size: 1.5rem;
    }
  }
</style>

<script>
  // Auto-scroll carousel with requestAnimationFrame for smoother animation
  let carouselState = {
    carousel: null,
    isScrolling: false,
    isPaused: false,
    scrollSpeed: 0.5,
    animationFrame: null
  };

  function autoScroll() {
    if (!carouselState.carousel || carouselState.isPaused || carouselState.isScrolling) {
      carouselState.animationFrame = requestAnimationFrame(autoScroll);
      return;
    }

    const carousel = carouselState.carousel;
    const maxScroll = carousel.scrollWidth - carousel.clientWidth;

    // Check if we're near the end
    if (carousel.scrollLeft >= maxScroll - 10) {
      // Near the end - smooth reset to start
      carouselState.isScrolling = true;

      carousel.scrollTo({
        left: 0,
        behavior: 'smooth'
      });

      // Wait for smooth scroll to complete
      setTimeout(() => {
        carouselState.isScrolling = false;
      }, 500);
    } else {
      // Continue scrolling
      carousel.scrollLeft += carouselState.scrollSpeed;
    }

    carouselState.animationFrame = requestAnimationFrame(autoScroll);
  }

  function startAutoScroll() {
    if (!carouselState.carousel) {
      carouselState.carousel = document.getElementById('carouselTrack');
    }
    carouselState.animationFrame = requestAnimationFrame(autoScroll);
  }

  function stopAutoScroll() {
    if (carouselState.animationFrame) {
      cancelAnimationFrame(carouselState.animationFrame);
      carouselState.animationFrame = null;
    }
  }

  // Initialize and start auto-scroll
  function initCarousel() {
    const carousel = document.getElementById('carouselTrack');
    if (carousel) {
      carouselState.carousel = carousel;
      startAutoScroll();

      // Pause on hover
      carousel.addEventListener('mouseenter', () => {
        carouselState.isPaused = true;
      });

      carousel.addEventListener('mouseleave', () => {
        carouselState.isPaused = false;
      });

      // Pause on user interaction (scroll)
      carousel.addEventListener('mousedown', () => {
        carouselState.isPaused = true;
      });

      carousel.addEventListener('mouseup', () => {
        carouselState.isPaused = false;
      });

      carousel.addEventListener('touchstart', () => {
        carouselState.isPaused = true;
      });

      carousel.addEventListener('touchend', () => {
        carouselState.isPaused = false;
      });
    }
  }

  // Start on DOM load
  initCarousel();

  // Re-initialize after view transition
  document.addEventListener('astro:after-swap', () => {
    stopAutoScroll();
    carouselState = {
      carousel: null,
      isScrolling: false,
      isPaused: false,
      scrollSpeed: 0.5,
      animationFrame: null
    };
    setTimeout(initCarousel, 100);
  });
</script>

<script>
  // Language switching functionality
  function setDental360Language(lang) {
    const langKey = lang === 'EN' ? 'en' : 'id';

    // Update all elements with data-lang attributes
    document.querySelectorAll('[data-lang-en]').forEach(element => {
      const translation = element.getAttribute(`data-lang-${langKey}`);
      if (translation) {
        element.textContent = translation;
      }
    });
  }

  // Listen for language change events from Header
  window.addEventListener('languageChanged', (event) => {
    setDental360Language(event.detail.language);
  });

  // Set initial language on page load
  document.addEventListener('DOMContentLoaded', () => {
    const savedLang = localStorage.getItem('language') || 'EN';
    setDental360Language(savedLang);
  });

  // Re-initialize after view transition
  document.addEventListener('astro:after-swap', () => {
    setTimeout(() => {
      const savedLang = localStorage.getItem('language') || 'EN';
      setDental360Language(savedLang);
    }, 50);
  });
</script>
