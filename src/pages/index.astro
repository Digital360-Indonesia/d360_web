---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Clients from '../components/Clients.astro';
import FeaturedProducts from '../components/FeaturedProducts.astro';
import GlobalStats from '../components/GlobalStats.astro';
import TeamSolutions from '../components/TeamSolutions.astro';
import CustomerTestimonials from '../components/CustomerTestimonials.astro';
import EnterpriseSecurity from '../components/EnterpriseSecurity.astro';
import CTASection from '../components/CTASection.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Digital360 - Your Digital Transformation Partner">
  <Header />
  <main transition:animate="fade">
    <Hero />
    <Clients />
    <FeaturedProducts />
    <GlobalStats />
    <TeamSolutions />
    <CustomerTestimonials />
    <EnterpriseSecurity />
    <CTASection />
  </main>
  <Footer />
</Layout>