---
import Layout from '../layouts/Layout.astro';

const title = 'Dental360 E-Brosur | Digital360';
const description = 'E-brosur interaktif Dental360 dengan pengalaman membaca digital yang menarik';
---

<Layout title={title}>
  <main class="min-h-screen bg-gradient-to-br from-slate-50 via-white to-slate-100 py-2 md:py-8">
    <!-- Header -->
    <header class="text-center mb-2 md:mb-6 px-2 md:px-4">
      <h1 class="text-xl md:text-4xl lg:text-5xl font-bold text-slate-800 mb-1 md:mb-2">
        Dental360 E-Brosur
      </h1>
      <p class="text-slate-600 text-xs md:text-lg">
        Brosur interaktif dengan pengalaman membaca digital
      </p>
    </header>

    <!-- Loading State -->
    <div id="loading" class="flex flex-col items-center justify-center py-12 md:py-20">
      <div class="animate-spin rounded-full h-12 w-12 md:h-16 md:w-16 border-t-4 border-b-4 border-cyan-600 mb-4"></div>
      <p class="text-slate-800 text-base md:text-lg font-medium">Memuat brosur...</p>
      <p class="text-slate-500 text-xs md:text-sm mt-2" id="loadingStatus">Menyiapkan PDF...</p>
    </div>

    <!-- Book Container -->
    <div id="bookContainer" class="hidden pb-4 md:pb-6 px-0 md:px-4">
      <div class="book-wrapper relative w-full max-w-full md:max-w-6xl mx-auto">
        <div id="pdfPageContainer" class="pdf-page flex justify-center">
          <!-- Current page will be rendered here -->
        </div>
      </div>
    </div>

    <!-- Controls -->
    <div id="controls" class="hidden px-2 md:px-8">
      <div class="flex flex-wrap justify-center items-center gap-1 md:gap-4 max-w-full">
        <button id="prevBtn" class="px-2 md:px-4 py-2 md:py-3 bg-cyan-600 hover:bg-cyan-700 text-white rounded-lg transition-all disabled:opacity-50 disabled:cursor-not-allowed text-xs md:text-base shadow-md">
          ← Prev
        </button>

        <div id="pageInfo" class="px-2 md:px-4 py-2 md:py-3 bg-white text-slate-800 border-2 border-slate-200 rounded-lg text-xs md:text-base shadow-sm min-w-fit">
          <span id="currentPage">1</span>
        </div>

        <button id="nextBtn" class="px-2 md:px-4 py-2 md:py-3 bg-cyan-600 hover:bg-cyan-700 text-white rounded-lg transition-all disabled:opacity-50 disabled:cursor-not-allowed text-xs md:text-base shadow-md">
          Next →
        </button>

        <div class="flex gap-1 md:gap-2">
          <button id="zoomOutBtn" class="px-2 md:px-3 py-2 md:py-3 bg-slate-200 hover:bg-slate-300 text-slate-800 rounded-lg transition-all text-base md:text-lg shadow-sm" title="Perkecil">
            −
          </button>
          <button id="zoomInBtn" class="px-2 md:px-3 py-2 md:py-3 bg-slate-200 hover:bg-slate-300 text-slate-800 rounded-lg transition-all text-base md:text-lg shadow-sm" title="Perbesar">
            +
          </button>
        </div>

        <!-- Sound Toggle -->
        <button id="soundBtn" class="px-2 md:px-3 py-2 md:py-3 bg-slate-200 hover:bg-slate-300 text-slate-800 rounded-lg transition-all text-base md:text-lg shadow-sm" title="Suara">
          🔊
        </button>

        <!-- Home & WhatsApp Buttons -->
        <div class="flex gap-1 md:gap-2">
          <a href="/dental360" class="px-2 md:px-4 py-2 md:py-3 bg-slate-800 hover:bg-slate-900 text-white rounded-lg transition-all text-xs md:text-sm shadow-md flex items-center justify-center gap-1 whitespace-nowrap" title="Home">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-5 md:w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            <span class="hidden sm:inline">Home</span>
          </a>
          <a href="https://wa.me/6285156858298?text=Hello%20Digital360,%20saya%20tertarik%20dengan%20Dental360" target="_blank" rel="noopener" class="px-2 md:px-4 py-2 md:py-3 bg-green-600 hover:bg-green-700 text-white rounded-lg transition-all text-xs md:text-sm shadow-md flex items-center justify-center gap-1 whitespace-nowrap" title="WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-5 md:w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <span class="hidden sm:inline">WA</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Error State -->
    <div id="error" class="hidden text-center py-12 md:py-20 px-4">
      <div class="text-red-500 text-4xl md:text-6xl mb-4">⚠️</div>
      <h2 class="text-xl md:text-2xl font-bold text-slate-800 mb-2">Gagal Memuat Brosur</h2>
      <p id="errorMessage" class="text-slate-600 mb-4 text-sm md:text-base"></p>
      <button id="retryBtn" class="px-4 md:px-6 py-2 md:py-3 bg-cyan-600 hover:bg-cyan-700 text-white rounded-lg transition-all text-sm md:text-base shadow-md">
        Coba Lagi
      </button>
    </div>
  </main>
</Layout>

<style>
  .animate-spin {
    animation: spin 1s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .book-wrapper {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0;
  }

  .pdf-page {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: auto;
    max-height: 75vh;
    padding: 0;
  }

  .pdf-page canvas {
    max-width: 100%;
    height: auto;
    object-fit: contain;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
    border-radius: 8px;
    background: white;
    display: block;
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .book-wrapper {
      max-width: 100%;
      padding: 0 4px;
    }

    .pdf-page {
      max-height: 65vh;
      padding: 0;
    }

    .pdf-page canvas {
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.12);
      border-radius: 6px;
    }
  }

  @media (max-width: 480px) {
    .book-wrapper {
      max-width: 100%;
      padding: 0 2px;
    }

    .pdf-page {
      max-height: 60vh;
      padding: 0;
    }

    .pdf-page canvas {
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
      border-radius: 4px;
    }
  }

  /* Page transition animations */
  .page-transition {
    animation: slideInRight 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .page-transition.prev {
    animation: slideInLeft 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @keyframes slideInRight {
    0% {
      opacity: 0;
      transform: translateX(60px) scale(0.95);
      filter: blur(4px);
    }
    100% {
      opacity: 1;
      transform: translateX(0) scale(1);
      filter: blur(0);
    }
  }

  @keyframes slideInLeft {
    0% {
      opacity: 0;
      transform: translateX(-60px) scale(0.95);
      filter: blur(4px);
    }
    100% {
      opacity: 1;
      transform: translateX(0) scale(1);
      filter: blur(0);
    }
  }

  /* Add subtle pulse effect to buttons */
  button:active:not(:disabled) {
    transform: scale(0.95);
  }

  /* Mobile optimizations for animations */
  @media (max-width: 768px) {
    @keyframes slideInRight {
      0% {
        opacity: 0;
        transform: translateX(30px) scale(0.97);
        filter: blur(2px);
      }
      100% {
        opacity: 1;
        transform: translateX(0) scale(1);
        filter: blur(0);
      }
    }

    @keyframes slideInLeft {
      0% {
        opacity: 0;
        transform: translateX(-30px) scale(0.97);
        filter: blur(2px);
      }
      100% {
        opacity: 1;
        transform: translateX(0) scale(1);
        filter: blur(0);
      }
    }
  }
</style>

<script>
  let pdfDoc = null;
  let currentPageNum = 1;
  let currentScale = window.innerWidth < 768 ? 0.6 : 0.8;
  let totalPages = 0;
  let soundEnabled = true;
  let audioContext = null;
  let isRendering = false;

  // Create page flip sound using Web Audio API
  function createFlipSound() {
    if (!audioContext) {
      audioContext = new (window.AudioContext || window.webkitAudioContext)();
    }

    const oscillator = audioContext.createOscillator();
    const gainNode = audioContext.createGain();

    oscillator.connect(gainNode);
    gainNode.connect(audioContext.destination);

    oscillator.type = 'sawtooth';
    oscillator.frequency.setValueAtTime(150, audioContext.currentTime);
    oscillator.frequency.exponentialRampToValueAtTime(80, audioContext.currentTime + 0.1);

    gainNode.gain.setValueAtTime(0.2, audioContext.currentTime);
    gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.1);

    oscillator.start(audioContext.currentTime);
    oscillator.stop(audioContext.currentTime + 0.1);
  }

  function playFlipSound() {
    if (soundEnabled) {
      try {
        createFlipSound();
      } catch (e) {
        console.log('Audio error:', e);
      }
    }
  }

  async function loadPDF() {
    try {
      updateLoadingStatus('Memuat PDF.js...');

      // Load PDF.js dynamically
      if (!window.pdfjsLib) {
        await loadScript('https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js');
        window.pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
      }

      updateLoadingStatus('Membuka file PDF...');

      const loadingTask = window.pdfjsLib.getDocument('/assets/ebrosur/dental360-ebrosur.pdf');
      pdfDoc = await loadingTask.promise;

      totalPages = pdfDoc.numPages;
      updateLoadingStatus(`PDF dimuat (${totalPages} halaman). Merender halaman...`);

      // Render first page
      await renderPage(1, 'next');

      // Show controls
      document.getElementById('loading').classList.add('hidden');
      document.getElementById('bookContainer').classList.remove('hidden');
      document.getElementById('controls').classList.remove('hidden');

      // Update page info and buttons
      updatePageInfo();
      updateButtons();

    } catch (error) {
      console.error('Error loading PDF:', error);
      showError(error.message);
    }
  }

  function loadScript(src) {
    return new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = src;
      script.onload = resolve;
      script.onerror = reject;
      document.head.appendChild(script);
    });
  }

  async function renderPage(pageNum, direction = 'next') {
    if (isRendering) return;
    isRendering = true;

    try {
      const page = await pdfDoc.getPage(pageNum);
      const viewport = page.getViewport({ scale: currentScale });

      const canvas = document.createElement('canvas');
      const ctx = canvas.getContext('2d');

      canvas.height = viewport.height;
      canvas.width = viewport.width;

      // Add transition class based on direction
      canvas.className = direction === 'next' ? 'page-transition' : 'page-transition prev';

      await page.render({
        canvasContext: ctx,
        viewport: viewport
      }).promise;

      // Clear previous content and add new page
      const pageContainer = document.getElementById('pdfPageContainer');
      pageContainer.innerHTML = '';
      pageContainer.appendChild(canvas);

      currentPageNum = pageNum;

    } finally {
      isRendering = false;
    }
  }

  async function goToNextPage() {
    if (currentPageNum < totalPages && !isRendering) {
      playFlipSound();
      await renderPage(currentPageNum + 1, 'next');
      updatePageInfo();
      updateButtons();
    }
  }

  async function goToPrevPage() {
    if (currentPageNum > 1 && !isRendering) {
      playFlipSound();
      await renderPage(currentPageNum - 1, 'prev');
      updatePageInfo();
      updateButtons();
    }
  }

  function updatePageInfo() {
    document.getElementById('currentPage').textContent = currentPageNum;
  }

  function updateButtons() {
    document.getElementById('prevBtn').disabled = currentPageNum <= 1;
    document.getElementById('nextBtn').disabled = currentPageNum >= totalPages;
  }

  function updateLoadingStatus(message) {
    const statusEl = document.getElementById('loadingStatus');
    if (statusEl) statusEl.textContent = message;
  }

  function showError(message) {
    document.getElementById('loading').classList.add('hidden');
    document.getElementById('bookContainer').classList.add('hidden');
    document.getElementById('controls').classList.add('hidden');
    document.getElementById('error').classList.remove('hidden');
    document.getElementById('errorMessage').textContent = message || 'Terjadi kesalahan saat memuat brosur';
  }

  // Event listeners
  document.getElementById('prevBtn').addEventListener('click', goToPrevPage);
  document.getElementById('nextBtn').addEventListener('click', goToNextPage);

  document.getElementById('zoomInBtn').addEventListener('click', async () => {
    if (currentScale < 2.0) {
      currentScale += 0.1;
      await renderPage(currentPageNum, 'next');
    }
  });

  document.getElementById('zoomOutBtn').addEventListener('click', async () => {
    if (currentScale > 0.5) {
      currentScale -= 0.1;
      await renderPage(currentPageNum, 'next');
    }
  });

  document.getElementById('soundBtn').addEventListener('click', () => {
    soundEnabled = !soundEnabled;
    const soundBtn = document.getElementById('soundBtn');
    soundBtn.textContent = soundEnabled ? '🔊' : '🔇';
  });

  document.getElementById('retryBtn').addEventListener('click', () => {
    document.getElementById('error').classList.add('hidden');
    document.getElementById('loading').classList.remove('hidden');
    loadPDF();
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight') goToNextPage();
    if (e.key === 'ArrowLeft') goToPrevPage();
  });

  // Start loading
  loadPDF();
</script>
