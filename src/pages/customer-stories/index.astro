---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CustomerStoryCard from '../../components/CustomerStoryCard.astro';
import CustomerStoryFilter from '../../components/CustomerStoryFilter.astro';
import { getCollection } from 'astro:content';

// Get all published customer stories
const allStories = await getCollection('customerStories', ({ data }) => {
  return data.published === true;
});

// Sort by date (newest first)
const sortedStories = allStories.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
---

<Layout
  title="Customer Stories - Digital360 | Success Stories & Case Studies"
  description="Discover how leading businesses across Indonesia transformed their operations with Digital360's innovative digital solutions. Read inspiring customer success stories."
>
  <Header />

  <main class="min-h-screen bg-white pt-20">
    <!-- Hero Section - Two Column Layout -->
    <section class="bg-gray-50 py-8 md:py-12">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
          <!-- Left Column - Text Content -->
          <div class="max-w-xl">
            <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4 leading-tight" data-lang-en="Inspiring stories, remarkable productivity" data-lang-id="Kisah inspiratif, produktivitas luar biasa">
              Inspiring stories, remarkable productivity
            </h1>
            <p class="text-base md:text-lg text-gray-700 mb-6 leading-relaxed" data-lang-en="Efficiency abounds in these success stories of teams, companies and industries shaping the future of work. They do it all with the help of Digital360." data-lang-id="Efisiensi melimpah dalam kisah sukses tim, perusahaan, dan industri yang membentuk masa depan pekerjaan. Semua achieved dengan bantuan Digital360.">
              Efficiency abounds in these success stories of teams, companies and industries shaping the future of work. They do it all with the help of Digital360.
            </p>
            <a
              href="#stories"
              class="inline-flex items-center text-primary-800 font-medium hover:underline"
              data-lang-en="See all stories" data-lang-id="Lihat semua kisah"
            >
              <span class="cta-text">See all stories</span>
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </a>
          </div>

          <!-- Right Column - Featured Image with Rounded Right Edge -->
          <div class="relative lg:ml-8">
            <!-- Oval/Rounded Container -->
            <div class="relative hero-image-container">
              <img
                src="https://images.unsplash.com/photo-1588776814546-1ffcf47267a5?w=800&h=600&fit=crop"
                alt="Dental clinic"
                class="w-full h-auto object-cover"
              />
            </div>

            <!-- Featured Story Card - Bottom Right (Outside container) -->
            <div class="absolute -bottom-4 -right-4 bg-white p-4 shadow-xl max-w-xs rounded-lg">
              <h3 class="font-bold text-gray-900 mb-1 text-base uppercase tracking-wide">{sortedStories[0].data.company}</h3>
              <p class="text-gray-700 mb-2 text-sm featured-story-title" data-lang-en={sortedStories[0].data.title} data-lang-id={sortedStories[0].data.titleId || sortedStories[0].data.title}>{sortedStories[0].data.title}</p>
              <a
                href={`/customer-stories/${sortedStories[0].slug}`}
                class="inline-flex items-center text-primary-800 font-semibold text-sm hover:underline featured-story-link"
                data-lang-en="Read story" data-lang-id="Baca kisah"
              >
                <span class="read-story-text">Read story</span>
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="py-16 bg-gray-50 border-t border-gray-200">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12 max-w-6xl mx-auto">
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-bold text-primary-800 mb-3">50+</div>
            <div class="text-gray-600 font-medium text-sm md:text-base" data-lang-en="Happy Clients" data-lang-id="Klien Puas">Happy Clients</div>
          </div>
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-bold text-primary-800 mb-3">85%</div>
            <div class="text-gray-600 font-medium text-sm md:text-base" data-lang-en="Improved Efficiency" data-lang-id="Efisiensi Meningkat">Improved Efficiency</div>
          </div>
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-bold text-primary-800 mb-3">95%</div>
            <div class="text-gray-600 font-medium text-sm md:text-base" data-lang-en="Client Satisfaction" data-lang-id="Kepuasan Klien">Client Satisfaction</div>
          </div>
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-bold text-primary-800 mb-3">24/7</div>
            <div class="text-gray-600 font-medium text-sm md:text-base" data-lang-en="Support Available" data-lang-id="Support Tersedia">Support Available</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Filter Section -->
    <section id="stories" class="pt-8 pb-4 bg-white border-t border-gray-200">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <CustomerStoryFilter />
      </div>
    </section>

    <!-- All Stories Grid -->
    <section class="pt-0 pb-16 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8" id="stories-grid">
        {sortedStories.map((story) => (
          <CustomerStoryCard
            company={story.data.company}
            title={story.data.title}
            titleId={story.data.titleId}
            excerpt={story.data.excerpt}
            excerptId={story.data.excerptId}
            industry={story.data.industry}
            logo={story.data.logo}
            coverImage={story.data.coverImage}
            slug={story.slug}
            dataIndustry={story.data.industry}
          />
        ))}
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="text-center py-16 hidden">
        <svg class="w-24 h-24 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <h3 class="text-xl font-semibold text-gray-700 mb-2" data-lang-en="No stories found" data-lang-id="Tidak ada kisah ditemukan">No stories found</h3>
        <p class="text-gray-500" data-lang-en="We're having a bit of trouble finding a story in that category." data-lang-id="Kami mengalami sedikit kesulitan menemukan kisah di kategori tersebut.">We're having a bit of trouble finding a story in that category.</p>
        <button
          onclick="document.querySelector('[data-filter=\"all\"]').click()"
          class="mt-4 px-6 py-2 bg-primary-800 text-white rounded-full font-semibold hover:bg-primary-900 transition-colors"
          data-lang-en="View all stories" data-lang-id="Lihat semua kisah"
        >
          <span class="view-all-text">View all stories</span>
        </button>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 bg-gradient-to-br from-primary-800 to-primary-900 text-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6" data-lang-en="Ready to Write Your Success Story?" data-lang-id="Siap Menulis Kisah Sukses Anda?">Ready to Write Your Success Story?</h2>
        <p class="text-xl text-primary-100 mb-8 max-w-2xl mx-auto" data-lang-en="Join hundreds of businesses that have transformed their operations with Digital360" data-lang-id="Bergabunglah dengan ratusan bisnis yang telah mengubah operasional mereka dengan Digital360">
          Join hundreds of businesses that have transformed their operations with Digital360
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="https://wa.me/6285156858298"
            target="_blank"
            class="px-8 py-4 bg-white text-primary-800 rounded-lg font-semibold hover:bg-gray-100 transition-colors"
            data-lang-en="Get Started Today" data-lang-id="Mulai Sekarang"
          >
            <span class="get-started-text">Get Started Today</span>
          </a>
          <a
            href="/"
            class="px-8 py-4 bg-primary-700 text-white rounded-lg font-semibold hover:bg-primary-600 transition-colors border-2 border-white/20"
            data-lang-en="Explore Our Solutions" data-lang-id="Jelajahi Solusi Kami"
          >
            <span class="explore-text">Explore Our Solutions</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Hero image with rounded right edge */
  .hero-image-container {
    border-radius: 0 50% 50% 0 / 0 50% 50% 0;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
  }

  @media (max-width: 1024px) {
    .hero-image-container {
      border-radius: 1.5rem;
    }
  }
</style>

<script>
  // Language switching functionality
  function setCustomerStoriesLanguage(lang) {
    const langKey = lang === 'EN' ? 'en' : 'id';

    // Update all elements with data-lang attributes
    document.querySelectorAll('[data-lang-en]').forEach(element => {
      const translation = element.getAttribute(`data-lang-${langKey}`);
      if (translation) {
        // Check if element has a span child with specific class
        const spanElement = element.querySelector('.cta-text, .read-story-text, .view-all-text, .get-started-text, .explore-text');
        if (spanElement) {
          spanElement.textContent = translation;
        } else if (element.classList.contains('featured-story-title') || element.classList.contains('featured-story-link')) {
          // Special handling for featured story card
          const textSpan = element.querySelector('.read-story-text');
          if (textSpan) {
            textSpan.textContent = translation;
          } else {
            element.textContent = translation;
          }
        } else {
          element.textContent = translation;
        }
      }
    });
  }

  // Listen for language change events from Header
  window.addEventListener('languageChanged', (event) => {
    setCustomerStoriesLanguage(event.detail.language);
  });

  // Set initial language on page load
  document.addEventListener('DOMContentLoaded', () => {
    const savedLang = localStorage.getItem('language') || 'EN';
    setCustomerStoriesLanguage(savedLang);
  });

  // Re-initialize after view transition
  document.addEventListener('astro:after-swap', () => {
    setTimeout(() => {
      const savedLang = localStorage.getItem('language') || 'EN';
      setCustomerStoriesLanguage(savedLang);
    }, 50);
  });
</script>
