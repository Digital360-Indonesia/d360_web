---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CustomerStoryCard from '../../components/CustomerStoryCard.astro';
import CustomerStoryFilter from '../../components/CustomerStoryFilter.astro';
import { getCollection } from 'astro:content';

// Get all published customer stories
const allStories = await getCollection('customerStories', ({ data }) => {
  return data.published === true;
});

// Sort by date (newest first)
const sortedStories = allStories.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

// Get featured stories (first 3)
const featuredStories = sortedStories.slice(0, 3);
const remainingStories = sortedStories.slice(3);
---

<Layout
  title="Customer Stories - Digital360 | Success Stories & Case Studies"
  description="Discover how leading businesses across Indonesia transformed their operations with Digital360's innovative digital solutions. Read inspiring customer success stories."
>
  <Header />

  <main class="min-h-screen bg-white pt-20">
    <!-- Hero Section - Two Column Layout -->
    <section class="bg-gray-50 py-8 md:py-12">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
          <!-- Left Column - Text Content -->
          <div class="max-w-xl">
            <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4 leading-tight">
              Inspiring stories, remarkable productivity
            </h1>
            <p class="text-base md:text-lg text-gray-700 mb-6 leading-relaxed">
              Efficiency abounds in these success stories of teams, companies and industries shaping the future of work. They do it all with the help of Digital360.
            </p>
            <div class="flex flex-col gap-3">
              <a
                href="#featured-video"
                class="inline-flex items-center justify-center px-6 py-3 bg-primary-800 text-white rounded font-semibold hover:bg-primary-900 transition-colors w-fit"
              >
                WATCH DEMO
              </a>
              <a
                href="#stories"
                class="inline-flex items-center text-primary-800 font-medium hover:underline"
              >
                See all stories
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </a>
            </div>
          </div>

          <!-- Right Column - Featured Image with Rounded Right Edge -->
          <div class="relative lg:ml-8">
            <!-- Oval/Rounded Container -->
            <div class="relative hero-image-container">
              <img
                src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=800&h=600&fit=crop"
                alt="Team collaboration"
                class="w-full h-auto object-cover"
              />

              <!-- Featured Story Card - Bottom Right -->
              <div class="absolute bottom-6 right-6 bg-white p-4 shadow-xl max-w-xs">
                <h3 class="font-bold text-gray-900 mb-1 text-base uppercase tracking-wide">{featuredStories[0].data.company}</h3>
                <p class="text-gray-700 mb-2 text-sm">{featuredStories[0].data.title}</p>
                <a
                  href={`/customer-stories/${featuredStories[0].slug}`}
                  class="inline-flex items-center text-primary-800 font-semibold text-sm hover:underline"
                >
                  Read story
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Stories Grid (3 Cards) -->
    <section class="py-16 md:py-20 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 lg:gap-12">
          {featuredStories.slice(1, 4).map((story) => (
            <div class="group text-left">
              <!-- Circular Story Image -->
              <a href={`/customer-stories/${story.slug}`} class="block mb-6">
                <div class="relative rounded-full aspect-square overflow-hidden bg-gray-100 shadow-lg">
                  <img
                    src={story.data.coverImage}
                    alt={story.data.company}
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                  />
                </div>
              </a>

              <!-- Company Logo -->
              <div class="mb-4">
                <img
                  src={story.data.logo}
                  alt={story.data.company}
                  class="h-8 w-auto object-contain"
                />
              </div>

              <!-- Story Title -->
              <h3 class="font-bold text-gray-900 mb-3 text-xl leading-snug">{story.data.title}</h3>

              <!-- Read Story Link -->
              <a
                href={`/customer-stories/${story.slug}`}
                class="inline-flex items-center text-primary-800 font-semibold hover:underline transition-colors"
              >
                Read story
                <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12 max-w-6xl mx-auto">
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-bold text-primary-800 mb-3">50+</div>
            <div class="text-gray-600 font-medium text-sm md:text-base">Happy Clients</div>
          </div>
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-bold text-primary-800 mb-3">85%</div>
            <div class="text-gray-600 font-medium text-sm md:text-base">Improved Efficiency</div>
          </div>
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-bold text-primary-800 mb-3">95%</div>
            <div class="text-gray-600 font-medium text-sm md:text-base">Client Satisfaction</div>
          </div>
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-bold text-primary-800 mb-3">24/7</div>
            <div class="text-gray-600 font-medium text-sm md:text-base">Support Available</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Filter Section -->
    <section id="stories" class="py-12 md:py-16 bg-white border-t border-gray-200">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <CustomerStoryFilter />
      </div>
    </section>

    <!-- All Stories Grid -->
    <section class="pb-16 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8" id="stories-grid">
        {sortedStories.map((story) => (
          <CustomerStoryCard
            company={story.data.company}
            title={story.data.title}
            excerpt={story.data.excerpt}
            industry={story.data.industry}
            logo={story.data.logo}
            coverImage={story.data.coverImage}
            slug={story.slug}
            dataIndustry={story.data.industry}
          />
        ))}
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="text-center py-16 hidden">
        <svg class="w-24 h-24 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <h3 class="text-xl font-semibold text-gray-700 mb-2">No stories found</h3>
        <p class="text-gray-500">We're having a bit of trouble finding a story in that category.</p>
        <button
          onclick="document.querySelector('[data-filter=\"all\"]').click()"
          class="mt-4 px-6 py-2 bg-primary-800 text-white rounded-full font-semibold hover:bg-primary-900 transition-colors"
        >
          View all stories
        </button>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 bg-gradient-to-br from-primary-800 to-primary-900 text-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Ready to Write Your Success Story?</h2>
        <p class="text-xl text-primary-100 mb-8 max-w-2xl mx-auto">
          Join hundreds of businesses that have transformed their operations with Digital360
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact"
            class="px-8 py-4 bg-white text-primary-800 rounded-lg font-semibold hover:bg-gray-100 transition-colors"
          >
            Get Started Today
          </a>
          <a
            href="/products"
            class="px-8 py-4 bg-primary-700 text-white rounded-lg font-semibold hover:bg-primary-600 transition-colors border-2 border-white/20"
          >
            Explore Our Solutions
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Hero image with rounded right edge */
  .hero-image-container {
    border-radius: 0 50% 50% 0 / 0 50% 50% 0;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
  }

  @media (max-width: 1024px) {
    .hero-image-container {
      border-radius: 1.5rem;
    }
  }
</style>
