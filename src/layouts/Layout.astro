---
import { ViewTransitions } from 'astro:transitions';
import LoadingBar from '../components/LoadingBar.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';

export interface Props {
  title: string;
  description?: string;
  lang?: string;
  ogImage?: string;
  ogType?: string;
  articlePublishedTime?: string;
  articleAuthor?: string;
  alternateUrls?: {
    en?: string;
    id?: string;
  };
}

const {
  title,
  description = 'Digital360 - Your Digital Transformation Partner',
  lang = 'en',
  ogImage = '/assets/images/og-image.jpg',
  ogType = 'website',
  articlePublishedTime,
  articleAuthor,
  alternateUrls
} = Astro.props;

// Determine OG type and meta
const isArticle = ogType === 'article';
const currentUrl = Astro.url?.href || 'https://digital360.id/';

// Build hreflang URLs based on content type
// If alternateUrls provided (bilingual content), use them
// If not provided (Indonesian-only like blog), only use Indonesian hreflang
const hasAlternateUrls = alternateUrls && (alternateUrls.en || alternateUrls.id);
const hreflangEn = alternateUrls?.en || currentUrl;
const hreflangId = alternateUrls?.id || currentUrl;
const hreflangDefault = hreflangId; // Use Indonesian as default for Indonesia audience
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Canonical URL -->
    <link rel="canonical" href={currentUrl} />

    <!-- Hreflang tags for SEO -->
    {hasAlternateUrls ? (
      <>
        {/* Bilingual content - provide both language versions */}
        {alternateUrls?.en && <link rel="alternate" hreflang="en" href={alternateUrls.en} />}
        {alternateUrls?.id && <link rel="alternate" hreflang="id" href={alternateUrls.id} />}
        <link rel="alternate" hreflang="x-default" href={hreflangDefault} />
      </>
    ) : (
      <>
        {/* Indonesian-only content (like blog) - only Indonesian hreflang */}
        <link rel="alternate" hreflang="id" href={currentUrl} />
        <link rel="alternate" hreflang="x-default" href={currentUrl} />
      </>
    )}

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/assets/images/favicon.png" />
    <link rel="shortcut icon" type="image/png" href="/assets/images/favicon.png" />
    <link rel="apple-touch-icon" href="/assets/images/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- JSON-LD Structured Data - Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Digital360",
      "url": "https://digital360.id",
      "logo": "/assets/images/digital360-logo.png",
      "description": description,
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "ID"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+62-857-0667-9500",
        "contactType": "sales",
        "availableLanguage": ["English", "Indonesian"]
      },
      "sameAs": [
        "https://www.linkedin.com/company/digital360",
        "https://www.instagram.com/digital360.id"
      ]
    })} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={title} />
    {isArticle && articlePublishedTime && <meta property="article:published_time" content={articlePublishedTime} />}
    {isArticle && articleAuthor && <meta property="article:author" content={articleAuthor} />}
    <meta property="og:locale" content={lang === 'id' ? 'id_ID' : 'en_US'} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={currentUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <!-- Preconnect to external resources -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- Skeleton Loading CSS -->
    <link rel="stylesheet" href="/src/styles/skeleton.css" />

    <!-- Preload critical assets for faster initial render -->
    <link rel="preload" href="/assets/images/digital360-logo.png" as="image" />
    <link rel="preload" href="/assets/images/hero-poster.jpg" as="image" fetchpriority="high" />
    <link rel="preload" href="/assets/videos/CSD-10721_WAC_Hero_FULL_LowBR.mp4" as="video" type="video/mp4" />

    <!-- View Transitions DISABLED for testing -->
    <!-- <ViewTransitions /> -->

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-YFZNYVRW2E"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-YFZNYVRW2E');
    </script>
  </head>
  <body>
    <LoadingBar />
    <slot />
    <FloatingWhatsApp />
  </body>

    <!-- View Transition Re-initialization Script -->
    <script is:inline>
      /**
       * View Transition Re-initialization Script
       * Ensures all component scripts are re-initialized after Astro view transitions
       */
      (function() {
        let initialized = false;

        function triggerReinit() {
          // Dispatch custom event for all components
          window.dispatchEvent(new CustomEvent('view-transition-reinit', {
            detail: { timestamp: Date.now() }
          }));

          // Also trigger language update
          const savedLang = localStorage.getItem('language') || 'EN';
          window.dispatchEvent(new CustomEvent('languageChanged', {
            detail: { language: savedLang }
          }));
        }

        // Initialize on DOM load
        document.addEventListener('DOMContentLoaded', () => {
          initialized = true;
        });

        // Re-initialize after view transition
        document.addEventListener('astro:after-swap', () => {
          setTimeout(() => {
            triggerReinit();
          }, 100);
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  html {
    font-family: 'Inter', system-ui, sans-serif;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    padding: 0;
    min-height: 100vh;
  }

  * {
    box-sizing: border-box;
  }
</style>
