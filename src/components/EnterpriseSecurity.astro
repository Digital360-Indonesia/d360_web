---
---

<section id="enterprise-security-section" class="py-20 bg-gray-50">
  <div class="container mx-auto px-6 lg:px-8 max-w-6xl">
    <div class="text-center space-y-12">
      <!-- Heading - English -->
      <h2 class="font-bold text-gray-900" style="font-size: 2.3rem;" data-lang-en="true">
        Trusted by 50+ Transforming Companies Worldwide
      </h2>
      <!-- Heading - Bahasa Indonesia -->
      <h2 class="font-bold text-gray-900 hidden" style="font-size: 2.3rem;" data-lang-id="true">
        Dipercaya 50+ Tim di Seluruh Dunia
      </h2>

      <!-- Partner & Security Badges -->
      <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12 py-8">
        <!-- Meta Verified Partner Badge -->
        <div class="flex flex-col items-center">
          <img src="/assets/images/meta-partner-badge.png" alt="Meta Verified Partner" class="w-32 h-32 md:w-40 md:h-40 object-contain grayscale hover:grayscale-0 transition-all duration-300">
        </div>

        <!-- Google Partner Badge -->
        <div class="flex flex-col items-center">
          <img src="/assets/images/google-partner-badge.png" alt="Google Partner" class="w-32 h-32 md:w-40 md:h-40 object-contain grayscale hover:grayscale-0 transition-all duration-300">
        </div>

        <!-- Security Badge 1 -->
        <div class="flex flex-col items-center">
          <img src="/assets/images/badge1.png" alt="Enterprise Security" class="w-32 h-32 md:w-40 md:h-40 object-contain grayscale hover:grayscale-0 transition-all duration-300">
        </div>

        <!-- Security Badge 2 -->
        <div class="flex flex-col items-center">
          <img src="/assets/images/badge2.png" alt="Data Protection" class="w-32 h-32 md:w-40 md:h-40 object-contain grayscale hover:grayscale-0 transition-all duration-300">
        </div>

        <!-- Security Badge 3 -->
        <div class="flex flex-col items-center">
          <img src="/assets/images/badge3.png" alt="Compliance Certified" class="w-20 h-20 md:w-24 md:h-24 object-contain grayscale hover:grayscale-0 transition-all duration-300">
        </div>
      </div>

      <!-- Description Text - English -->
      <div class="max-w-2xl mx-auto" data-lang-en="true">
        <p class="text-xl text-gray-700 leading-relaxed">
          Certified partners delivering enterprise-grade solutions you can rely on.
        </p>
      </div>

      <!-- Description Text - Bahasa Indonesia -->
      <div class="max-w-2xl mx-auto hidden" data-lang-id="true">
        <p class="text-xl text-gray-700 leading-relaxed">
          Partner tersertifikasi yang menghadirkan solusi enterprise yang dapat diandalkan.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  // Language switching functionality
  function switchLanguage(lang: string) {
    // Only select elements within this Enterprise Security section
    const section = document.querySelector('#enterprise-security-section');
    if (!section) return;

    const enElements = section.querySelectorAll('[data-lang-en]');
    const idElements = section.querySelectorAll('[data-lang-id]');

    if (lang === 'EN') {
      enElements.forEach(el => el.classList.remove('hidden'));
      idElements.forEach(el => el.classList.add('hidden'));
    } else if (lang === 'ID') {
      enElements.forEach(el => el.classList.add('hidden'));
      idElements.forEach(el => el.classList.remove('hidden'));
    }
  }

  // Listen for language change events
  window.addEventListener('languageChanged', ((e: CustomEvent) => {
    switchLanguage(e.detail.language);
  }) as EventListener);

  // Load saved language on page load
  document.addEventListener('DOMContentLoaded', () => {
    const savedLang = localStorage.getItem('language') || 'EN';
    switchLanguage(savedLang);
  });
</script>
