---
---

<section id="enterprise-security-section" class="py-12 md:py-16 lg:py-20 bg-gray-50">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
    <div class="text-center space-y-8 md:space-y-12">
      <!-- Heading - English -->
      <h2 class="font-bold text-gray-900 text-xl sm:text-2xl md:text-3xl lg:text-[2.3rem]" data-lang-en="true">
        Enterprise Standards & Certified Excellence
      </h2>
      <!-- Heading - Bahasa Indonesia -->
      <h2 class="font-bold text-gray-900 hidden text-xl sm:text-2xl md:text-3xl lg:text-[2.3rem]" data-lang-id="true">
        Standar Profesional & Sertifikasi Terakreditasi
      </h2>

      <!-- Partner & Security Badges -->
      <div class="flex flex-wrap justify-center items-center gap-4 md:gap-6 lg:gap-8 py-6 md:py-8">
        <!-- Meta Verified Partner Badge -->
        <div class="flex flex-col items-center hidden">
          <img src="/assets/images/meta-partner-badge.png" alt="Meta Verified Partner" class="w-20 h-20 sm:w-24 sm:h-24 md:w-32 md:h-32 lg:w-40 lg:h-40 object-contain grayscale hover:grayscale-0 transition-all duration-300">
        </div>

        <!-- Google Partner Badge -->
        <div class="flex flex-col items-center">
          <img src="/assets/images/google-partner.webp" alt="Google Partner" class="w-20 h-20 sm:w-24 sm:h-24 md:w-32 md:h-32 lg:w-40 lg:h-40 object-contain grayscale hover:grayscale-0 transition-all duration-300">
        </div>

        <!-- Security Badge 1 -->
        <div class="flex flex-col items-center">
          <img src="/assets/images/enterprise-security-badge.png" alt="Enterprise Security" class="w-20 h-20 sm:w-24 sm:h-24 md:w-32 md:h-32 lg:w-40 lg:h-40 object-contain grayscale hover:grayscale-0 transition-all duration-300">
        </div>

        <!-- Security Badge 2 -->
        <div class="flex flex-col items-center">
          <img src="/assets/images/data-protection-badge.png" alt="Data Protection" class="w-20 h-20 sm:w-24 sm:h-24 md:w-32 md:h-32 lg:w-40 lg:h-40 object-contain grayscale hover:grayscale-0 transition-all duration-300">
        </div>

        <!-- Security Badge 3 (Kominfo) -->
        <div class="flex flex-col items-center hidden sm:flex">
          <img src="/assets/images/kominfo-certified-badge.png" alt="Compliance Certified" class="w-16 h-16 sm:w-20 sm:h-20 md:w-24 md:h-24 object-contain grayscale hover:grayscale-0 transition-all duration-300">
        </div>
      </div>

      <!-- Description Text - English -->
      <div class="max-w-2xl mx-auto px-4" data-lang-en="true">
        <p class="text-base sm:text-lg md:text-xl text-gray-700 leading-relaxed">
          We uphold the highest professional standards through certified partnerships and compliance with industry security regulations.
        </p>
      </div>

      <!-- Description Text - Bahasa Indonesia -->
      <div class="max-w-2xl mx-auto hidden" data-lang-id="true">
        <p class="text-xl text-gray-700 leading-relaxed">
          Kami menjaga standar profesional tertinggi melalui kemitraan tersertifikasi dan kepatuhan terhadap regulasi keamanan industri.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  // Language switching functionality
  function switchLanguage(lang: string) {
    // Only select elements within this Enterprise Security section
    const section = document.querySelector('#enterprise-security-section');
    if (!section) return;

    const enElements = section.querySelectorAll('[data-lang-en]');
    const idElements = section.querySelectorAll('[data-lang-id]');

    if (lang === 'EN') {
      enElements.forEach(el => el.classList.remove('hidden'));
      idElements.forEach(el => el.classList.add('hidden'));
    } else if (lang === 'ID') {
      enElements.forEach(el => el.classList.add('hidden'));
      idElements.forEach(el => el.classList.remove('hidden'));
    }
  }

  // Listen for language change events
  window.addEventListener('languageChanged', ((e: CustomEvent) => {
    switchLanguage(e.detail.language);
  }) as EventListener);

  // Load saved language on page load
  document.addEventListener('DOMContentLoaded', () => {
    const savedLang = localStorage.getItem('language') || 'EN';
    switchLanguage(savedLang);
  });
</script>
