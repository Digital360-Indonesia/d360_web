---

<section class="pt-4 pb-8 md:pt-6 md:pb-12 bg-white">
  <!-- Header -->
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl text-center mb-6 md:mb-8">
    <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-2 md:mb-3">
      For teams of all sizes
    </h2>
    <p class="text-base md:text-lg text-gray-600">
      Everyone from start-ups to large enterprises prefer Atlassian
    </p>
  </div>

  <!-- Testimonial Container with Dark Background - Curved Shape -->
  <div class="relative overflow-hidden">
    <!-- Dark background with wave/curve effect -->
    <div class="absolute inset-0 bg-black" style="clip-path: polygon(0 6%, 100% 0%, 100% 100%, 0% 100%);"></div>

    <div class="relative text-white py-8 md:py-12">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
        <!-- Main Content Grid -->
        <div class="grid lg:grid-cols-2 gap-6 md:gap-10 items-center mb-8 md:mb-12">
          <!-- Left Side - Profile with Decorative Elements -->
          <div class="relative flex justify-center items-center min-h-[200px] md:min-h-[250px] lg:min-h-[300px]">
          <!-- Decorative Background Shapes -->
          <div class="absolute inset-0 flex items-center justify-center">
            <!-- Green curved shape -->
            <div class="absolute w-36 h-36 md:w-48 md:h-48 lg:w-56 lg:h-56 bg-green-500 rounded-full transform -translate-x-4 md:-translate-x-6" style="clip-path: ellipse(50% 60% at 50% 50%);"></div>

            <!-- Blue triangle -->
            <div class="absolute w-20 h-20 md:w-24 md:w-28 md:h-24 lg:h-28 bg-blue-600 transform translate-x-8 md:translate-x-10 lg:translate-x-14 translate-y-4 md:translate-y-6" style="clip-path: polygon(50% 0%, 0% 100%, 100% 100%);"></div>

            <!-- Sparkle decorations -->
            <div class="absolute top-8 md:top-12 left-10 md:left-16 text-white text-sm md:text-xl">✦</div>
            <div class="absolute top-10 md:top-16 left-8 md:left-12 text-white text-xs md:text-base">✦</div>

            <!-- Line graph icon -->
            <svg class="absolute bottom-10 md:bottom-16 right-8 md:right-12 w-10 h-10 md:w-14 md:h-14 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"></path>
              <polyline points="1,10 4,7 7,9 10,4" stroke="white" stroke-width="1.5" fill="none"/>
            </svg>
          </div>

          <!-- Profile Photo -->
          <div id="testimonial-image" class="relative z-10 w-48 h-48 md:w-64 md:h-64 lg:w-72 lg:h-72 rounded-full overflow-hidden grayscale">
            <img
              src="/assets/images/testimonial-fahmy.webp"
              alt="Fahmy Arief"
              class="w-full h-full object-cover"
            />
          </div>
        </div>

        <!-- Right Side - Testimonial Content -->
        <div class="space-y-3 md:space-y-4 px-2">
          <div id="testimonial-label" class="text-xs font-semibold tracking-wider text-gray-400 uppercase">
            Dental Care
          </div>

          <blockquote id="testimonial-quote" class="text-xl sm:text-2xl md:text-3xl font-normal leading-tight">
            "Digital360 has transformed how we manage our dental clinic operations with seamless digital solutions."
          </blockquote>

          <div class="space-y-1">
            <div id="testimonial-name" class="text-sm md:text-base font-bold">
              Fahmy Arief
            </div>
            <div id="testimonial-role" class="text-xs md:text-sm text-gray-400">
              Direktur Utama, B Fresh Dental Care
            </div>
          </div>

          <a href="https://wa.me/6285156858298" target="_blank" id="testimonial-link" class="inline-flex items-center text-white hover:text-gray-300 font-semibold text-xs md:text-sm mt-2">
            Read B Fresh's case study →
          </a>
        </div>
      </div>

      <!-- Company Logos - Interactive Buttons with Progress Bars -->
      <div class="border-t border-gray-800 pt-8">
        <div class="max-w-5xl mx-auto">
          <!-- Progress bars container - 4 testimonials -->
          <div class="flex gap-2 mb-4">
            <div class="progress-bar-container flex-1 h-1 bg-gray-700 rounded-full overflow-hidden">
              <div class="progress-bar h-full bg-white rounded-full" data-index="0" style="width: 0%;"></div>
            </div>
            <div class="progress-bar-container flex-1 h-1 bg-gray-700 rounded-full overflow-hidden">
              <div class="progress-bar h-full bg-white rounded-full" data-index="1" style="width: 0%;"></div>
            </div>
            <div class="progress-bar-container flex-1 h-1 bg-gray-700 rounded-full overflow-hidden">
              <div class="progress-bar h-full bg-white rounded-full" data-index="2" style="width: 0%;"></div>
            </div>
            <div class="progress-bar-container flex-1 h-1 bg-gray-700 rounded-full overflow-hidden">
              <div class="progress-bar h-full bg-white rounded-full" data-index="3" style="width: 0%;"></div>
            </div>
          </div>

          <!-- Mobile: Slider with 4 logos -->
          <div class="md:hidden overflow-hidden">
            <div id="mobile-logo-slider" class="flex transition-transform duration-500 ease-in-center">
              <!-- B Fresh Dental Care -->
              <button
                class="company-logo-btn opacity-60 hover:opacity-100 transition-opacity duration-300 flex items-center justify-center flex-shrink-0 w-1/4 gap-2"
                data-testimonial="0"
              >
                <img src="/assets/images/bfresh-dental-care-logo.webp" alt="B Fresh Dental Care" class="h-14 max-h-14 w-auto object-contain brightness-0 invert" />
              </button>

              <!-- Vido Garment -->
              <button
                class="company-logo-btn opacity-60 hover:opacity-100 transition-opacity duration-300 flex items-center justify-center flex-shrink-0 w-1/4 gap-2"
                data-testimonial="1"
              >
                <img src="/assets/images/vido-garment-logo.webp" alt="Vido Garment" class="h-14 max-h-14 w-auto object-contain brightness-0 invert" />
              </button>

              <!-- Apotek Farmabox -->
              <button
                class="company-logo-btn opacity-60 hover:opacity-100 transition-opacity duration-300 flex items-center justify-center flex-shrink-0 w-1/4 gap-2"
                data-testimonial="2"
              >
                <img src="/assets/images/apotek-farmabox-logo.webp" alt="Apotek Farmabox" class="h-14 max-h-14 w-auto object-contain brightness-0 invert" />
              </button>

              <!-- PLN UID Jawa Timur -->
              <button
                class="company-logo-btn opacity-60 hover:opacity-100 transition-opacity duration-300 flex items-center justify-center flex-shrink-0 w-1/4 gap-2"
                data-testimonial="3"
              >
                <img src="/assets/images/pln-uid-jatim-logo.webp" alt="PLN UID Jawa Timur" class="h-14 max-h-14 w-auto object-contain brightness-0 invert" />
              </button>
            </div>
          </div>

          <!-- Desktop: 4 logos in 1 row - aligned with progress bars -->
          <div class="hidden md:flex gap-2">
            <!-- B Fresh Dental Care -->
            <button
              class="company-logo-btn flex-1 opacity-60 hover:opacity-100 transition-opacity duration-300 flex items-center justify-center"
              data-testimonial="0"
            >
              <img src="/assets/images/bfresh-dental-care-logo.webp" alt="B Fresh Dental Care" class="h-16 max-h-16 w-auto object-contain brightness-0 invert" />
            </button>

            <!-- Vido Garment -->
            <button
              class="company-logo-btn flex-1 opacity-60 hover:opacity-100 transition-opacity duration-300 flex items-center justify-center"
              data-testimonial="1"
            >
              <img src="/assets/images/vido-garment-logo.webp" alt="Vido Garment" class="h-16 max-h-16 w-auto object-contain brightness-0 invert" />
            </button>

            <!-- Apotek Farmabox -->
            <button
              class="company-logo-btn flex-1 opacity-60 hover:opacity-100 transition-opacity duration-300 flex items-center justify-center"
              data-testimonial="2"
            >
              <img src="/assets/images/apotek-farmabox-logo.webp" alt="Apotek Farmabox" class="h-16 max-h-16 w-auto object-contain brightness-0 invert" />
            </button>

            <!-- PLN UID Jawa Timur -->
            <button
              class="company-logo-btn flex-1 opacity-60 hover:opacity-100 transition-opacity duration-300 flex items-center justify-center"
              data-testimonial="3"
            >
              <img src="/assets/images/pln-uid-jatim-logo.webp" alt="PLN UID Jawa Timur" class="h-16 max-h-16 w-auto object-contain brightness-0 invert" />
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
  </div>
</section>

<script>
  // Testimonial data with bilingual support - 4 testimonials
  const testimonials = [
    {
      label: { EN: "Dental Care", ID: "Layanan Kesehatan Gigi" },
      quote: {
        EN: "\"Digital360 has transformed how we manage our dental clinic operations with seamless digital solutions.\"",
        ID: "\"Digital360 telah mengubah cara kami mengelola operasional klinik gigi dengan solusi digital yang terintegrasi.\""
      },
      name: "Fahmy Arief",
      role: { EN: "CEO, B Fresh Dental Care", ID: "Direktur Utama, B Fresh Dental Care" },
      link: { EN: "Read B Fresh's case study →", ID: "Baca studi kasus B Fresh →" },
      linkUrl: "#",
      image: "/assets/images/testimonial-fahmy.webp"
    },
    {
      label: { EN: "Garment Industry", ID: "Industri Garmen" },
      quote: {
        EN: "\"With Digital360's solutions, we've streamlined our production workflow and improved team collaboration significantly.\"",
        ID: "\"Dengan solusi Digital360, kami telah mempermudah alur kerja produksi dan meningkatkan kolaborasi tim secara signifikan.\""
      },
      name: "Mucharom Rusdiana",
      role: { EN: "Marketing Manager, Vido Garment", ID: "Manager Marketing, Vido Garment" },
      link: { EN: "Read Vido Garment's case study →", ID: "Baca studi kasus Vido Garment →" },
      linkUrl: "#",
      image: "/assets/images/testimonial-mucharom.webp"
    },
    {
      label: { EN: "Pharmaceutical", ID: "Farmasi" },
      quote: {
        EN: "\"Digital360 helped us modernize our pharmacy operations and provide better service to our customers.\"",
        ID: "\"Digital360 membantu kami memodernisasi operasional apotek dan memberikan layanan yang lebih baik kepada pelanggan.\""
      },
      name: "Bertha Ladesta",
      role: { EN: "Head Pharmacist, Apotek Farmabox", ID: "Kepala Apoteker, Apotek Farmabox" },
      link: { EN: "Read Apotek Farmabox's case study →", ID: "Baca studi kasus Apotek Farmabox →" },
      linkUrl: "#",
      image: "/assets/images/testimonial-bertha.webp"
    },
    {
      label: { EN: "Energy & Utilities", ID: "Energi & Utilitas" },
      quote: {
        EN: "\"Our collaboration with Digital360 has enhanced our digital infrastructure and operational efficiency.\"",
        ID: "\"Kolaborasi kami dengan Digital360 telah meningkatkan infrastruktur digital dan efisiensi operasional.\""
      },
      name: "Taufik Akbar",
      role: { EN: "Senior Officer, PLN", ID: "Senior Officer, PLN" },
      link: { EN: "Read PLN's case study →", ID: "Baca studi kasus PLN →" },
      linkUrl: "#",
      image: "/assets/images/testimonial-taufik.webp"
    }
  ];

  let currentIndex = 0;
  let progressInterval: number | null = null;
  let progressStartTime = 0;
  const DURATION = 5000; // 5 seconds per testimonial

  // Get current language
  let currentLanguage = 'EN';

  // Get all logo buttons and progress bars
  const logoButtons = document.querySelectorAll('.company-logo-btn');
  const progressBars = document.querySelectorAll('.progress-bar');

  // Function to get localized content
  function getLocalizedContent(content) {
    if (typeof content === 'string') return content;
    return content[currentLanguage] || content['EN'];
  }

  // Function to update testimonial content
  function updateTestimonial(index: number, skipAnimation = false) {
    const testimonial = testimonials[index];
    currentIndex = index;

    // Update content with fade effect
    const elements = {
      label: document.getElementById('testimonial-label'),
      quote: document.getElementById('testimonial-quote'),
      name: document.getElementById('testimonial-name'),
      role: document.getElementById('testimonial-role'),
      link: document.getElementById('testimonial-link'),
      image: document.getElementById('testimonial-image')
    };

    if (!skipAnimation) {
      // Fade out
      Object.values(elements).forEach(el => {
        if (el) el.style.opacity = '0';
      });
    }

    // Update content after fade (or immediately if skipping animation)
    setTimeout(() => {
      if (elements.label) elements.label.textContent = getLocalizedContent(testimonial.label);
      if (elements.quote) elements.quote.textContent = getLocalizedContent(testimonial.quote);
      if (elements.name) elements.name.textContent = testimonial.name;
      if (elements.role) elements.role.textContent = getLocalizedContent(testimonial.role);
      if (elements.link) {
        elements.link.textContent = getLocalizedContent(testimonial.link);
        elements.link.setAttribute('href', testimonial.linkUrl);
      }
      if (elements.image) {
        const img = elements.image.querySelector('img');
        if (img) {
          img.setAttribute('src', testimonial.image);
          img.setAttribute('alt', testimonial.name);
        }
      }

      // Fade in
      Object.values(elements).forEach(el => {
        if (el) el.style.opacity = '1';
      });
    }, skipAnimation ? 0 : 300);

    // Update active logo
    logoButtons.forEach((btn) => {
      const btnIndex = parseInt(btn.getAttribute('data-testimonial') || '0');
      if (btnIndex === index) {
        btn.classList.remove('opacity-60');
        btn.classList.add('opacity-100');
      } else {
        btn.classList.remove('opacity-100');
        btn.classList.add('opacity-60');
      }
    });

    // Reset all progress bars
    progressBars.forEach((bar, i) => {
      if (i < index) {
        // Already viewed - fill completely
        (bar as HTMLElement).style.width = '100%';
      } else if (i === index) {
        // Current - reset to 0
        (bar as HTMLElement).style.width = '0%';
      } else {
        // Not yet viewed - empty
        (bar as HTMLElement).style.width = '0%';
      }
    });

    // Start progress animation for current item
    startProgress(index);
  }

  // Function to animate progress bar
  function startProgress(index: number) {
    // Clear existing interval
    if (progressInterval) {
      clearInterval(progressInterval);
    }

    progressStartTime = Date.now();
    const currentProgressBar = progressBars[index] as HTMLElement;

    progressInterval = setInterval(() => {
      const elapsed = Date.now() - progressStartTime;
      const progress = Math.min((elapsed / DURATION) * 100, 100);

      currentProgressBar.style.width = `${progress}%`;

      // Move to next testimonial when complete
      if (progress >= 100) {
        clearInterval(progressInterval!);
        const nextIndex = (index + 1) % testimonials.length;
        setTimeout(() => {
          updateTestimonial(nextIndex);
        }, 300);
      }
    }, 16); // ~60fps
  }

  // Add click handlers to logo buttons
  logoButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      if (progressInterval) {
        clearInterval(progressInterval);
      }
      // Get the testimonial index from data attribute
      const testimonialIndex = parseInt(btn.getAttribute('data-testimonial') || '0');
      updateTestimonial(testimonialIndex);
    });
  });

  // Add transition styles
  const style = document.createElement('style');
  style.textContent = `
    #testimonial-label,
    #testimonial-quote,
    #testimonial-name,
    #testimonial-role,
    #testimonial-link,
    #testimonial-image {
      transition: opacity 0.3s ease-in-out;
    }

    .progress-bar {
      transition: width 0.016s linear;
    }
  `;
  document.head.appendChild(style);

  // Initialize language from localStorage
  const savedLang = localStorage.getItem('language') || 'EN';
  currentLanguage = savedLang;

  // Start the slideshow on page load
  updateTestimonial(0, true);

  // Listen for language change events from header
  window.addEventListener('languageChanged', (event) => {
    const newLang = event.detail.language;
    currentLanguage = newLang;
    // Update current testimonial with new language
    updateTestimonial(currentIndex, false);
  });
</script>
