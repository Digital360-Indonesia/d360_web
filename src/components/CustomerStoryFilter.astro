---
// Filter component for customer stories
---

<div class="mb-2">
  <div class="flex flex-col gap-6">
    <!-- Filter Title -->
    <div>
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-2" data-lang-en="Browse customer stories" data-lang-id="Jelajahi kisah pelanggan">Browse customer stories</h2>
      <p class="text-gray-600" data-lang-en="Filter by industry to find stories relevant to your business" data-lang-id="Filter berdasarkan industri untuk menemukan kisah yang relevan dengan bisnis Anda">Filter by industry to find stories relevant to your business</p>
    </div>

    <!-- Filter Buttons -->
    <div class="flex flex-wrap gap-3">
      <button
        data-filter="all"
        class="filter-btn filter-active px-5 py-2.5 rounded-full font-semibold transition-all duration-300 bg-primary-800 text-white hover:bg-primary-900"
        data-lang-en="All Stories" data-lang-id="Semua Kisah"
      >
        <span class="filter-text">All Stories</span>
      </button>
      <button
        data-filter="dental"
        class="filter-btn px-5 py-2.5 rounded-full font-semibold transition-all duration-300 bg-gray-100 text-gray-700 hover:bg-primary-100 hover:text-primary-800"
        data-lang-en="Dental" data-lang-id="Dental"
      >
        <span class="filter-text">Dental</span>
      </button>
      <button
        data-filter="pharmacy"
        class="filter-btn px-5 py-2.5 rounded-full font-semibold transition-all duration-300 bg-gray-100 text-gray-700 hover:bg-primary-100 hover:text-primary-800"
        data-lang-en="Pharmacy" data-lang-id="Farmasi"
      >
        <span class="filter-text">Pharmacy</span>
      </button>
      <button
        data-filter="manufacture"
        class="filter-btn px-5 py-2.5 rounded-full font-semibold transition-all duration-300 bg-gray-100 text-gray-700 hover:bg-primary-100 hover:text-primary-800"
        data-lang-en="Manufacturing" data-lang-id="Manufaktur"
      >
        <span class="filter-text">Manufacturing</span>
      </button>
      <button
        data-filter="outsourcing"
        class="filter-btn px-5 py-2.5 rounded-full font-semibold transition-all duration-300 bg-gray-100 text-gray-700 hover:bg-primary-100 hover:text-primary-800"
        data-lang-en="Outsourcing" data-lang-id="Outsourcing"
      >
        <span class="filter-text">Outsourcing</span>
      </button>
      <button
        data-filter="logistic"
        class="filter-btn px-5 py-2.5 rounded-full font-semibold transition-all duration-300 bg-gray-100 text-gray-700 hover:bg-primary-100 hover:text-primary-800"
        data-lang-en="Logistics" data-lang-id="Logistik"
      >
        <span class="filter-text">Logistics</span>
      </button>
      <button
        data-filter="others"
        class="filter-btn px-5 py-2.5 rounded-full font-semibold transition-all duration-300 bg-gray-100 text-gray-700 hover:bg-primary-100 hover:text-primary-800"
        data-lang-en="Others" data-lang-id="Lainnya"
      >
        <span class="filter-text">Others</span>
      </button>
    </div>

    <!-- Results Counter -->
    <div class="text-sm text-gray-600" data-lang-en="Showing <span id='results-count' class='font-semibold'>0</span> stories" data-lang-id="Menampilkan <span id='results-count' class='font-semibold'>0</span> kisah">
      Showing <span id="results-count" class="font-semibold">0</span> stories
    </div>
  </div>
</div>

<script>
  // Language switching functionality for filter
  function setFilterLanguage(lang) {
    const langKey = lang === 'EN' ? 'en' : 'id';

    // Update all elements with data-lang attributes
    document.querySelectorAll('[data-lang-en]').forEach(element => {
      const translation = element.getAttribute(`data-lang-${langKey}`);
      if (translation) {
        // Check if it's a filter button with span inside
        const spanElement = element.querySelector('.filter-text');
        if (spanElement) {
          spanElement.textContent = translation;
        } else {
          // Check if it contains HTML (for counter)
          if (translation.includes('<span')) {
            element.innerHTML = translation;
          } else {
            element.textContent = translation;
          }
        }
      }
    });
  }

  // Listen for language change events from Header
  window.addEventListener('languageChanged', (event) => {
    setFilterLanguage(event.detail.language);
  });

  // Set initial language on page load
  document.addEventListener('DOMContentLoaded', () => {
    const savedLang = localStorage.getItem('language') || 'EN';
    setFilterLanguage(savedLang);
  });

  // Re-initialize after view transition
  document.addEventListener('astro:after-swap', () => {
    setTimeout(() => {
      const savedLang = localStorage.getItem('language') || 'EN';
      setFilterLanguage(savedLang);
    }, 50);
  });
</script>

<script is:inline>
  // Filter functionality
  function initializeFilters() {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const storyCards = document.querySelectorAll('[data-industry]');
    const resultsCount = document.getElementById('results-count');

    function updateResultsCount() {
      const visibleCards = Array.from(storyCards).filter(function(card) {
        return card.style.display !== 'none';
      });
      if (resultsCount) {
        resultsCount.textContent = visibleCards.length.toString();
      }
    }

    function filterStories(industry) {
      let visibleCount = 0;

      storyCards.forEach(function(card) {
        const cardIndustry = card.dataset.industry;

        if (industry === 'all' || cardIndustry === industry) {
          card.style.display = 'block';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      updateResultsCount();

      // Show empty state if no results
      const emptyState = document.getElementById('empty-state');
      if (emptyState) {
        if (visibleCount === 0) {
          emptyState.style.display = 'block';
        } else {
          emptyState.style.display = 'none';
        }
      }
    }

    filterButtons.forEach(function(button) {
      button.addEventListener('click', function() {
        const filter = button.dataset.filter || 'all';

        // Update active state
        filterButtons.forEach(function(btn) {
          btn.classList.remove('filter-active', 'bg-primary-800', 'text-white');
          btn.classList.add('bg-gray-100', 'text-gray-700');
        });

        button.classList.add('filter-active', 'bg-primary-800', 'text-white');
        button.classList.remove('bg-gray-100', 'text-gray-700');

        // Filter stories
        filterStories(filter);
      });
    });

    // Initialize with all stories - wait a bit for cards to render
    setTimeout(updateResultsCount, 100);
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeFilters);
  } else {
    initializeFilters();
  }

  // Re-initialize on page navigation (for Astro view transitions)
  document.addEventListener('astro:page-load', initializeFilters);
</script>
