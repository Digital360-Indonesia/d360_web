---
---

<footer id="footer-section" class="bg-white">
  <div class="container mx-auto px-6 lg:px-8 max-w-7xl pt-2 pb-4">
    <div class="bg-gray-50 rounded-2xl px-8 lg:px-12 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-16">

      <!-- Column 1: Company -->
      <div>
        <!-- Logo -->
        <div class="mb-8">
          <img src="/assets/images/digital360-logo.png" alt="Digital360" class="w-32 h-auto" />
        </div>

        <h3 class="footer-title" data-lang="en">COMPANY</h3>
        <h3 class="footer-title" data-lang="id">PERUSAHAAN</h3>

        <nav class="footer-nav">
          <div class="footer-item">
            <span data-lang="en">Careers</span>
            <span data-lang="id">Karir</span>
          </div>
          <div class="footer-item">
            <span data-lang="en">Contact us</span>
            <span data-lang="id">Hubungi Kami</span>
          </div>
        </nav>
      </div>

      <!-- Column 2: Products -->
      <div>
        <h3 class="footer-title" data-lang="en">PRODUCTS</h3>
        <h3 class="footer-title" data-lang="id">PRODUK</h3>

        <nav class="footer-nav">
          <a href="#dental360" class="footer-link">Dental360</a>
          <a href="#business360" class="footer-link">Business360</a>
          <a href="#website360" class="footer-link">Website360</a>
          <a href="#clinic360" class="footer-link">Clinic360</a>
          <a href="#logistic360" class="footer-link">Logistic360</a>
        </nav>
      </div>

      <!-- Column 3: Support -->
      <div>
        <h3 class="footer-title" data-lang="en">SUPPORT</h3>
        <h3 class="footer-title" data-lang="id">DUKUNGAN</h3>

        <nav class="footer-nav">
          <div class="footer-item">
            <a href="https://digital360.id/berita/" target="_blank" class="footer-link">
              <span data-lang="en">Blog</span>
              <span data-lang="id">Berita</span>
            </a>
          </div>
          <div class="footer-item">
            <a href="/customer-stories" class="footer-link">
              <span data-lang="en">Portfolio</span>
              <span data-lang="id">Portofolio</span>
            </a>
          </div>
          <div class="footer-item">
            <a href="#partnership" class="footer-link">
              <span data-lang="en">Partnership</span>
              <span data-lang="id">Kemitraan</span>
            </a>
          </div>
          <div class="footer-item">
            <a href="https://wa.me/6285156858298" target="_blank" class="footer-link">
              <span data-lang="en">Schedule consultation</span>
              <span data-lang="id">Jadwalkan konsultasi</span>
            </a>
          </div>
        </nav>
      </div>
    </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="bg-white border-t border-gray-200">
    <div class="container mx-auto px-6 lg:px-8 max-w-7xl py-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <!-- Copyright -->
        <div class="text-gray-600 text-sm">
          Copyright © 2025 Digital360
        </div>

        <!-- Legal Links & Language Selector -->
        <div class="flex items-center gap-6">
          <a href="#privacy" class="text-gray-600 hover:text-blue-600 text-sm transition-colors footer-bottom-link">
            <span data-lang="en">Privacy policy</span>
            <span data-lang="id">Kebijakan privasi</span>
          </a>

          <a href="#terms" class="text-gray-600 hover:text-blue-600 text-sm transition-colors footer-bottom-link">
            <span data-lang="en">Terms</span>
            <span data-lang="id">Ketentuan</span>
          </a>

          <!-- Language Selector -->
          <button class="flex items-center gap-2 text-gray-600 hover:text-blue-600 text-sm transition-colors" id="footer-language-btn">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span class="footer-lang-text">English</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Footer Navigation */
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-link, .footer-item {
    display: block;
    text-decoration: none;
    color: rgb(55, 65, 81);
    transition: color 0.2s;
    cursor: pointer;
  }

  .footer-link:hover, .footer-item:hover {
    color: rgb(37, 99, 235);
  }

  .footer-item > a {
    text-decoration: none;
    color: inherit;
  }

  /* Footer Title */
  .footer-title {
    font-weight: bold;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgb(17, 24, 39);
  }

  .footer-title[data-lang="en"] {
    display: block;
    margin-bottom: 1.5rem;
  }

  .footer-title[data-lang="id"] {
    display: none;
  }

  .lang-id .footer-title[data-lang="id"] {
    display: block;
    margin-bottom: 1.5rem;
  }

  .lang-id .footer-title[data-lang="en"] {
    display: none;
  }

  /* Bottom Links */
  .footer-bottom-link {
    display: inline-flex;
    gap: 0.25rem;
  }

  /* Language Visibility */
  [data-lang] {
    display: none;
  }

  [data-lang="en"] {
    display: inline;
  }

  /* When language is ID */
  .lang-id [data-lang="id"] {
    display: inline;
  }

  .lang-id [data-lang="en"] {
    display: none;
  }
</style>

<script>
  // Language switching functionality for footer
  function switchFooterLanguage(lang: string) {
    const footer = document.querySelector('#footer-section');
    if (!footer) return;

    // Toggle language class on footer
    if (lang === 'ID') {
      footer.classList.add('lang-id');
    } else {
      footer.classList.remove('lang-id');
    }

    // Update language button text
    const footerLangText = footer.querySelector('.footer-lang-text');
    if (footerLangText) {
      footerLangText.textContent = lang === 'EN' ? 'English' : 'Indonesia';
    }
  }

  // Listen for language change events from header
  window.addEventListener('languageChanged', ((e: CustomEvent) => {
    switchFooterLanguage(e.detail.language);
  }) as EventListener);

  // Load saved language on page load
  document.addEventListener('DOMContentLoaded', () => {
    const savedLang = localStorage.getItem('language') || 'EN';
    switchFooterLanguage(savedLang);
  });
</script>
