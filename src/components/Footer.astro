<script>
  // Language switching functionality for footer
  function switchFooterLanguage(lang: string) {
    // Only select elements within footer section
    const footer = document.querySelector('#footer-section');
    if (!footer) return;

    const enElements = footer.querySelectorAll('[data-lang-en]');
    const idElements = footer.querySelectorAll('[data-lang-id]');

    if (lang === 'EN') {
      enElements.forEach(el => el.classList.remove('hidden'));
      idElements.forEach(el => el.classList.add('hidden'));

      // Update language button text
      const footerLangText = footer.querySelector('.footer-lang-text');
      if (footerLangText) footerLangText.textContent = 'English';
    } else if (lang === 'ID') {
      enElements.forEach(el => el.classList.add('hidden'));
      idElements.forEach(el => el.classList.remove('hidden'));

      // Update language button text
      const footerLangText = footer.querySelector('.footer-lang-text');
      if (footerLangText) footerLangText.textContent = 'Indonesia';
    }
  }

  // Listen for language change events from header
  window.addEventListener('languageChanged', ((e: CustomEvent) => {
    switchFooterLanguage(e.detail.language);
  }) as EventListener);

  // Load saved language on page load
  document.addEventListener('DOMContentLoaded', () => {
    const savedLang = localStorage.getItem('language') || 'EN';
    switchFooterLanguage(savedLang);
  });
</script>
