---
interface Props {
  src: string;
  alt: string;
  class?: string;
  width?: string;
  height?: string;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const { src, alt, class: className = '', width, height, loading = 'lazy', fetchpriority } = Astro.props;
---

<div class={`image-skeleton-wrapper ${className}`} style={width ? `width: ${width}` : ''}>
  <img
    src={src}
    alt={alt}
    class="skeleton-image"
    style={height ? `height: ${height}` : ''}
    loading={loading}
    {fetchpriority}
    onload="this.parentElement.classList.add('loaded')"
    onerror="this.parentElement.classList.add('loaded', 'error')"
  />
</div>

<style>
  .image-skeleton-wrapper {
    position: relative;
    overflow: hidden;
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    display: inline-block;
  }

  .image-skeleton-wrapper.loaded {
    background: none;
    animation: none;
  }

  .image-skeleton-wrapper.error {
    background: #ffcccc;
    animation: none;
  }

  .skeleton-image {
    position: relative;
    z-index: 2;
    opacity: 0;
    transition: opacity 0.3s ease-in;
    display: block;
  }

  .image-skeleton-wrapper.loaded .skeleton-image {
    opacity: 1;
  }

  @keyframes shimmer {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }
</style>
