---
interface Props {
  company: string;
  title: string;
  excerpt: string;
  industry: string;
  logo: string;
  coverImage: string;
  slug: string;
  dataIndustry?: string;
}

const { company, title, excerpt, industry, logo, coverImage, slug, dataIndustry } = Astro.props;

const industryLabels: Record<string, string> = {
  dental: 'Dental',
  pharmacy: 'Pharmacy',
  manufacture: 'Manufacturing',
  outsourcing: 'Outsourcing',
  logistic: 'Logistics',
  others: 'Others'
};
---

<article
  class="group relative bg-white rounded-lg shadow-md overflow-hidden hover:shadow-2xl transition-all duration-300"
  data-industry={dataIndustry || industry}
>
  <!-- Background Cover Image -->
  <div class="relative story-card-image overflow-hidden bg-gradient-to-br from-primary-50 to-primary-100">
    <img
      src={coverImage}
      alt={company}
      class="w-full h-full object-cover opacity-80 group-hover:opacity-90 group-hover:scale-105 transition-all duration-500"
      loading="lazy"
    />
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
  </div>

  <!-- Content Overlay -->
  <div class="absolute inset-0 p-8 flex flex-col justify-between">
    <!-- Company Logo -->
    <div class="flex justify-start">
      <div class="bg-white rounded-lg p-3 shadow-lg">
        <img
          src={logo}
          alt={`${company} logo`}
          class="h-8 w-auto object-contain"
          loading="lazy"
        />
      </div>
    </div>

    <!-- Bottom Content -->
    <div class="text-white">
      <!-- Industry Badge -->
      <div class="mb-3">
        <span class="inline-block bg-white/90 backdrop-blur-sm text-primary-800 px-3 py-1 rounded-full text-sm font-semibold">
          {industryLabels[industry] || industry}
        </span>
      </div>

      <!-- Title -->
      <h3 class="text-2xl font-bold mb-3 line-clamp-2 drop-shadow-lg">
        {title}
      </h3>

      <!-- Excerpt -->
      <p class="text-white/90 mb-4 line-clamp-2 drop-shadow-md">
        {excerpt}
      </p>

      <!-- Read Story Link -->
      <a
        href={`/customer-stories/${slug}`}
        class="inline-flex items-center text-white font-semibold hover:text-primary-200 transition-colors group-hover:translate-x-1 transform duration-300"
      >
        Read story
        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </div>
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .story-card-image {
    aspect-ratio: 16 / 10;
  }

  @media (max-width: 768px) {
    .story-card-image {
      aspect-ratio: 4 / 3;
    }
  }
</style>
