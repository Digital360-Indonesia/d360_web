<script>
  // Global state to manage cleanup
  let featuredProductsState = {
    scrollHandler: null,
    currentIndex: 0,
    initialized: false
  };

  // Function to cleanup previous instance
  function cleanupFeaturedProducts() {
    if (featuredProductsState.scrollHandler) {
      window.removeEventListener('scroll', featuredProductsState.scrollHandler);
      featuredProductsState.scrollHandler = null;
    }
    featuredProductsState.currentIndex = 0;
    featuredProductsState.initialized = false;
  }

  // Function to initialize FeaturedProducts
  function initFeaturedProducts() {
    // Clean up previous instance if exists
    cleanupFeaturedProducts();

    const productSections = document.querySelectorAll('.product-section');
    const productImages = document.querySelectorAll('.product-image');

    if (productSections.length === 0 || productImages.length === 0) {
      return; // Exit if elements don't exist
    }

    // Reset all images to hidden state first
    productImages.forEach((img, i) => {
      img.style.opacity = '0';
      img.style.pointerEvents = 'none';
      img.style.transform = 'scale(0.95)';
    });

    // Mark as initialized
    featuredProductsState.initialized = true;

    function updateActiveProduct(index) {
      if (index === featuredProductsState.currentIndex) return;

      // Update images
      productImages.forEach((image, i) => {
        if (i === index) {
          image.style.opacity = '1';
          image.style.pointerEvents = 'auto';
          image.style.transform = 'scale(1)';
        } else {
          image.style.opacity = '0';
          image.style.pointerEvents = 'none';
          image.style.transform = 'scale(0.95)';
        }
      });

      featuredProductsState.currentIndex = index;
    }

    // Scroll-based detection
    function handleScroll() {
      const viewportHeight = window.innerHeight;
      const scrollPosition = window.scrollY;

      productSections.forEach((section, index) => {
        const rect = section.getBoundingClientRect();
        const sectionTop = rect.top + scrollPosition;
        const sectionMiddle = sectionTop + (rect.height / 2);
        const currentViewportMiddle = scrollPosition + (viewportHeight / 2);

        // If this section is in the center area of viewport
        if (rect.top < viewportHeight * 0.6 && rect.bottom > viewportHeight * 0.4) {
          updateActiveProduct(index);
        }
      });
    }

    // Save handler reference for cleanup
    featuredProductsState.scrollHandler = handleScroll;

    // Listen to scroll events
    window.addEventListener('scroll', handleScroll, { passive: true });

    // Force initial check after a small delay to ensure DOM is ready
    setTimeout(() => {
      handleScroll();
      // Always show first product initially
      updateActiveProduct(0);
    }, 100);
  }

  // Initialize on DOM load
  document.addEventListener('DOMContentLoaded', initFeaturedProducts);

  // Re-initialize after view transition
  document.addEventListener('astro:after-swap', () => {
    setTimeout(() => {
      const hasFeaturedProducts = document.querySelector('#featured-products-section');
      if (hasFeaturedProducts) {
        initFeaturedProducts();
      }
    }, 100);
  });
</script>

