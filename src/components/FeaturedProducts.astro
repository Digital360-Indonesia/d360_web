<script>
  // Function to initialize FeaturedProducts
  function initFeaturedProducts() {
    const productSections = document.querySelectorAll('.product-section');
    const productImages = document.querySelectorAll('.product-image');

    let currentIndex = 0;

    function updateActiveProduct(index) {
      if (index === currentIndex) return;

      // Update images
      productImages.forEach((image, i) => {
        if (i === index) {
          image.style.opacity = '1';
          image.style.pointerEvents = 'auto';
          image.style.transform = 'scale(1)';
        } else {
          image.style.opacity = '0';
          image.style.pointerEvents = 'none';
          image.style.transform = 'scale(0.95)';
        }
      });

      currentIndex = index;
    }

    // Scroll-based detection
    function handleScroll() {
      const viewportHeight = window.innerHeight;
      const scrollPosition = window.scrollY;

      productSections.forEach((section, index) => {
        const rect = section.getBoundingClientRect();
        const sectionTop = rect.top + scrollPosition;
        const sectionMiddle = sectionTop + (rect.height / 2);
        const currentViewportMiddle = scrollPosition + (viewportHeight / 2);

        // Check if section middle is closest to viewport middle
        const distanceFromCenter = Math.abs(sectionMiddle - currentViewportMiddle);

        // If this section is in the center area of viewport
        if (rect.top < viewportHeight * 0.6 && rect.bottom > viewportHeight * 0.4) {
          updateActiveProduct(index);
        }
      });
    }

    // Listen to scroll events
    window.addEventListener('scroll', handleScroll, { passive: true });

    // Initial check
    handleScroll();

    // Initial state
    updateActiveProduct(0);

    // Ensure images are visible after navigation
    productImages.forEach((img, i) => {
      if (i === 0) {
        img.style.opacity = '1';
        img.style.pointerEvents = 'auto';
        img.style.transform = 'scale(1)';
      }
    });
  }

  // Initialize on DOM load
  document.addEventListener('DOMContentLoaded', initFeaturedProducts);

  // Re-initialize after view transition
  document.addEventListener('astro:after-swap', () => {
    setTimeout(initFeaturedProducts, 50);
  });
</script>

