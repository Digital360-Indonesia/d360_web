  // Skeleton Loading Handler - Simple and Clean
  function handleImageLoad(img) {
    // Check if already processed to avoid duplicate handling
    if (img.classList.contains('loaded')) {
      return;
    }

    const skeleton = img.parentElement.querySelector('.skeleton-placeholder');
    if (skeleton) {
      // Mark image as loaded (triggers fade in)
      img.classList.add('loaded');

      // Hide skeleton after short delay
      setTimeout(() => {
        skeleton.classList.add('hidden');
      }, 300);
    }
  }

  // Attach load handlers when DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    const productImages = document.querySelectorAll('.product-img');
    productImages.forEach(img => {
      if (img.complete && img.naturalHeight !== 0) {
        // Image already loaded
        handleImageLoad(img);
      } else {
        // Wait for load event
        img.addEventListener('load', () => handleImageLoad(img));
        img.addEventListener('error', () => {
          // On error, hide skeleton immediately
          const skeleton = img.parentElement.querySelector('.skeleton-placeholder');
          if (skeleton) skeleton.classList.add('hidden');
        });
      }
    });
  });

  // Re-attach handlers after view transition
  document.addEventListener('astro:after-swap', () => {
    setTimeout(() => {
      const productImages = document.querySelectorAll('.product-img');
      productImages.forEach(img => {
        if (img.complete && img.naturalHeight !== 0) {
          handleImageLoad(img);
        } else {
          img.addEventListener('load', () => handleImageLoad(img));
        }
      });
    }, 100);
  });
