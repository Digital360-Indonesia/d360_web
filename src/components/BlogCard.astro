---
interface Props {
  title: string;
  excerpt: string;
  category: string;
  date: string;
  readTime: string;
  image: string;
  slug: string;
  tags?: string[];
  dataCategory?: string;
}

const { title, excerpt, category, date, readTime, image, slug, tags, dataCategory } = Astro.props;
---

<article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300" data-category={dataCategory || category}>
  <!-- Image -->
  <div class="relative blog-card-image overflow-hidden">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
      loading="lazy"
    />
  </div>

  <!-- Content -->
  <div class="p-6">
    <!-- Category Badge & Tags -->
    <div class="mb-3 flex flex-wrap items-center gap-2">
      <span class="inline-block bg-primary-100 text-primary-800 px-3 py-1 rounded-full text-sm font-semibold">
        {category}
      </span>
      {tags && tags.length > 0 && (
        <>
          {tags.slice(0, 3).map((tag) => (
            <span class="inline-block bg-gray-100 text-gray-600 px-2 py-1 rounded-full text-xs font-medium">
              #{tag}
            </span>
          ))}
          {tags.length > 3 && (
            <span class="inline-block bg-gray-100 text-gray-600 px-2 py-1 rounded-full text-xs font-medium">
              +{tags.length - 3}
            </span>
          )}
        </>
      )}
    </div>

    <h3 class="text-xl font-bold mb-3 line-clamp-2 hover:text-primary-800 transition-colors">
      <a href={`/blog/${slug}`} class="hover:text-primary-800 transition-colors">
        {title}
      </a>
    </h3>

    <p class="text-gray-600 mb-4 line-clamp-3">
      {excerpt}
    </p>

    <!-- Meta Info -->
    <div class="flex items-center justify-between text-sm text-gray-500 mb-4">
      <div class="flex items-center space-x-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
        <span>{date}</span>
      </div>
      <div class="flex items-center space-x-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span>{readTime}</span>
      </div>
    </div>

    <!-- Read More Button -->
    <a
      href={`/blog/${slug}`}
      class="inline-flex items-center text-primary-800 font-semibold hover:text-primary-900 transition-colors"
    >
      Baca Selengkapnya
      <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </a>
  </div>
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card-image {
    aspect-ratio: 1200 / 715;
  }
</style>