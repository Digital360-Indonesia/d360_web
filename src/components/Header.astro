                    <!-- Subtle gradient overlay -->
                    <div class="absolute inset-0 bg-gradient-to-br from-purple-50/50 via-white to-pink-50/30 opacity-0 hover:opacity-100 transition-opacity duration-500"></div>

                    <div class="relative flex items-center gap-12">
                      <!-- Left Content -->
                      <div class="flex-1">
                        <img
                          src="/assets/images/tryon360-logo.png"
                          alt="Tryon360"
                          width="200"
                          height="56"
                          class="h-14 w-auto mb-6"
                        />
                        <p class="text-gray-700 mb-8 leading-relaxed text-sm">
                          Join our global partner network and unlock new opportunities for growth. Access exclusive resources, training, and support to deliver exceptional value to your clients.
                        </p>
                        <a href="https://wa.me/6285156858298" target="_blank" class="text-sm text-blue-600 font-medium inline-flex items-center hover:text-blue-700 transition-colors cta-text" data-lang-en="Check more" data-lang-id="Cek lebih lanjut">
