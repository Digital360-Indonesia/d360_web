            <span class="portfolio-text">Portfolio</span>
          </a>

          <a href="/blog" class="text-gray-700 hover:text-gray-900 font-medium transition-colors" data-lang-en="Blog" data-lang-id="Berita">
            <span class="blog-text">Blog</span>
          </a>

        </div>
      </div>

      <!-- Right side -->
      <div class="hidden md:flex items-center space-x-4">
        <!-- Language Dropdown -->
        <div class="relative group">
          <button class="flex items-center text-gray-700 hover:text-gray-900 font-medium transition-colors" id="language-btn">
            <span>EN</span>
            <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
