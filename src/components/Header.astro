          </svg>
          <span class="bookmeeting-text" data-lang-en="Book a Meeting" data-lang-id="Jadwalkan Pertemuan">Book a Meeting</span>
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <div class="md:hidden">
        <button class="p-2 text-gray-700" id="mobile-menu-btn">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </nav>
</header>

<!-- Fullscreen Mobile Navigation Overlay (outside header) -->
