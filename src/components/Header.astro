          <!-- Language Dropdown Menu -->
          <div class="absolute right-0 mt-2 w-24 bg-white rounded-lg shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200" id="language-dropdown">
            <a href="#" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 rounded-t-lg" onclick="event.preventDefault(); setLanguage('EN'); return false;">English</a>
            <a href="#" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 rounded-b-lg" onclick="event.preventDefault(); setLanguage('ID'); return false;">Indonesia</a>
          </div>
        </div>

        <!-- Sign In -->
        <a href="#signin" class="text-gray-700 hover:text-gray-900 font-medium transition-colors" data-lang-en="Sign in" data-lang-id="Masuk">
          <span class="signin-text">Sign in</span>
        </a>

        <!-- Book a Meeting Button -->
        <a href="https://wa.me/6285156858298" target="_blank" class="flex items-center bg-primary-800 hover:bg-primary-900 text-white font-medium px-4 py-2 rounded-lg transition-colors duration-200">
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
