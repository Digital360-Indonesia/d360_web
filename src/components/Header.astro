              src="/assets/images/tryon360-logo.png"
              alt="Tryon360"
              class="h-16 w-auto object-contain"
            />
          </div>
          <div class="p-5">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Tryon360</h3>
            <p class="text-sm text-gray-600 mb-3">AI-powered virtual try-on for fashion & e-commerce. Upload 2 photos and get realistic visualizations.</p>
            <div class="flex items-center text-blue-600 font-medium text-sm">
              <span>Try It Now</span>
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </div>
        </div>
      </a>
    </div>
  </div>
</div>

<script>
  // Fullscreen mobile navigation
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileNavOverlay = document.getElementById('mobile-nav-overlay');
  const mobileNavMain = document.getElementById('mobile-nav-main');
  const mobileNavProducts = document.getElementById('mobile-nav-products');
  const mobileProductsTrigger = document.getElementById('mobile-products-trigger');
  const mobileNavBack = document.getElementById('mobile-nav-back');
  const mobileNavClose = document.getElementById('mobile-nav-close');
  const mobileNavCloseSub = document.getElementById('mobile-nav-close-sub');

  // Open mobile nav
  function openMobileNav() {
    if (mobileNavOverlay) {
      mobileNavOverlay.classList.remove('translate-x-full');
      document.body.classList.add('mobile-nav-open');
    }
  }

  // Close mobile nav
  function closeMobileNav() {
    if (mobileNavOverlay) {
      mobileNavOverlay.classList.add('translate-x-full');
      document.body.classList.remove('mobile-nav-open');
    }
    // Reset to main menu
    setTimeout(() => {
      if (mobileNavProducts) mobileNavProducts.classList.add('hidden');
      if (mobileNavMain) mobileNavMain.classList.remove('hidden');
    }, 300);
  }

  // Show products submenu
  function showProductsSubmenu() {
    if (mobileNavMain) mobileNavMain.classList.add('hidden');
    if (mobileNavProducts) mobileNavProducts.classList.remove('hidden');
  }

  // Back to main menu
  function backToMainMenu() {
    if (mobileNavProducts) mobileNavProducts.classList.add('hidden');
    if (mobileNavMain) mobileNavMain.classList.remove('hidden');
  }

  // Event listeners
  if (mobileMenuBtn) mobileMenuBtn.addEventListener('click', openMobileNav);
  if (mobileNavClose) mobileNavClose.addEventListener('click', closeMobileNav);
  if (mobileNavCloseSub) mobileNavCloseSub.addEventListener('click', closeMobileNav);
  if (mobileProductsTrigger) mobileProductsTrigger.addEventListener('click', showProductsSubmenu);
  if (mobileNavBack) mobileNavBack.addEventListener('click', backToMainMenu);

  // Make functions available globally
  window.closeMobileNav = closeMobileNav;

  // Sticky header scroll effect
  const header = document.getElementById('main-header');

  window.addEventListener('scroll', () => {
    const scrollTop = window.pageYOffset || document.documentElement.scrollTop;

    // Add shadow and adjust opacity on scroll - header stays visible
    if (scrollTop > 10) {
      header?.classList.add('shadow-lg');
      header?.style.setProperty('background', 'rgba(255, 255, 255, 0.98)');
    } else {
      header?.classList.remove('shadow-lg');
      header?.style.setProperty('background', 'rgba(255, 255, 255, 0.95)');
    }
  });

  // Products dropdown category switching
  document.addEventListener('DOMContentLoaded', () => {
    const categoryTabs = document.querySelectorAll('.category-tab');
    const categoryContents = document.querySelectorAll('.category-content');

    categoryTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const category = tab.getAttribute('data-category');

        // Remove active class from all tabs
        categoryTabs.forEach(t => {
          t.classList.remove('active', 'border-blue-600', 'text-blue-600');
          t.classList.add('border-transparent', 'text-gray-600');
        });

        // Add active class to clicked tab
        tab.classList.add('active', 'border-blue-600', 'text-blue-600');
        tab.classList.remove('border-transparent', 'text-gray-600');

        // Hide all content sections
        categoryContents.forEach(content => {
          content.classList.add('hidden');
        });

        // Show selected content
        const selectedContent = document.getElementById(`${category}-content`);
        if (selectedContent) {
          selectedContent.classList.remove('hidden');
        }
      });
    });
  });

  // Language functionality
  function setLanguage(lang, skipSave = false, skipURL = false) {
    try {
      // Show loading state
      if (!skipSave) {
        document.body.classList.add('language-switching');
      }

      // Update language button display
      const langBtn = document.getElementById('language-btn');
      const span = langBtn?.querySelector('span');
      if (span) {
        span.textContent = lang;
      }

      // Update mobile language buttons active state
      const mobileLangEn = document.getElementById('mobile-lang-en');
      const mobileLangId = document.getElementById('mobile-lang-id');
      if (mobileLangEn && mobileLangId) {
        if (lang === 'EN') {
          mobileLangEn.classList.add('text-blue-600', 'font-bold');
          mobileLangEn.classList.remove('text-gray-700');
          mobileLangId.classList.remove('text-blue-600', 'font-bold');
          mobileLangId.classList.add('text-gray-700');
        } else {
          mobileLangId.classList.add('text-blue-600', 'font-bold');
          mobileLangId.classList.remove('text-gray-700');
          mobileLangEn.classList.remove('text-blue-600', 'font-bold');
          mobileLangEn.classList.add('text-gray-700');
        }
      }

      // Save to localStorage (unless skipSave is true)
      if (!skipSave) {
        localStorage.setItem('language', lang);
      }

      // Update URL without reload (unless skipURL is true)
      if (!skipURL) {
        const url = new URL(window.location);
        url.searchParams.set('lang', lang.toLowerCase());
        window.history.replaceState({}, '', url);
      }

      // Update all translatable elements
      const langKey = lang === 'EN' ? 'en' : 'id';

      // Helper function to get translation from element or its parent
      const getTranslation = (element, langKey) => {
        if (!element) return null;
        // Check element itself first
        let translation = element.getAttribute(`data-lang-${langKey}`);
        // If not found, check parent
        if (!translation && element.parentElement) {
          translation = element.parentElement.getAttribute(`data-lang-${langKey}`);
        }
        return translation;
      };

      // Update navigation items
      const productsText = document.querySelector('.products-text');
      if (productsText) {
        const translation = getTranslation(productsText, langKey);
        if (translation) productsText.textContent = translation;
      }

      const portfolioText = document.querySelector('.portfolio-text');
      if (portfolioText) {
        const translation = getTranslation(portfolioText, langKey);
        if (translation) portfolioText.textContent = translation;
      }

      const blogText = document.querySelector('.blog-text');
      if (blogText) {
        const translation = getTranslation(blogText, langKey);
        if (translation) blogText.textContent = translation;
      }

      const signinText = document.querySelector('.signin-text');
      if (signinText) {
        const translation = getTranslation(signinText, langKey);
        if (translation) signinText.textContent = translation;
      }

      const bookMeetingElement = document.querySelector('.bookmeeting-text');
      if (bookMeetingElement) {
        const translation = getTranslation(bookMeetingElement, langKey);
        if (translation) bookMeetingElement.textContent = translation;
      }

      // Update mobile menu items
      const mobileProducts = document.querySelector('.mobile-products-text');
      if (mobileProducts) {
        const translation = getTranslation(mobileProducts, langKey);
        if (translation) mobileProducts.textContent = translation;
      }

      const mobilePortfolio = document.querySelector('.mobile-portfolio-text');
      if (mobilePortfolio) {
        const translation = getTranslation(mobilePortfolio, langKey);
        if (translation) mobilePortfolio.textContent = translation;
      }

      const mobileBlog = document.querySelector('.mobile-blog-text');
      if (mobileBlog) {
        const translation = getTranslation(mobileBlog, langKey);
        if (translation) mobileBlog.textContent = translation;
      }

      const mobileSignin = document.querySelector('.mobile-signin-text');
      if (mobileSignin) {
        const translation = getTranslation(mobileSignin, langKey);
        if (translation) mobileSignin.textContent = translation;
      }

      const mobileBookMeeting = document.querySelector('.mobile-bookmeeting-text');
      if (mobileBookMeeting) {
        const translation = getTranslation(mobileBookMeeting, langKey);
        if (translation) mobileBookMeeting.textContent = translation;
      }

      // Update dropdown tabs
      document.querySelectorAll('.category-tab').forEach(tab => {
        const textSpan = tab.querySelector('.tab-text');
        if (textSpan) {
          const translation = tab.getAttribute(`data-lang-${langKey}`);
          if (translation) {
            textSpan.textContent = translation;
          }
        }
      });

      // Update schedule consultation
      const scheduleElement = document.querySelector('.schedule-text');
      if (scheduleElement) {
        const translation = getTranslation(scheduleElement, langKey);
        if (translation) scheduleElement.textContent = translation;
      }

      // Update CTA texts (Check more / Cek lebih lanjut)
      document.querySelectorAll('.cta-text').forEach(cta => {
        const translation = cta.getAttribute(`data-lang-${langKey}`);
        if (translation) {
          // Update only the text node, not the SVG
          const textNode = cta.childNodes[0];
          if (textNode && textNode.nodeType === Node.TEXT_NODE) {
            textNode.textContent = translation + ' ';
          }
        }
      });

      // Dispatch custom event for other components to listen
      const event = new CustomEvent('languageChanged', { detail: { language: lang } });
      window.dispatchEvent(event);

      // Hide loading state after a short delay for smooth transition
      if (!skipSave) {
        setTimeout(() => {
          document.body.classList.remove('language-switching');
        }, 150);
      }
    } catch (error) {
      console.error('Error changing language:', error);
      document.body.classList.remove('language-switching');
    }
  }

  // Initialize language on page load
  let languageInitialized = false;

  document.addEventListener('DOMContentLoaded', () => {
    if (languageInitialized) return;
    languageInitialized = true;

    const savedLang = localStorage.getItem('language') || 'EN';

    // Update language button display
    const langBtn = document.getElementById('language-btn');
    const span = langBtn?.querySelector('span');
    if (span) {
      span.textContent = savedLang;
    }

    // Update mobile language buttons active state
    const mobileLangEn = document.getElementById('mobile-lang-en');
    const mobileLangId = document.getElementById('mobile-lang-id');
    if (mobileLangEn && mobileLangId) {
      if (savedLang === 'EN') {
        mobileLangEn.classList.add('text-blue-600', 'font-bold');
        mobileLangEn.classList.remove('text-gray-700');
        mobileLangId.classList.remove('text-blue-600', 'font-bold');
        mobileLangId.classList.add('text-gray-700');
      } else {
        mobileLangId.classList.add('text-blue-600', 'font-bold');
        mobileLangId.classList.remove('text-gray-700');
        mobileLangEn.classList.remove('text-blue-600', 'font-bold');
        mobileLangEn.classList.add('text-gray-700');
      }
    }

    // Apply saved language (including EN to ensure consistency)
    // Use requestAnimationFrame for smooth rendering
    requestAnimationFrame(() => {
      setLanguage(savedLang, true, true); // skipSave = true, skipURL = true to avoid redundant write/update
    });
  });

  // Make setLanguage available globally
  window.setLanguage = setLanguage;
</script>

<style>
  .language-switching {
    cursor: wait !important;
    opacity: 0.95;
  }

  .language-switching * {
    pointer-events: none;
  }

  /* Mobile Navigation - simple transitions */
  #mobile-nav-main.hidden {
    display: none;
  }

  #mobile-nav-products.hidden {
    display: none;
  }

  /* Body scroll lock class */
  body.mobile-nav-open {
    overflow: hidden;
  }
</style>