        <!-- Logo -->
        <a href="/" class="flex items-center">
          <img
            src="/assets/images/logo-digital360-ori.png"
            alt="Digital360 Logo"
            class="h-12 w-auto"
          />
        </a>

        <!-- Desktop Navigation -->
        <div class="hidden md:flex items-center space-x-8">
          <!-- Products with dropdown -->
          <div class="relative group">
