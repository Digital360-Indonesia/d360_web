                      <!-- Right Image -->
                      <div class="flex-shrink-0">
                        <img
                          src="/assets/images/header-tryon360-right.png"
                          alt="Tryon360"
                          width="320"
                          height="240"
                          class="w-80 h-60 object-contain"
                        />
                      </div>
