---

<section id="global-stats-section" class="py-12 md:py-16 lg:py-20 bg-gray-50 relative overflow-hidden">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    <div class="grid lg:grid-cols-3 gap-8 md:gap-12 lg:gap-16 items-center">
      <!-- Left Content -->
      <div class="space-y-4 md:space-y-6 px-2">
        <!-- English Version -->
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 leading-tight" data-lang-en>
          Results That Drive Your Business Forward
        </h2>
        <!-- Bahasa Version -->
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 leading-tight hidden" data-lang-id>
          Hasil Nyata yang Mendorong Bisnis Anda Maju
        </h2>

        <!-- English Version -->
        <p class="text-sm sm:text-base md:text-lg text-gray-600" data-lang-en>
          We help businesses grow sustain in a longterm — with the right technologies to implemented.
        </p>
        <!-- Bahasa Version -->
        <p class="text-sm sm:text-base md:text-lg text-gray-600 hidden" data-lang-id>
          Kami bantu bisnis bertumbuh untuk sustain dalam jangka panjang - dengan implementasi teknologi yang sesuai.
        </p>

        <div class="space-y-2 md:space-y-3">
          <div class="text-4xl sm:text-5xl md:text-6xl font-bold text-blue-600">
            <span class="counter" data-target="97">0</span>%
          </div>
          <!-- English Version -->
          <p class="text-sm sm:text-base md:text-lg text-gray-900" data-lang-en>
            client satisfaction rate across multiple industries
          </p>
          <!-- Bahasa Version -->
          <p class="text-sm sm:text-base md:text-lg text-gray-900 hidden" data-lang-id>
            tingkat kepuasan klien di berbagai industri
          </p>
        </div>
      </div>

      <!-- Middle Content - Stats -->
      <div class="space-y-6 md:space-y-10 px-2">
        <!-- Stat 1 -->
        <div class="border-l-2 border-gray-300 pl-4 md:pl-6 space-y-1 md:space-y-2">
          <div class="text-4xl sm:text-5xl md:text-6xl font-bold text-blue-600">
            <span class="counter" data-target="2">0</span>x
          </div>
          <!-- English Version -->
          <p class="text-sm sm:text-base md:text-lg text-gray-900" data-lang-en>
            faster decision-making with real-time analytics dashboards
          </p>
          <!-- Bahasa Version -->
          <p class="text-sm sm:text-base md:text-lg text-gray-900 hidden" data-lang-id>
            Keputusan lebih cepat berkat dashboard analitik real-time
          </p>
        </div>

        <!-- Stat 2 -->
        <div class="border-l-2 border-gray-300 pl-4 md:pl-6 space-y-1 md:space-y-2">
          <div class="text-4xl sm:text-5xl md:text-6xl font-bold text-blue-600">
            <span class="counter" data-target="28">0</span>%
          </div>
          <!-- English Version -->
          <p class="text-sm sm:text-base md:text-lg text-gray-900" data-lang-en>
            average increase in workflow efficiency within 3 months of implementation
          </p>
          <!-- Bahasa Version -->
          <p class="text-sm sm:text-base md:text-lg text-gray-900 hidden" data-lang-id>
            Rata-rata peningkatan efisiensi kerja dalam 3 bulan implementasi
          </p>
        </div>
      </div>

      <!-- Right Content - Globe Graphic -->
      <div class="relative flex justify-center lg:justify-end order-first lg:order-last">
        <div class="relative w-full max-w-sm sm:max-w-md md:max-w-lg lg:max-w-xl">
          <img
            src="/assets/images/section4-logoimg.png"
            alt="Global Digital360 Network"
            width="600"
            height="600"
            loading="lazy"
            class="w-full h-auto"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Function to initialize counter animations
  function initGlobalStats() {
    const counters = document.querySelectorAll('.counter');
    let hasAnimated = false;

    const animateCounter = (counter: Element) => {
      const target = parseInt(counter.getAttribute('data-target') || '0');
      const duration = 2000; // 2 seconds animation
      const frameRate = 1000 / 60; // 60fps
      const totalFrames = Math.round(duration / frameRate);
      const increment = target / totalFrames;
      let current = 0;
      let frame = 0;

      const updateCounter = () => {
        frame++;
        current += increment;

        if (frame < totalFrames) {
          counter.textContent = Math.ceil(current).toLocaleString();
          requestAnimationFrame(updateCounter);
        } else {
          counter.textContent = target.toLocaleString();
        }
      };

      updateCounter();
    };

    // Intersection Observer for triggering animation when section is visible
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !hasAnimated) {
            hasAnimated = true;
            // Small delay to ensure smooth trigger
            setTimeout(() => {
              counters.forEach((counter) => {
                animateCounter(counter);
              });
            }, 100);
          }
        });
      },
      {
        threshold: 0.2, // Trigger when 20% of section is visible
        rootMargin: '0px 0px -100px 0px' // Trigger slightly before fully visible
      }
    );

    // Observe the section by ID
    const section = document.querySelector('#global-stats-section');
    if (section) {
      observer.observe(section);
    }
  }

  // Initialize on DOM load
  document.addEventListener('DOMContentLoaded', initGlobalStats);

  // Re-initialize after view transition
  document.addEventListener('astro:after-swap', () => {
    setTimeout(initGlobalStats, 50);
  });

  // Language switching functionality
  function switchLanguage(lang: string) {
    const section = document.querySelector('#global-stats-section');
    if (!section) return;

    const enElements = section.querySelectorAll('[data-lang-en]');
    const idElements = section.querySelectorAll('[data-lang-id]');

    if (lang === 'EN') {
      enElements.forEach(el => el.classList.remove('hidden'));
      idElements.forEach(el => el.classList.add('hidden'));
    } else if (lang === 'ID') {
      enElements.forEach(el => el.classList.add('hidden'));
      idElements.forEach(el => el.classList.remove('hidden'));
    }
  }

  // Listen for language change events
  window.addEventListener('languageChanged', ((e: CustomEvent) => {
    switchLanguage(e.detail.language);
  }) as EventListener);

  // Load saved language on page load
  document.addEventListener('DOMContentLoaded', () => {
    const savedLang = localStorage.getItem('language') || 'EN';
    switchLanguage(savedLang);
  });
</script>

<style>
  .counter {
    display: inline-block;
    min-width: 1ch;
  }
</style>