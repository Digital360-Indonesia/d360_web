---

<section class="py-10 sm:py-12 md:py-16 bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-8 md:mb-12 lg:mb-16 px-4">
      <h2 class="font-bold text-gray-900 mb-8 md:mb-12 text-xl sm:text-2xl md:text-3xl lg:text-[2.3rem]" id="clients-title">
        Trusted by Growing Indonesian Businesses
      </h2>

      <!-- Trust Badges -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 md:gap-8 mb-8 md:mb-16">
        <!-- Years Badge -->
        <div class="flex items-center bg-gray-50 rounded-lg px-4 md:px-6 py-3 md:py-4 w-full sm:w-auto justify-center">
          <img src="/assets/images/years-track-record-badge.png" alt="Years Badge" class="w-6 h-6 md:w-8 md:h-8 mr-2 md:mr-3">
          <span class="text-gray-700 font-medium text-sm md:text-base" id="badge-years">4+ Years Proven Track Record</span>
        </div>

        <!-- Industries Badge -->
        <div class="flex items-center bg-gray-50 rounded-lg px-4 md:px-6 py-3 md:py-4 w-full sm:w-auto justify-center">
          <img src="/assets/images/industries-served-badge.png" alt="Industries Badge" class="w-6 h-6 md:w-8 md:h-8 mr-2 md:mr-3">
          <span class="text-gray-700 font-medium text-sm md:text-base" id="badge-industries">Serving multiple industries nationwide</span>
        </div>
      </div>
    </div>

    <!-- Client Logos -->
    <div class="max-w-6xl mx-auto px-2 sm:px-4">
      <!-- Mobile Slider -->
      <div class="lg:hidden relative overflow-hidden">
        <div id="clients-slider" class="flex transition-transform duration-500 ease-in-out">
          <!-- Slide 1: Clients 1-3 -->
          <div class="w-full flex-shrink-0 px-2">
            <div class="grid grid-cols-3 gap-x-4 items-center justify-items-center">
              <div class="flex items-center justify-center h-12 sm:h-16 md:h-24">
                <img src="/assets/images/vido-garment-logo.png" alt="Vido Garment" class="h-12 sm:h-14 md:h-20 w-auto object-contain">
              </div>
              <div class="flex items-center justify-center h-12 sm:h-16 md:h-24">
                <img src="/assets/images/bfresh-dental-care-logo.png" alt="BFresh Dental Care" class="h-12 sm:h-14 md:h-20 w-auto object-contain">
              </div>
              <div class="flex items-center justify-center h-12 sm:h-16 md:h-24">
                <img src="/assets/images/paa-indonesia-logo.png" alt="PAA Indonesia" class="h-12 sm:h-14 md:h-20 w-auto object-contain">
              </div>
            </div>
          </div>

          <!-- Slide 2: Clients 4-6 -->
          <div class="w-full flex-shrink-0 px-2">
            <div class="grid grid-cols-3 gap-x-4 items-center justify-items-center">
              <div class="flex items-center justify-center h-12 sm:h-16 md:h-24">
                <img src="/assets/images/terminal-cargo-indonesia-logo.png" alt="Terminal Cargo Indonesia" class="h-12 sm:h-14 md:h-20 w-auto object-contain">
              </div>
              <div class="flex items-center justify-center h-12 sm:h-16 md:h-24">
                <img src="/assets/images/apotek-farmabox-logo.png" alt="Apotek Farmabox" class="h-12 sm:h-14 md:h-20 w-auto object-contain">
              </div>
              <div class="flex items-center justify-center h-12 sm:h-16 md:h-24">
                <img src="/assets/images/pln-uid-jatim-logo.png" alt="PLN UID Jawa Timur" class="h-12 sm:h-14 md:h-20 w-auto object-contain">
              </div>
            </div>
          </div>

          <!-- Slide 3: Clients 7-9 -->
          <div class="w-full flex-shrink-0 px-2">
            <div class="grid grid-cols-3 gap-x-4 items-center justify-items-center">
              <div class="flex items-center justify-center h-12 sm:h-16 md:h-24">
                <img src="/assets/images/pusaka-putra-jaya-logo.png" alt="Pusaka Putra Jaya" class="h-12 sm:h-14 md:h-20 w-auto object-contain">
              </div>
              <div class="flex items-center justify-center h-12 sm:h-16 md:h-24">
                <img src="/assets/images/lion-mti-perkasa-logo.png" alt="Lion MTI Perkasa" class="h-12 sm:h-14 md:h-20 w-auto object-contain">
              </div>
              <div class="flex items-center justify-center h-12 sm:h-16 md:h-24">
                <img src="/assets/images/pln-up3-tanah-bumbu-logo.png" alt="PLN UP3 Tanah Bumbu" class="h-12 sm:h-14 md:h-20 w-auto object-contain">
              </div>
            </div>
          </div>
        </div>

        <!-- Navigation Dots (Mobile Only) -->
        <div class="flex justify-center gap-2 mt-8">
          <button id="dot-0" class="w-2 h-2 rounded-full bg-blue-600 transition-all duration-300"></button>
          <button id="dot-1" class="w-2 h-2 rounded-full bg-gray-300 transition-all duration-300"></button>
          <button id="dot-2" class="w-2 h-2 rounded-full bg-gray-300 transition-all duration-300"></button>
        </div>
      </div>

      <!-- Desktop Grid: 2 rows x 5 columns -->
      <div class="hidden lg:grid grid-cols-5 gap-x-6 gap-y-8 items-center justify-items-center">
        <!-- Row 1 -->
        <div class="flex items-center justify-center h-20 lg:h-24">
          <img src="/assets/images/vido-garment-logo.png" alt="Vido Garment" class="h-16 lg:h-20 w-auto object-contain">
        </div>
        <div class="flex items-center justify-center h-20 lg:h-24">
          <img src="/assets/images/bfresh-dental-care-logo.png" alt="BFresh Dental Care" class="h-16 lg:h-20 w-auto object-contain">
        </div>
        <div class="flex items-center justify-center h-20 lg:h-24">
          <img src="/assets/images/paa-indonesia-logo.png" alt="PAA Indonesia" class="h-16 lg:h-20 w-auto object-contain">
        </div>
        <div class="flex items-center justify-center h-20 lg:h-24">
          <img src="/assets/images/terminal-cargo-indonesia-logo.png" alt="Terminal Cargo Indonesia" class="h-16 lg:h-20 w-auto object-contain">
        </div>
        <div class="flex items-center justify-center h-20 lg:h-24">
          <img src="/assets/images/apotek-farmabox-logo.png" alt="Apotek Farmabox" class="h-16 lg:h-20 w-auto object-contain">
        </div>

        <!-- Row 2 -->
        <div class="flex items-center justify-center h-20 lg:h-24">
          <img src="/assets/images/pln-uid-jatim-logo.png" alt="PLN UID Jawa Timur" class="h-16 lg:h-20 w-auto object-contain">
        </div>
        <div class="flex items-center justify-center h-20 lg:h-24">
          <img src="/assets/images/pusaka-putra-jaya-logo.png" alt="Pusaka Putra Jaya" class="h-16 lg:h-20 w-auto object-contain">
        </div>
        <div class="flex items-center justify-center h-20 lg:h-24">
          <img src="/assets/images/lion-mti-perkasa-logo.png" alt="Lion MTI Perkasa" class="h-16 lg:h-20 w-auto object-contain">
        </div>
        <div class="flex items-center justify-center h-20 lg:h-24">
          <img src="/assets/images/pln-up3-tanah-bumbu-logo.png" alt="PLN UP3 Tanah Bumbu" class="h-16 lg:h-20 w-auto object-contain">
        </div>
        <div class="flex items-center justify-center h-20 lg:h-24">
          <img src="/assets/images/tibed-dental-care-logo.svg" alt="Tibed Dental Care" class="h-12 lg:h-16 w-auto object-contain max-w-[140px]">
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Language translations
  const translations = {
    title: {
      EN: "Trusted by Growing Indonesian Businesses",
      ID: "Dipercaya oleh Bisnis Indonesia yang Sedang Bertumbuh"
    },
    badgeYears: {
      EN: "4+ Years Proven Track Record",
      ID: "4+ Tahun Terpercaya"
    },
    badgeIndustries: {
      EN: "Serving multiple industries nationwide",
      ID: "Melayani Berbagai Industri Nasional"
    }
  };

  // Update content based on language
  function updateClientsContent(lang) {
    const title = document.getElementById('clients-title');
    const badgeYears = document.getElementById('badge-years');
    const badgeIndustries = document.getElementById('badge-industries');

    if (title && translations.title[lang]) {
      title.textContent = translations.title[lang];
    }
    if (badgeYears && translations.badgeYears[lang]) {
      badgeYears.textContent = translations.badgeYears[lang];
    }
    if (badgeIndustries && translations.badgeIndustries[lang]) {
      badgeIndustries.textContent = translations.badgeIndustries[lang];
    }
  }

  // Listen for language change events
  window.addEventListener('languageChanged', (event) => {
    updateClientsContent(event.detail.language);
  });

  // Set initial language on page load
  document.addEventListener('DOMContentLoaded', () => {
    const savedLang = localStorage.getItem('language') || 'EN';
    updateClientsContent(savedLang);

    // Slider functionality
    const slider = document.getElementById('clients-slider');
    const dots = [
      document.getElementById('dot-0'),
      document.getElementById('dot-1'),
      document.getElementById('dot-2')
    ];
    let currentSlide = 0;
    const totalSlides = 3;

    function updateSlider() {
      if (slider) {
        slider.style.transform = `translateX(-${currentSlide * 100}%)`;
      }
      dots.forEach((dot, index) => {
        if (dot) {
          if (index === currentSlide) {
            dot.classList.remove('bg-gray-300');
            dot.classList.add('bg-blue-600');
          } else {
            dot.classList.remove('bg-blue-600');
            dot.classList.add('bg-gray-300');
          }
        }
      });
    }

    // Auto slide every 5 seconds
    setInterval(() => {
      currentSlide = (currentSlide + 1) % totalSlides;
      updateSlider();
    }, 5000);

    // Click on dots to navigate
    dots.forEach((dot, index) => {
      if (dot) {
        dot.addEventListener('click', () => {
          currentSlide = index;
          updateSlider();
        });
      }
    });
  });
</script>