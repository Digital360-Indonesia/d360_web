<section class="py-16 bg-white">
  <div class="container mx-auto px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="font-bold text-gray-900 mb-12" style="font-size: 2.3rem;" id="clients-title">
        Trusted by Growing Indonesian Businesses
      </h2>

      <!-- Trust Badges -->
      <div class="flex flex-col md:flex-row items-center justify-center gap-8 mb-16">
        <!-- Years Badge -->
        <div class="flex items-center bg-gray-50 rounded-lg px-6 py-4">
          <img src="/images/section2badges-1.png" alt="Years Badge" class="w-8 h-8 mr-3">
          <span class="text-gray-700 font-medium" id="badge-years">4+ Years Proven Track Record</span>
        </div>

        <!-- Industries Badge -->
        <div class="flex items-center bg-gray-50 rounded-lg px-6 py-4">
          <img src="/images/section2badges-2.png" alt="Industries Badge" class="w-8 h-8 mr-3">
          <span class="text-gray-700 font-medium" id="badge-industries">Serving multiple industries nationwide</span>
        </div>
      </div>
    </div>

    <!-- Client Logos Grid -->
    <div class="max-w-5xl mx-auto">
      <!-- First Row -->
      <div class="grid grid-cols-2 md:grid-cols-5 gap-x-4 gap-y-28 items-center justify-items-center mb-4">
        <!-- Client 1 -->
        <div class="flex items-center justify-center h-24">
          <img src="/images/section2-1.png" alt="Client 1" class="max-h-full max-w-full object-contain" style="width: auto; height: auto; max-height: 100px; max-width: 220px;">
        </div>

        <!-- Client 2 -->
        <div class="flex items-center justify-center h-24">
          <img src="/images/section2-2.png" alt="Client 2" class="max-h-full max-w-full object-contain" style="width: auto; height: auto; max-height: 100px; max-width: 220px;">
        </div>

        <!-- Client 3 -->
        <div class="flex items-center justify-center h-24">
          <img src="/images/section2-3.png" alt="Client 3" class="max-h-full max-w-full object-contain" style="width: auto; height: auto; max-height: 100px; max-width: 220px;">
        </div>

        <!-- Client 4 -->
        <div class="flex items-center justify-center h-24">
          <img src="/images/section2-4.png" alt="Client 4" class="max-h-full max-w-full object-contain" style="width: auto; height: auto; max-height: 100px; max-width: 220px;">
        </div>

        <!-- Client 5 -->
        <div class="flex items-center justify-center h-24">
          <img src="/images/section2-5.png" alt="Client 5" class="max-h-full max-w-full object-contain" style="width: auto; height: auto; max-height: 100px; max-width: 220px;">
        </div>
      </div>

      <!-- Second Row -->
      <div class="grid grid-cols-2 md:grid-cols-5 gap-x-4 gap-y-28 items-center justify-items-center">
        <!-- Client 6 -->
        <div class="flex items-center justify-center h-24">
          <img src="/images/section2-6.png" alt="Client 6" class="max-h-full max-w-full object-contain" style="width: auto; height: auto; max-height: 100px; max-width: 220px;">
        </div>

        <!-- Client 7 -->
        <div class="flex items-center justify-center h-24">
          <img src="/images/section2-7.png" alt="Client 7" class="max-h-full max-w-full object-contain" style="width: auto; height: auto; max-height: 100px; max-width: 220px;">
        </div>

        <!-- Client 8 -->
        <div class="flex items-center justify-center h-24">
          <img src="/images/section2-8.png" alt="Client 8" class="max-h-full max-w-full object-contain" style="width: auto; height: auto; max-height: 100px; max-width: 220px;">
        </div>

        <!-- Client 9 -->
        <div class="flex items-center justify-center h-24">
          <img src="/images/section2-9.png" alt="Client 9" class="max-h-full max-w-full object-contain" style="width: auto; height: auto; max-height: 100px; max-width: 220px;">
        </div>

        <!-- Client 10 -->
        <div class="flex items-center justify-center h-24">
          <img src="/images/section2-10.png" alt="Client 10" class="max-h-full max-w-full object-contain" style="width: auto; height: auto; max-height: 100px; max-width: 220px;">
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Language translations
  const translations = {
    title: {
      EN: "Trusted by Growing Indonesian Businesses",
      ID: "Dipercaya oleh Bisnis Indonesia yang Sedang Bertumbuh"
    },
    badgeYears: {
      EN: "4+ Years Proven Track Record",
      ID: "4+ Tahun Terpercaya"
    },
    badgeIndustries: {
      EN: "Serving multiple industries nationwide",
      ID: "Melayani Berbagai Industri Nasional"
    }
  };

  // Update content based on language
  function updateClientsContent(lang) {
    const title = document.getElementById('clients-title');
    const badgeYears = document.getElementById('badge-years');
    const badgeIndustries = document.getElementById('badge-industries');

    if (title && translations.title[lang]) {
      title.textContent = translations.title[lang];
    }
    if (badgeYears && translations.badgeYears[lang]) {
      badgeYears.textContent = translations.badgeYears[lang];
    }
    if (badgeIndustries && translations.badgeIndustries[lang]) {
      badgeIndustries.textContent = translations.badgeIndustries[lang];
    }
  }

  // Listen for language change events
  window.addEventListener('languageChanged', (event) => {
    updateClientsContent(event.detail.language);
  });

  // Set initial language on page load
  document.addEventListener('DOMContentLoaded', () => {
    const savedLang = localStorage.getItem('language') || 'EN';
    updateClientsContent(savedLang);
  });
</script>