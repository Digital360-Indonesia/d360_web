<section id="home" class="bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="pt-24 sm:pt-28 md:pt-32 pb-12 md:pb-16 lg:pb-20 text-center">
      <!-- Main Heading -->
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-normal text-gray-900 mb-6 md:mb-8 leading-tight max-w-5xl mx-auto px-2" data-lang-en="true">
        The Digital Partner for Businesses <span class="relative inline-block">
          <span class="relative z-10 font-bold">Ready</span>
          <svg class="absolute -bottom-1 sm:-bottom-2 left-0 w-full h-3 sm:h-4 z-0" viewBox="0 0 200 20" fill="none">
            <path d="M5 15 Q50 5 95 10 T185 12" stroke="#F59E0B" stroke-width="6" fill="none" stroke-linecap="round"/>
          </svg>
        </span> to Scale
      </h1>
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-normal text-gray-900 mb-6 md:mb-8 leading-tight max-w-5xl mx-auto px-2 hidden" data-lang-id="true">
        Partner Digital Bisnis Anda untuk <span class="relative inline-block">
          <span class="relative z-10 font-bold">Scale Up</span>
          <svg class="absolute -bottom-1 sm:-bottom-2 left-0 w-full h-3 sm:h-4 z-0" viewBox="0 0 200 20" fill="none">
            <path d="M5 15 Q50 5 95 10 T185 12" stroke="#F59E0B" stroke-width="6" fill="none" stroke-linecap="round"/>
          </svg>
        </span>
      </h1>

      <!-- Subtitle -->
      <p class="text-base sm:text-lg md:text-xl lg:text-2xl text-gray-600 mb-8 md:mb-12 max-w-4xl mx-auto px-4" data-lang-en="true">
        We build AI-powered systems that actually work for your business—custom dashboards, smart management tools, and digital solutions designed around how you really operate.
      </p>
      <p class="text-base sm:text-lg md:text-xl lg:text-2xl text-gray-600 mb-8 md:mb-12 max-w-4xl mx-auto px-4 hidden" data-lang-id="true">
        Bangun sistem digital yang efektif untuk bisnis Anda—dashboard AI-powered, tools manajemen terintegrasi, dan solusi custom yang mendukung pertumbuhan tanpa mengubah workflow Anda.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center items-center mb-10 md:mb-16 px-4">
        <a href="https://wa.me/6285706679500" target="_blank" class="w-full sm:w-auto bg-primary-800 hover:bg-primary-900 text-white font-semibold px-6 sm:px-8 py-3 sm:py-4 rounded-full transition-colors duration-200 inline-block text-center" data-lang-en="true">
          Get started
        </a>
        <a href="https://wa.me/6285706679500" target="_blank" class="w-full sm:w-auto bg-primary-800 hover:bg-primary-900 text-white font-semibold px-6 sm:px-8 py-3 sm:py-4 rounded-full transition-colors duration-200 inline-block text-center hidden" data-lang-id="true">
          Mulai Sekarang
        </a>
        <a href="https://wa.me/6285706679500" target="_blank" class="w-full sm:w-auto bg-white hover:bg-gray-50 text-black font-semibold px-6 sm:px-8 py-3 sm:py-4 rounded-full border border-gray-300 transition-colors duration-200 text-center" data-lang-en="true">
          Book a Consultation
        </a>
        <a href="https://wa.me/6285706679500" target="_blank" class="w-full sm:w-auto bg-white hover:bg-gray-50 text-black font-semibold px-6 sm:px-8 py-3 sm:py-4 rounded-full border border-gray-300 transition-colors duration-200 text-center hidden" data-lang-id="true">
          Hubungi Kami
        </a>
      </div>

      <!-- Video -->
      <div class="max-w-4xl mx-auto px-4">
        <div class="relative aspect-video bg-black rounded-2xl sm:rounded-3xl overflow-hidden shadow-xl">
          <!-- Loading skeleton - hidden once video loads -->
          <div id="video-skeleton" class="absolute inset-0 bg-gray-200 animate-pulse z-20">
            <div class="absolute inset-0 bg-gradient-to-br from-gray-300 via-gray-200 to-gray-300 opacity-50"></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-16 h-16 border-4 border-blue-600 border-t-transparent rounded-full animate-spin"></div>
            </div>
          </div>

          <!-- Animated gradient background behind video - hidden initially -->
          <div id="video-gradient" class="absolute inset-0 gradient-bg opacity-0 transition-opacity duration-500"></div>

          <!-- Video overlay -->
          <video
            id="hero-video"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster="/assets/images/hero-poster.jpg"
            class="w-full h-full object-cover relative z-10 opacity-0 transition-opacity duration-500"
          >
            <source src="/assets/videos/CSD-10721_WAC_Hero_FULL_LowBR.mp4" type="video/mp4">
            Your browser does not support the video tag.
          </video>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  svg path {
    stroke-dasharray: 300;
    stroke-dashoffset: 300;
  }

  svg path.animate-draw {
    animation: draw 2s ease-out 0.5s forwards;
  }

  /* Subtle slow-moving gradient animation */
  @keyframes gradientShift {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  .gradient-bg {
    background: linear-gradient(
      135deg,
      rgba(15, 45, 120, 0.65),     /* deeper navy blue - 65% opacity */
      rgba(30, 80, 200, 0.6),      /* vibrant blue - 60% opacity */
      rgba(50, 120, 220, 0.65),    /* bright blue - 65% opacity */
      rgba(15, 45, 120, 0.7)       /* deeper navy blue - 70% opacity */
    );
    background-size: 400% 400%;
    animation: gradientShift 20s ease-in-out infinite;
    opacity: 0.85;
  }
</style>

<script>
  // Language switching functionality
  function switchLanguage(lang: string) {
    // Only select elements within this Hero section, not the entire page
    const heroSection = document.querySelector('#home');
    if (!heroSection) return;

    const enElements = heroSection.querySelectorAll('[data-lang-en]');
    const idElements = heroSection.querySelectorAll('[data-lang-id]');

    if (lang === 'EN') {
      enElements.forEach(el => el.classList.remove('hidden'));
      idElements.forEach(el => el.classList.add('hidden'));
    } else if (lang === 'ID') {
      enElements.forEach(el => el.classList.add('hidden'));
      idElements.forEach(el => el.classList.remove('hidden'));
    }

    // Save language preference
    localStorage.setItem('language', lang);
  }

  // Listen for language change events
  window.addEventListener('languageChanged', ((e: CustomEvent) => {
    switchLanguage(e.detail.language);
  }) as EventListener);

  // Load saved language on page load and trigger animations
  document.addEventListener('DOMContentLoaded', () => {
    const savedLang = localStorage.getItem('language') || 'EN';
    switchLanguage(savedLang);

    // Trigger the "Ready" underline animation
    const svgPaths = document.querySelectorAll('#home svg path');
    svgPaths.forEach(path => {
      // Remove class first to reset
      path.classList.remove('animate-draw');
      // Force reflow
      void path.offsetWidth;
      // Add class to trigger animation
      path.classList.add('animate-draw');
    });
  });

  // Ensure video plays immediately with proper loading states
  function initHeroVideo() {
    const video = document.getElementById('hero-video') as HTMLVideoElement;
    const skeleton = document.getElementById('video-skeleton');
    const gradient = document.getElementById('video-gradient');

    if (video && skeleton && gradient) {
      // Hide skeleton and show video once it can play
      const handleCanPlay = () => {
        skeleton.style.display = 'none';
        video.style.opacity = '1';
        gradient.style.opacity = '0.85';
      };

      // Show skeleton if video takes too long
      const handleWaiting = () => {
        skeleton.style.display = 'block';
      };

      // Hide skeleton when playing
      const handlePlaying = () => {
        skeleton.style.display = 'none';
      };

      video.addEventListener('canplay', handleCanPlay);
      video.addEventListener('waiting', handleWaiting);
      video.addEventListener('playing', handlePlaying);

      // If video is already ready
      if (video.readyState >= 3) {
        handleCanPlay();
      }

      // Attempt to play
      const playPromise = video.play();

      if (playPromise !== undefined) {
        playPromise
          .then(() => {
            handleCanPlay();
          })
          .catch(error => {
            // Auto-play was prevented, retry on user interaction
            console.log('Autoplay prevented, will retry on interaction');
            document.addEventListener('click', () => {
              video.play().then(handleCanPlay);
            }, { once: true });
          });
      }
    }
  }

  // Initialize video immediately
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroVideo);
  } else {
    initHeroVideo();
  }

  // Also handle page show (back/forward cache)
  window.addEventListener('pageshow', (event) => {
    if (event.persisted) {
      initHeroVideo();
    }
  });
</script>