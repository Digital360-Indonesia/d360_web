---
---

<section id="cta-section" class="py-20 bg-white">
  <div class="container mx-auto px-6 lg:px-8 max-w-7xl">
    <!-- Main CTA Card -->
    <div class="relative rounded-3xl overflow-hidden">
      <!-- Gradient Layers -->
      <div class="absolute inset-0 bg-gradient-to-br from-[#0f172a] to-[#1e3a8a]"></div>
      <div class="absolute inset-0 bg-gradient-to-br from-[#1e3a8a] to-[#1e40af] gradient-layer-1"></div>
      <div class="absolute inset-0 bg-gradient-to-br from-[#7f1d1d] to-[#dc2626] gradient-layer-2"></div>

      <div class="relative grid lg:grid-cols-2 gap-8 items-center min-h-[400px]">

        <!-- Left Side - Abstract Shapes -->
        <div class="relative h-full min-h-[400px] flex items-center justify-center">
          <div class="absolute inset-0 flex items-center justify-center">
            <!-- Abstract 3D Shapes -->
            <div class="relative w-full h-full">
              <!-- Red/Orange Shape -->
              <div class="absolute top-1/4 left-1/4 w-48 h-48 bg-gradient-to-br from-red-500 via-orange-500 to-pink-400 rounded-full blur-3xl opacity-60 animate-float"></div>

              <!-- Purple/Pink Ribbon Shape -->
              <div class="absolute top-1/3 left-1/3 w-64 h-64">
                <div class="absolute inset-0 bg-gradient-to-br from-purple-600 via-purple-400 to-pink-400 rounded-3xl rotate-45 blur-2xl opacity-70 animate-float-delayed"></div>
              </div>

              <!-- Additional glow effects -->
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-56 h-56 bg-gradient-to-br from-pink-500 to-purple-500 rounded-full blur-3xl opacity-50"></div>
            </div>
          </div>
        </div>

        <!-- Right Side - Content -->
        <div class="relative z-10 px-8 lg:px-12 py-12 lg:py-16">
          <div class="space-y-6">
            <!-- English Version -->
            <div data-lang-en="true">
              <!-- Heading -->
              <h2 class="text-4xl lg:text-5xl font-bold text-white leading-tight mb-6">
                Ready to Scale<br>Your Business?
              </h2>

              <!-- Description -->
              <p class="text-xl text-gray-200 leading-relaxed max-w-xl mb-8">
                Custom AI solutions built for how you work.
              </p>

              <!-- CTA Button -->
              <div class="flex flex-wrap gap-4">
                <a href="https://wa.me/6285706679500" target="_blank" class="group relative px-10 py-4 bg-white text-gray-900 font-bold rounded-full overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-white/30">
                  <span class="relative z-10 flex items-center gap-2">
                    Book Your Free Demo
                    <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                  </span>
                  <div class="absolute inset-0 bg-gradient-to-r from-purple-400 via-pink-400 to-orange-400 opacity-0 group-hover:opacity-20 transition-opacity duration-300"></div>
                </a>
              </div>
            </div>

            <!-- Bahasa Indonesia Version -->
            <div class="hidden" data-lang-id="true">
              <!-- Heading -->
              <h2 class="text-4xl lg:text-5xl font-bold text-white leading-tight mb-6">
                Siap Scale Up<br>Bisnis Anda?
              </h2>

              <!-- Description -->
              <p class="text-xl text-gray-200 leading-relaxed max-w-xl mb-8">
                Solusi AI custom yang dibangun sesuai cara kerja Anda.
              </p>

              <!-- CTA Button -->
              <div class="flex flex-wrap gap-4">
                <a href="https://wa.me/6285706679500" target="_blank" class="group relative px-10 py-4 bg-white text-gray-900 font-bold rounded-full overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-white/30">
                  <span class="relative z-10 flex items-center gap-2">
                    Jadwalkan Demo Gratis
                    <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                  </span>
                  <div class="absolute inset-0 bg-gradient-to-r from-purple-400 via-pink-400 to-orange-400 opacity-0 group-hover:opacity-20 transition-opacity duration-300"></div>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-20px) rotate(5deg);
    }
  }

  @keyframes float-delayed {
    0%, 100% {
      transform: translateY(0) rotate(45deg);
    }
    50% {
      transform: translateY(-15px) rotate(50deg);
    }
  }

  @keyframes fadeInOut1 {
    0%, 33%, 100% {
      opacity: 0;
    }
    16% {
      opacity: 1;
    }
  }

  @keyframes fadeInOut2 {
    0%, 66% {
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
    83%, 100% {
      opacity: 0;
    }
  }

  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float-delayed 8s ease-in-out infinite;
  }

  .gradient-layer-1 {
    animation: fadeInOut1 30s ease-in-out infinite;
  }

  .gradient-layer-2 {
    animation: fadeInOut2 30s ease-in-out infinite;
  }
</style>

<script>
  // Language switching functionality
  function switchLanguage(lang: string) {
    // Only select elements within this CTA section
    const section = document.querySelector('#cta-section');
    if (!section) return;

    const enElements = section.querySelectorAll('[data-lang-en]');
    const idElements = section.querySelectorAll('[data-lang-id]');

    if (lang === 'EN') {
      enElements.forEach(el => el.classList.remove('hidden'));
      idElements.forEach(el => el.classList.add('hidden'));
    } else if (lang === 'ID') {
      enElements.forEach(el => el.classList.add('hidden'));
      idElements.forEach(el => el.classList.remove('hidden'));
    }
  }

  // Listen for language change events
  window.addEventListener('languageChanged', ((e: CustomEvent) => {
    switchLanguage(e.detail.language);
  }) as EventListener);

  // Load saved language on page load
  document.addEventListener('DOMContentLoaded', () => {
    const savedLang = localStorage.getItem('language') || 'EN';
    switchLanguage(savedLang);
  });
</script>
